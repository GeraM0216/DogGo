@{
    ViewData["Title"] = "Inicio";
}

@if (User.Identity.IsAuthenticated)
{
    <!-- Usuario logueado -->
    <div class="text-center py-4">
        <h2>¡Hola, @User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value! 🐾</h2>
        <p class="text-muted">¿Qué quieres hacer hoy?</p>
    </div>

    <div class="row g-3 justify-content-center mt-2">
        <div class="col-md-4">
            <a asp-controller="Paseo" asp-action="MisPaseos"
               class="card text-decoration-none h-100 p-4 text-center home-card">
                <div style="font-size:2.5rem">🦮</div>
                <h5 class="mt-2">Mis paseos</h5>
                <p class="text-muted small">Revisa el estado de tus paseos activos e historial</p>
            </a>
        </div>

        @if (User.IsInRole("Dueño"))
        {
            <div class="col-md-4">
                <a asp-controller="Paseador" asp-action="Directorio"
                   class="card text-decoration-none h-100 p-4 text-center home-card">
                    <div style="font-size:2.5rem">🔍</div>
                    <h5 class="mt-2">Buscar paseador</h5>
                    <p class="text-muted small">Encuentra el paseador ideal para tu mascota</p>
                </a>
            </div>
            <div class="col-md-4">
                <a asp-controller="Perro" asp-action="MisPerros"
                   class="card text-decoration-none h-100 p-4 text-center home-card">
                    <div style="font-size:2.5rem">🐶</div>
                    <h5 class="mt-2">Mis perros</h5>
                    <p class="text-muted small">Administra los perfiles de tus mascotas</p>
                </a>
            </div>
        }

        @if (User.IsInRole("Paseador"))
        {
            <div class="col-md-4">
                <a asp-controller="Paseador" asp-action="Perfil"
                   class="card text-decoration-none h-100 p-4 text-center home-card">
                    <div style="font-size:2.5rem">⭐</div>
                    <h5 class="mt-2">Mi perfil</h5>
                    <p class="text-muted small">Ve tus calificaciones y actualiza tu información</p>
                </a>
            </div>
        }
    </div>
}
else
{
    <!-- Landing para visitantes -->
    <div class="text-center py-5">
        <div style="font-size:4rem">🐾</div>
        <h1 class="fw-bold mt-2">DogGo</h1>
        <p class="lead text-muted">Conectamos dueños de mascotas con paseadores de confianza</p>
        <div class="d-flex gap-3 justify-content-center mt-4">
            <a asp-controller="Auth" asp-action="Register"
               class="btn btn-primary btn-lg px-4">
                Comenzar ahora
            </a>
            <a asp-controller="Paseador" asp-action="Directorio"
               class="btn btn-outline-secondary btn-lg px-4">
                Ver paseadores
            </a>
        </div>
    </div>

    <div class="row g-4 mt-4 text-center">
        <div class="col-md-4">
            <div class="p-3">
                <div style="font-size:2rem">🔒</div>
                <h6 class="mt-2">Paseadores verificados</h6>
                <p class="text-muted small">Todos los paseadores tienen perfil y calificaciones visibles</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3">
                <div style="font-size:2rem">📍</div>
                <h6 class="mt-2">Seguimiento en tiempo real</h6>
                <p class="text-muted small">Sigue la ubicación de tu mascota durante el paseo</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="p-3">
                <div style="font-size:2rem">💬</div>
                <h6 class="mt-2">Chat directo</h6>
                <p class="text-muted small">Comunícate con el paseador en cualquier momento</p>
            </div>
        </div>
    </div>
}

<style>
.home-card {
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    transition: box-shadow .2s, transform .2s;
    color: inherit;
    background: white;
}
.home-card:hover {
    box-shadow: 0 6px 20px rgba(0,0,0,.1);
    transform: translateY(-3px);
}
</style>