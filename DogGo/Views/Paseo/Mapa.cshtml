@model DogGo.Models.Paseo
@using System.Globalization

@{
    ViewData["Title"] = "Mapa del paseo";
    var esPaseador = (bool)ViewBag.EsPaseador;
    var esDuenio = !esPaseador;

    var tienePuntoRecoleccion = Model.LatitudRecogida.HasValue && Model.LongitudRecogida.HasValue;

    var lat = Model.LatitudActual != 0
        ? Model.LatitudActual
        : (Model.LatitudRecogida ?? 25.6866m);

    var lng = Model.LongitudActual != 0
        ? Model.LongitudActual
        : (Model.LongitudRecogida ?? -100.3161m);

    var latRecoleccionJs = (Model.LatitudRecogida ?? 0m).ToString(CultureInfo.InvariantCulture);
    var lngRecoleccionJs = (Model.LongitudRecogida ?? 0m).ToString(CultureInfo.InvariantCulture);

    string? googleMapsRecoleccionUrl = null;

    if (tienePuntoRecoleccion)
    {
        googleMapsRecoleccionUrl =
            $"https://www.google.com/maps?q={Model.LatitudRecogida!.Value.ToString(CultureInfo.InvariantCulture)},{Model.LongitudRecogida!.Value.ToString(CultureInfo.InvariantCulture)}";
    }

    var nombresPerros = (Model.PaseoPerros != null && Model.PaseoPerros.Any(pp => pp.Perro != null))
        ? string.Join(", ",
            Model.PaseoPerros
                .Where(pp => pp.Perro != null && !string.IsNullOrWhiteSpace(pp.Perro.Nombre))
                .Select(pp => pp.Perro!.Nombre)
                .Distinct())
        : (Model.Perro?.Nombre ?? "Perro");

    var cantidadPerros = (Model.PaseoPerros != null && Model.PaseoPerros.Any(pp => pp.Perro != null))
        ? Model.PaseoPerros
            .Where(pp => pp.Perro != null)
            .Select(pp => pp.PerroId)
            .Distinct()
            .Count()
        : (Model.Perro != null ? 1 : 0);

    var variosPerros = cantidadPerros > 1;
    var etiquetaPerros = variosPerros ? "Perros" : "Perro";
    var textoFotoInicio = variosPerros ? "Sube una foto de los perros para poder comenzar el paseo." : "Sube una foto del perro para poder comenzar el paseo.";
    var textoFotoFin = variosPerros ? "Antes de finalizar el paseo, sube una foto final de los perros como comprobante." : "Antes de finalizar el paseo, sube una foto final como comprobante.";

    var haySolicitudFinalizacionAnticipada =
        Model.Estado == "EnCurso" &&
        Model.FinalizacionAnticipadaSolicitada &&
        Model.FinalizacionAnticipadaAprobada == null;

    var duracionActualMinutos = 0;

    if (Model.Estado == "EnCurso" && Model.FechaInicio != null)
    {
        duracionActualMinutos = Math.Max(1, (int)Math.Ceiling((DateTime.UtcNow - Model.FechaInicio.Value).TotalMinutes));
    }

    var minutosCobradosEstimados = Math.Min(duracionActualMinutos, Model.DuracionMinutos);
    minutosCobradosEstimados = Math.Max(minutosCobradosEstimados, 15);

    var precioEstimadoAnticipado = Model.Paseador != null
        ? Math.Round(Model.Paseador.TarifaPorHora * (minutosCobradosEstimados / 60m), 2, MidpointRounding.AwayFromZero)
        : 0m;
}

<div class="mapa-container">

    <div class="mapa-header">
        <h5>
            Paseo de: @nombresPerros —
            <span id="estadoBadge" class="badge
                @(Model.Estado == "EnCurso" ? "bg-success" :
                                                     Model.Estado == "Finalizado" ? "bg-secondary" :
                                                     Model.Estado == "Cancelado" ? "bg-danger" : "bg-warning text-dark")">
                @Model.Estado
            </span>

            @if (variosPerros)
            {
                <span class="badge bg-primary ms-2">@cantidadPerros perros</span>
            }

            @if (Model.EsProgramado)
            {
                <span class="badge bg-info text-dark ms-2">Programado</span>
            }

            @if (haySolicitudFinalizacionAnticipada)
            {
                <span class="badge bg-danger ms-2">Finalización anticipada solicitada</span>
            }
        </h5>

        <div class="mapa-info">
            <span>🐶 @etiquetaPerros: @nombresPerros</span>
            <span>👤 Paseador: @Model.Paseador.Usuario.Nombre @Model.Paseador.Usuario.Apellido</span>
            <span>⏱ Duración solicitada: @Model.DuracionMinutos min</span>
            <span>💰 Precio actual: $@Model.Precio.ToString("0.00")</span>

            @if (Model.FechaInicio != null)
            {
                <span>▶ Inicio real: @Model.FechaInicio?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
            }
            else
            {
                <span>▶ Aún no inicia</span>
            }

            @if (Model.Estado == "EnCurso" && Model.FechaInicio != null)
            {
                var duracionActual = DateTime.UtcNow - Model.FechaInicio.Value;
                <span>🕒 Duración actual: @((int)duracionActual.TotalMinutes) min</span>
            }

            @if (Model.FechaFin != null)
            {
                <span>⏹ Fin real: @Model.FechaFin?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
            }

            @if (Model.DuracionRealMinutos.HasValue)
            {
                <span>✅ Duración real: @Model.DuracionRealMinutos min</span>
            }
            else if (Model.FechaInicio != null && Model.FechaFin != null)
            {
                var duracionReal = Model.FechaFin.Value - Model.FechaInicio.Value;
                <span>✅ Duración real: @((int)duracionReal.TotalMinutes) min</span>
            }
        </div>

        @if (Model.EsProgramado && Model.FechaProgramada != null)
        {
            <div class="mapa-programado">
                <strong>Programado para:</strong>
                @Model.FechaProgramada?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
            </div>
        }
    </div>

    @if (haySolicitudFinalizacionAnticipada)
    {
        <div class="alert alert-warning border-warning shadow-sm">
            <h6 class="fw-bold mb-2">Solicitud de finalización anticipada</h6>

            <p class="mb-1">
                El paseador solicitó terminar el paseo antes de cumplir la duración acordada.
            </p>

            <p class="mb-1">
                <strong>Motivo:</strong>
                @(string.IsNullOrWhiteSpace(Model.MotivoFinalizacionAnticipada) ? "Sin motivo registrado." : Model.MotivoFinalizacionAnticipada)
            </p>

            <p class="mb-1">
                <strong>Duración solicitada:</strong> @Model.DuracionMinutos min
            </p>

            <p class="mb-1">
                <strong>Tiempo realizado aprox.:</strong> @duracionActualMinutos min
            </p>

            <p class="mb-3">
                <strong>Nuevo precio estimado:</strong> $@precioEstimadoAnticipado.ToString("0.00")
            </p>

            @if (esDuenio)
            {
                <div class="d-flex gap-2 flex-wrap">
                    <button type="button"
                            class="btn btn-success"
                            onclick="responderFinalizacionAnticipada(true)">
                        Aceptar finalización
                    </button>

                    <button type="button"
                            class="btn btn-outline-danger"
                            onclick="responderFinalizacionAnticipada(false)">
                        Rechazar
                    </button>
                </div>
            }
            else
            {
                <div class="alert alert-info py-2 mb-0">
                    Esperando respuesta del dueño.
                </div>
            }
        </div>
    }

    <div class="recoleccion-box">
        <div class="recoleccion-header">
            <div>
                <h6 class="recoleccion-title">📍 Punto de recolección</h6>
                <p class="recoleccion-sub">
                    Esta es la ubicación donde el paseador debe recoger al perro.
                </p>
            </div>

            @if (!string.IsNullOrWhiteSpace(googleMapsRecoleccionUrl))
            {
                <a href="@googleMapsRecoleccionUrl"
                       target="_blank"
                       rel="noopener noreferrer"
                       class="btn-ver-maps">
                    Abrir en Maps
                </a>
            }
        </div>

        <div class="recoleccion-grid">
            <div class="recoleccion-item">
                <span class="recoleccion-label">Dirección</span>
                <span class="recoleccion-value">
                    @(string.IsNullOrWhiteSpace(Model.DireccionRecogida) ? "Sin dirección registrada" : Model.DireccionRecogida)
                </span>
            </div>

            <div class="recoleccion-item">
                <span class="recoleccion-label">Zona</span>
                <span class="recoleccion-value">
                    @(string.IsNullOrWhiteSpace(Model.ZonaRecogida) ? "Sin zona registrada" : Model.ZonaRecogida)
                </span>
            </div>

            <div class="recoleccion-item recoleccion-full">
                <span class="recoleccion-label">Referencias</span>
                <span class="recoleccion-value">
                    @(string.IsNullOrWhiteSpace(Model.ReferenciasRecogida) ? "Sin referencias adicionales" : Model.ReferenciasRecogida)
                </span>
            </div>
        </div>
    </div>

    <div id="map"></div>

    <div class="evidencias-box">
        <h6 class="evidencias-titulo">📸 Evidencia del paseo</h6>
        <p class="evidencias-sub">Aquí puedes revisar las fotos registradas al inicio y al final del paseo.</p>

        <div class="evidencias-grid">
            <div class="evidencia-card">
                <div class="evidencia-header">Foto de inicio</div>

                @if (!string.IsNullOrWhiteSpace(Model.FotoInicioUrl))
                {
                    <img src="@Model.FotoInicioUrl"
                         alt="Foto de inicio del paseo"
                         class="evidencia-img" />
                }
                else
                {
                    <div class="evidencia-empty">
                        Aún no se ha subido evidencia de inicio.
                    </div>
                }
            </div>

            <div class="evidencia-card">
                <div class="evidencia-header">Foto final</div>

                @if (!string.IsNullOrWhiteSpace(Model.FotoFinUrl))
                {
                    <img src="@Model.FotoFinUrl"
                         alt="Foto final del paseo"
                         class="evidencia-img" />
                }
                else
                {
                    <div class="evidencia-empty">
                        Aún no se ha subido evidencia de finalización.
                    </div>
                }
            </div>
        </div>
    </div>

    @if (esPaseador)
    {
        <div class="mapa-controles">

            @if (Model.Estado == "Pendiente")
            {
                <div class="accion-box">
                    <h6 class="mb-2">Para iniciar el paseo</h6>
                    <p class="text-muted small mb-3">
                        Antes de iniciar, revisa el punto de recolección y sube la foto de inicio.
                    </p>

                    <button id="btnIniciar"
                            class="btn btn-success w-100"
                            onclick="cambiarEstado('EnCurso')">
                        ▶ Iniciar paseo
                    </button>
                </div>

                <div id="panelFotoInicio"
                     class="foto-box mt-3"
                     style="display:@(string.IsNullOrWhiteSpace(Model.FotoInicioUrl) ? "none" : "block")">
                    <h6 class="mb-2">Evidencia de inicio</h6>
                    <p class="text-muted small mb-3">
                        @textoFotoInicio
                    </p>

                    <form asp-controller="Paseo"
                          asp-action="SubirFotoInicio"
                          method="post"
                          enctype="multipart/form-data"
                          class="mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="paseoId" value="@Model.Id" />

                        <div class="mb-2">
                            <input type="file"
                                   name="fotoInicio"
                                   class="form-control"
                                   accept=".jpg,.jpeg,.png,.webp"
                                   required />
                        </div>

                        <button type="submit" class="btn btn-outline-primary w-100">
                            @(string.IsNullOrWhiteSpace(Model.FotoInicioUrl) ? "Subir foto de inicio" : "Reemplazar foto de inicio")
                        </button>
                    </form>

                    @if (!string.IsNullOrWhiteSpace(Model.FotoInicioUrl))
                    {
                        <div class="alert alert-success py-2 mb-0">
                            Foto de inicio lista. Ya puedes presionar <strong>Iniciar paseo</strong>.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning py-2 mb-0">
                            Primero sube la foto de inicio y después vuelve a presionar <strong>Iniciar paseo</strong>.
                        </div>
                    }
                </div>
            }

            @if (Model.Estado == "EnCurso")
            {
                <div class="foto-box">
                    <h6 class="mb-2">Evidencia de finalización</h6>
                    <p class="text-muted small mb-3">
                        @textoFotoFin
                    </p>

                    <form asp-controller="Paseo"
                          asp-action="SubirFotoFin"
                          method="post"
                          enctype="multipart/form-data"
                          class="mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="paseoId" value="@Model.Id" />

                        <div class="mb-2">
                            <input type="file"
                                   name="fotoFin"
                                   class="form-control"
                                   accept=".jpg,.jpeg,.png,.webp"
                                   required="@string.IsNullOrWhiteSpace(Model.FotoFinUrl)" />
                        </div>

                        <button type="submit" class="btn btn-outline-primary w-100">
                            @(string.IsNullOrWhiteSpace(Model.FotoFinUrl) ? "Subir foto final" : "Reemplazar foto final")
                        </button>
                    </form>

                    @if (!string.IsNullOrWhiteSpace(Model.FotoFinUrl))
                    {
                        <div class="alert alert-success py-2 mb-0">
                            Ya subiste la foto final. Puedes intentar terminar el paseo.
                            Si todavía no se cumple el tiempo acordado, se pedirá motivo y aprobación del dueño.
                        </div>
                    }
                </div>

                @if (haySolicitudFinalizacionAnticipada)
                {
                    <button id="btnFinalizar"
                            class="btn btn-danger w-100"
                            disabled>
                        ⏹ Solicitud enviada al dueño
                    </button>

                    <small class="text-muted d-block mt-2">
                        No puedes enviar otra solicitud mientras el dueño no responda.
                    </small>
                }
                else
                {
                    <button id="btnFinalizar"
                            class="btn btn-danger w-100"
                            onclick="cambiarEstado('Finalizado')"
                            disabled="@(string.IsNullOrWhiteSpace(Model.FotoFinUrl) ? "disabled" : null)">
                        ⏹ Finalizar paseo
                    </button>
                }

                @if (string.IsNullOrWhiteSpace(Model.FotoFinUrl))
                {
                    <small class="text-danger d-block mt-2">
                        Debes subir una foto final antes de finalizar el paseo.
                    </small>
                }
            }

            @if (Model.Estado == "Finalizado")
            {
                <div class="alert alert-secondary mb-0">
                    El paseo ya fue finalizado.
                </div>
            }
        </div>
    }

    <div class="mapa-footer d-flex gap-2">
        <a asp-controller="Paseo" asp-action="MisPaseos"
               class="btn btn-outline-secondary w-100">
            ← Volver a mis paseos
        </a>

        <a asp-controller="Chat" asp-action="Index"
               asp-route-paseoId="@Model.Id"
               class="btn btn-outline-primary w-100">
            Abrir chat del paseo
        </a>
    </div>

</div>

<div id="modalFinalizacionAnticipada" class="doggo-modal-backdrop" style="display:none;">
    <div class="doggo-modal-card">
        <div class="doggo-modal-header">
            <div>
                <h5 class="mb-1">Finalización anticipada</h5>
                <p class="text-muted small mb-0">
                    El paseo aún no cumple la duración solicitada.
                </p>
            </div>

            <button type="button" class="doggo-modal-close" onclick="cerrarModalFinalizacionAnticipada()">✕</button>
        </div>

        <div class="alert alert-warning py-2">
            <div><strong>Duración solicitada:</strong> <span id="modalDuracionSolicitada">0</span> min</div>
            <div><strong>Tiempo realizado:</strong> <span id="modalMinutosReales">0</span> min</div>
            <div><strong>Nuevo precio estimado:</strong> $<span id="modalPrecioEstimado">0.00</span></div>
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Motivo de finalización anticipada</label>
            <textarea id="motivoFinalizacionAnticipada"
                      class="form-control"
                      rows="4"
                      maxlength="500"
                      placeholder="Ej. El perro se cansó, comenzó a llover, el dueño solicitó terminar antes, emergencia, etc."></textarea>
            <small class="text-muted">
                Este motivo se enviará al dueño para que acepte o rechace la finalización.
            </small>
        </div>

        <div class="d-flex gap-2">
            <button type="button"
                    class="btn btn-outline-secondary w-100"
                    onclick="cerrarModalFinalizacionAnticipada()">
                Cancelar
            </button>

            <button type="button"
                    class="btn btn-danger w-100"
                    onclick="enviarSolicitudFinalizacionAnticipada()">
                Enviar solicitud al dueño
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <script>
        const paseoId = @Model.Id;
        const esPaseador = @(esPaseador ? "true" : "false");
        const esDuenio = @(esDuenio ? "true" : "false");
        const tieneFotoInicio = @(!string.IsNullOrWhiteSpace(Model.FotoInicioUrl) ? "true" : "false");
        const tieneFotoFin = @(!string.IsNullOrWhiteSpace(Model.FotoFinUrl) ? "true" : "false");
        const latInicial = @lat.ToString(CultureInfo.InvariantCulture);
        const lngInicial = @lng.ToString(CultureInfo.InvariantCulture);
        const tienePuntoRecoleccion = @(tienePuntoRecoleccion ? "true" : "false");
        const latRecoleccion = @latRecoleccionJs;
        const lngRecoleccion = @lngRecoleccionJs;

        let watchId = null;
        let marker = null;
        let markerRecoleccion = null;
        let ruta = [];
        let polyline = null;
        let map = null;
        let ultimaPosicionEnviada = null;
        const DISTANCIA_MINIMA_METROS = 3;

        const connection = new signalR.HubConnectionBuilder()
        .withUrl("/paseohub")
        .withAutomaticReconnect()
        .build();

        function calcularDistanciaMetros(lat1, lng1, lat2, lng2) {
        const R = 6371000;
        const dLat = (lat2 - lat1) * Math.PI / 180;
        const dLng = (lng2 - lng1) * Math.PI / 180;

        const a =
        Math.sin(dLat / 2) * Math.sin(dLat / 2) +
        Math.cos(lat1 * Math.PI / 180) *
        Math.cos(lat2 * Math.PI / 180) *
        Math.sin(dLng / 2) * Math.sin(dLng / 2);

        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        return R * c;
        }

        try {
        map = L.map("map").setView([latInicial, lngInicial], 15);

        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        attribution: "© OpenStreetMap contributors"
        }).addTo(map);

        const iconoPaseo = L.divIcon({
        className: "",
        html: `<div style="font-size:28px;filter:drop-shadow(0 2px 4px rgba(0,0,0,.4))">🐕</div>`,
        iconSize: [32, 32],
        iconAnchor: [16, 32]
        });

        marker = L.marker([latInicial, lngInicial], { icon: iconoPaseo })
        .addTo(map)
        .bindPopup("Ubicación actual del paseo");

        if (tienePuntoRecoleccion) {
        const iconoRecoleccion = L.divIcon({
        className: "",
        html: `<div style="font-size:30px;filter:drop-shadow(0 2px 4px rgba(0,0,0,.35))">📍</div>`,
        iconSize: [34, 34],
        iconAnchor: [17, 34]
        });

        markerRecoleccion = L.marker([latRecoleccion, lngRecoleccion], { icon: iconoRecoleccion })
        .addTo(map)
        .bindPopup("Punto de recolección del perro");

        L.circle([latRecoleccion, lngRecoleccion], {
        radius: 35,
        color: "#0f9b8e",
        fillColor: "#0f9b8e",
        fillOpacity: 0.12,
        weight: 2
        }).addTo(map);
        }

        @if (Model.Ubicaciones != null && Model.Ubicaciones.Any())
        {
            <text>
                const historial = [
                @foreach (var u in Model.Ubicaciones)
                {
                    @:[@u.Latitud.ToString(CultureInfo.InvariantCulture), @u.Longitud.ToString(CultureInfo.InvariantCulture)],
                }
                ];

                ruta = [...historial];

                if (historial.length > 1) {
                polyline = L.polyline(historial, {
                color: "#0d6efd",
                weight: 3,
                opacity: 0.7
                }).addTo(map);

                map.fitBounds(polyline.getBounds(), { padding: [20, 20] });
                }
            </text>
        }
        } catch (err) {
        console.error("Error al inicializar el mapa:", err);
        }

        connection.on("RecibirUbicacion", (lat, lng) => {
        const pos = [lat, lng];

        if (marker) {
        marker.setLatLng(pos);
        }

        const ultimoPunto = ruta.length > 0 ? ruta[ruta.length - 1] : null;

        if (!ultimoPunto || calcularDistanciaMetros(ultimoPunto[0], ultimoPunto[1], lat, lng) >= DISTANCIA_MINIMA_METROS) {
        ruta.push(pos);

        if (!polyline && map && ruta.length > 1) {
        polyline = L.polyline(ruta, {
        color: "#0d6efd",
        weight: 3,
        opacity: 0.7
        }).addTo(map);
        } else if (polyline) {
        polyline.setLatLngs(ruta);
        }
        }
        });

        connection.on("AccionPaseoRechazada", (mensaje) => {
        alert(mensaje || "No se pudo realizar la acción.");
        });

        connection.on("FinalizacionAnticipadaRequerida", (minutosReales, duracionSolicitada, precioEstimado) => {
        mostrarModalFinalizacionAnticipada(minutosReales, duracionSolicitada, precioEstimado);
        });

        connection.on("SolicitudFinalizacionAnticipada", (minutosReales, duracionSolicitada, precioEstimado, motivo) => {
        if (esPaseador) {
        alert("Solicitud enviada al dueño. Debes esperar su respuesta.");
        } else {
        alert("El paseador solicitó finalizar antes de tiempo. Revisa la solicitud.");
        }

        setTimeout(() => {
        location.reload();
        }, 700);
        });

        connection.on("FinalizacionAnticipadaRespondida", (aprobada) => {
        if (aprobada) {
        alert("El dueño aceptó la finalización anticipada.");
        } else {
        alert("El dueño rechazó la finalización anticipada. El paseo debe continuar.");
        }

        setTimeout(() => {
        location.reload();
        }, 700);
        });

        connection.on("EstadoCambiado", (estado) => {
        const badge = document.getElementById("estadoBadge");

        if (badge) {
        badge.textContent = estado;
        badge.classList.remove("bg-warning", "text-dark", "bg-success", "bg-secondary", "bg-danger");

        if (estado === "Pendiente") {
        badge.classList.add("bg-warning", "text-dark");
        } else if (estado === "EnCurso") {
        badge.classList.add("bg-success");
        } else if (estado === "Finalizado") {
        badge.classList.add("bg-secondary");
        } else if (estado === "Cancelado") {
        badge.classList.add("bg-danger");
        }
        }

        if (estado === "EnCurso" && esPaseador) {
        iniciarGPS();
        }

        if (estado === "Finalizado") {
        detenerGPS();
        }

        setTimeout(() => {
        location.reload();
        }, 600);
        });

        connection.start()
        .then(() => connection.invoke("UnirseAPaseo", paseoId))
        .catch(err => console.error("SignalR error:", err));

        function iniciarGPS() {
        if (!navigator.geolocation) {
        alert("Tu navegador no soporta geolocalización");
        return;
        }

        if (watchId !== null) return;

        watchId = navigator.geolocation.watchPosition(
        (pos) => {
        const lat = pos.coords.latitude;
        const lng = pos.coords.longitude;

        if (ultimaPosicionEnviada) {
        const distancia = calcularDistanciaMetros(
        ultimaPosicionEnviada.lat,
        ultimaPosicionEnviada.lng,
        lat,
        lng
        );

        if (distancia < DISTANCIA_MINIMA_METROS) {
        return;
        }
        }

        ultimaPosicionEnviada = { lat, lng };

        connection.invoke("EnviarUbicacion", paseoId, lat, lng)
        .catch(err => console.error("Error GPS:", err));
        },
        (err) => {
        console.error("Error geolocalización:", err);
        },
        {
        enableHighAccuracy: true,
        maximumAge: 0,
        timeout: 8000
        }
        );
        }

        function detenerGPS() {
        if (watchId !== null) {
        navigator.geolocation.clearWatch(watchId);
        watchId = null;
        }

        ultimaPosicionEnviada = null;
        }

        function mostrarPanelFotoInicio() {
        const panel = document.getElementById("panelFotoInicio");

        if (panel) {
        panel.style.display = "block";
        panel.scrollIntoView({ behavior: "smooth", block: "center" });
        }
        }

        async function cambiarEstado(nuevoEstado) {
        if (nuevoEstado === "EnCurso") {
        if (!tieneFotoInicio) {
        mostrarPanelFotoInicio();
        alert("Para iniciar el paseo, primero sube la foto de inicio.");
        return;
        }

        const esProgramado = @(Model.EsProgramado ? "true" : "false");
        const fechaProgramada = "@(Model.FechaProgramada?.ToString("yyyy-MM-ddTHH:mm:ss") ?? "")";

        if (esProgramado && fechaProgramada) {
        const ahora = new Date();
        const programada = new Date(fechaProgramada);
        const inicioPermitido = new Date(programada.getTime() - 15 * 60 * 1000);

        if (ahora < inicioPermitido) {
        alert("Este paseo programado solo puede iniciarse 15 minutos antes de la hora programada.");
        return;
        }
        }

        if (!navigator.geolocation) {
        alert("Tu navegador no soporta geolocalización");
        return;
        }

        try {
        await new Promise((resolve, reject) => {
        navigator.geolocation.getCurrentPosition(
        (pos) => {
        const lat = pos.coords.latitude;
        const lng = pos.coords.longitude;

        ultimaPosicionEnviada = { lat, lng };

        if (marker) {
        marker.setLatLng([lat, lng]);
        }

        const ultimoPunto = ruta.length > 0 ? ruta[ruta.length - 1] : null;

        if (!ultimoPunto || calcularDistanciaMetros(ultimoPunto[0], ultimoPunto[1], lat, lng) >= DISTANCIA_MINIMA_METROS) {
        ruta.push([lat, lng]);

        if (!polyline && map && ruta.length > 1) {
        polyline = L.polyline(ruta, {
        color: "#0d6efd",
        weight: 3,
        opacity: 0.7
        }).addTo(map);
        } else if (polyline) {
        polyline.setLatLngs(ruta);
        }
        }

        connection.invoke("EnviarUbicacion", paseoId, lat, lng)
        .then(() => {
        iniciarGPS();
        resolve(pos);
        })
        .catch(err => reject(err));
        },
        (err) => reject(err),
        { enableHighAccuracy: true, maximumAge: 0, timeout: 10000 }
        );
        });
        } catch (err) {
        console.error("Error geolocalización al iniciar:", err);
        alert("No se pudo obtener tu ubicación. Revisa los permisos del navegador.");
        return;
        }
        }

        if (nuevoEstado === "Finalizado") {
        if (!tieneFotoFin) {
        alert("Debes subir una foto final antes de finalizar el paseo.");
        return;
        }
        }

        connection.invoke("CambiarEstado", paseoId, nuevoEstado)
        .catch(err => console.error("Error al cambiar estado:", err));
        }

        function mostrarModalFinalizacionAnticipada(minutosReales, duracionSolicitada, precioEstimado) {
        const modal = document.getElementById("modalFinalizacionAnticipada");
        const minutosSpan = document.getElementById("modalMinutosReales");
        const duracionSpan = document.getElementById("modalDuracionSolicitada");
        const precioSpan = document.getElementById("modalPrecioEstimado");
        const motivo = document.getElementById("motivoFinalizacionAnticipada");

        if (minutosSpan) minutosSpan.textContent = minutosReales;
        if (duracionSpan) duracionSpan.textContent = duracionSolicitada;
        if (precioSpan) precioSpan.textContent = Number(precioEstimado || 0).toFixed(2);
        if (motivo) motivo.value = "";

        if (modal) {
        modal.style.display = "flex";
        document.body.style.overflow = "hidden";
        }
        }

        function cerrarModalFinalizacionAnticipada() {
        const modal = document.getElementById("modalFinalizacionAnticipada");

        if (modal) {
        modal.style.display = "none";
        document.body.style.overflow = "";
        }
        }

        function enviarSolicitudFinalizacionAnticipada() {
        const motivo = document.getElementById("motivoFinalizacionAnticipada")?.value?.trim() || "";

        if (motivo.length < 5) {
        alert("Escribe un motivo válido para solicitar la finalización anticipada.");
        return;
        }

        connection.invoke("SolicitarFinalizacionAnticipada", paseoId, motivo)
        .then(() => {
        cerrarModalFinalizacionAnticipada();
        })
        .catch(err => {
        console.error("Error al solicitar finalización anticipada:", err);
        alert("No se pudo enviar la solicitud.");
        });
        }

        function responderFinalizacionAnticipada(aprobar) {
        const texto = aprobar
        ? "¿Aceptar la finalización anticipada del paseo?"
        : "¿Rechazar la finalización anticipada y continuar el paseo?";

        if (!confirm(texto)) {
        return;
        }

        connection.invoke("ResponderFinalizacionAnticipada", paseoId, aprobar)
        .catch(err => {
        console.error("Error al responder finalización anticipada:", err);
        alert("No se pudo enviar la respuesta.");
        });
        }

        @if (Model.Estado == "EnCurso" && esPaseador)
        {
            <text>iniciarGPS();</text>
        }
    </script>
}

