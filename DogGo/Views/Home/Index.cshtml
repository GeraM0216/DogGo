@{
    ViewData["Title"] = "Inicio";
    var nombre = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "Usuario";
}

@if (User.Identity.IsAuthenticated)
{
    <!-- ── HERO (usuario logueado) ── -->
    <section class="hero">
        <div class="hero-content">
            <div class="hero-kicker"><span>👋</span> Bienvenido de vuelta</div>
            <h1 class="hero-h1">
                ¡Hola,<br>
                <span class="line-purple">@nombre!</span> 🐾
            </h1>
            <p class="hero-sub">
                Gestiona tus paseos, revisa tu información y accede rápido a las
                funciones principales de DogGo.
            </p>
            <div class="hero-ctas">
                <a asp-controller="Paseo" asp-action="MisPaseos" class="btn-main">
                    Ver mis paseos
                </a>
                @if (User.IsInRole("Duenio"))
                {
                    <a asp-controller="Paseador" asp-action="Directorio" class="btn-ghost">
                        Buscar paseador
                    </a>
                }
                else if (User.IsInRole("Paseador"))
                {
                    <a asp-controller="Paseador" asp-action="Perfil" class="btn-ghost">
                        Ver mi perfil
                    </a>
                }
            </div>
        </div>

        <div class="hero-visual">
            <div class="float-badge b1"><div class="dot dot-g"></div> 1 paseo activo</div>
            <div class="hero-card">
                <span class="card-dog-big">🐕</span>
                <div class="card-title">Tu espacio DogGo</div>
                <div class="card-sub">
                    Accede rápido a tus paseos, perfil y herramientas principales
                    desde un panel claro y moderno.
                </div>
                <div class="card-tags">
                    @if (User.IsInRole("Duenio"))
                    {
                        <span class="tag tag-p">Cliente</span>
                    }
                    else if (User.IsInRole("Paseador"))
                    {
                        <span class="tag tag-p">Paseador</span>
                    }
                    <span class="tag tag-g">Activo</span>
                    <span class="tag tag-b">DogGo</span>
                </div>
            </div>
            <div class="float-badge b2"><div class="dot dot-p"></div> 4.9 ⭐ promedio</div>
        </div>
    </section>

    <!-- ── TICKER ── -->
    <div class="ticker-wrap">
        <div class="ticker">
            <span class="ticker-item"><span class="ticker-dot">●</span> Paseadores verificados</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Seguimiento GPS</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Chat en tiempo real</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Calificaciones visibles</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Perfiles detallados</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Historial de paseos</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Paseadores verificados</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Seguimiento GPS</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Chat en tiempo real</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Calificaciones visibles</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Perfiles detallados</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Historial de paseos</span>
        </div>
    </div>

    <!-- ── ACCESOS RÁPIDOS ── -->
    <section class="home-section">
        <div class="section-label">Accesos rápidos</div>
        <h2 class="section-title">Todo en<br>un solo lugar.</h2>
        <p class="section-sub">Las funciones que más usas, siempre a un clic de distancia.</p>

        <div class="qa-grid">
            <a asp-controller="Paseo" asp-action="MisPaseos" class="qa-card">
                <div class="feat-icon ic-p">🦮</div>
                <h5>Mis paseos</h5>
                <p>Revisa el estado de tus paseos activos, historial y seguimiento.</p>
            </a>

            @if (User.IsInRole("Duenio"))
            {
                <a asp-controller="Paseador" asp-action="Directorio" class="qa-card">
                    <div class="feat-icon ic-g">🔍</div>
                    <h5>Buscar paseador</h5>
                    <p>Encuentra el paseador ideal para tu mascota de forma rápida.</p>
                </a>

                <a asp-controller="Perro" asp-action="Index" class="qa-card">
                    <div class="feat-icon ic-b">🐶</div>
                    <h5>Mis perros</h5>
                    <p>Administra los perfiles y datos de tus mascotas.</p>
                </a>
            }

            @if (User.IsInRole("Paseador"))
            {
                <a asp-controller="Paseador" asp-action="Perfil" class="qa-card">
                    <div class="feat-icon ic-g">⭐</div>
                    <h5>Mi perfil</h5>
                    <p>Consulta tus calificaciones y mantén tu información actualizada.</p>
                </a>
            }
        </div>
    </section>
}
else
{
    <!-- ── HERO (visitante) ── -->
    <section class="hero">
        <div class="hero-content">
            <div class="hero-kicker"><span>🐾</span> Plataforma de paseos</div>
            <h1 class="hero-h1">
                Tu perro merece<br>
                <span class="line-purple">paseos</span><br>
                <span class="line-green">increíbles.</span>
            </h1>
            <p class="hero-sub">
                Conectamos dueños con paseadores confiables. Chat en tiempo real,
                seguimiento GPS y perfiles verificados.
            </p>
            <div class="hero-ctas">
                <a asp-controller="Auth" asp-action="Register" class="btn-main">
                    Comenzar ahora
                </a>
                <a asp-controller="Paseador" asp-action="Directorio" class="btn-ghost">
                    Ver paseadores
                </a>
            </div>
        </div>

        <div class="hero-visual">
            <div class="float-badge b1"><div class="dot dot-g"></div> Paseo activo</div>
            <div class="hero-card">
                <span class="card-dog-big">🐶</span>
                <div class="card-title">DogGo</div>
                <div class="card-sub">
                    Una forma simple de organizar paseos y seguir a tu mascota
                    en tiempo real.
                </div>
                <div class="card-tags">
                    <span class="tag tag-p">Paseadores verificados</span>
                    <span class="tag tag-g">GPS en tiempo real</span>
                    <span class="tag tag-b">Chat directo</span>
                </div>
            </div>
            <div class="float-badge b2"><div class="dot dot-p"></div> 3 paseadores cerca</div>
        </div>
    </section>

    <!-- ── TICKER ── -->
    <div class="ticker-wrap">
        <div class="ticker">
            <span class="ticker-item"><span class="ticker-dot">●</span> Paseadores verificados</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Seguimiento GPS</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Chat en tiempo real</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Calificaciones visibles</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Perfiles detallados</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Historial de paseos</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Paseadores verificados</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Seguimiento GPS</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Chat en tiempo real</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Calificaciones visibles</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Perfiles detallados</span>
            <span class="ticker-item"><span class="ticker-dot">●</span> Historial de paseos</span>
        </div>
    </div>

    <!-- ── POR QUÉ DOGGO ── -->
    <section class="home-section">
        <div class="section-label">¿Por qué DogGo?</div>
        <h2 class="section-title">Funciones pensadas<br>para ti y tu mascota.</h2>
        <p class="section-sub">
            Todo lo que necesitas para organizar paseos seguros, cómodos
            y con total transparencia.
        </p>

        <div class="cards-grid">
            <div class="feat-card c-p">
                <div class="feat-icon ic-p">🔒</div>
                <div class="feat-title">Paseadores verificados</div>
                <p class="feat-desc">
                    Consulta perfiles, calificaciones e información antes de
                    elegir a alguien para tu perro.
                </p>
            </div>
            <div class="feat-card c-g">
                <div class="feat-icon ic-g">📍</div>
                <div class="feat-title">Seguimiento en tiempo real</div>
                <p class="feat-desc">
                    Sigue la ubicación de tu mascota durante todo el paseo
                    desde la app.
                </p>
            </div>
            <div class="feat-card c-b">
                <div class="feat-icon ic-b">💬</div>
                <div class="feat-title">Chat directo</div>
                <p class="feat-desc">
                    Comunícate con el paseador en cualquier momento,
                    sin intermediarios.
                </p>
            </div>
        </div>
    </section>
}
