@model List<DogGo.Models.Paseador>
@using DogGo.Models

@{
    ViewData["Title"] = "Paseadores disponibles";
}

<div class="container mt-4">
    <h4>Paseadores disponibles</h4>

    @if (!Model.Any())
    {
        <p class="text-muted mt-3">No hay paseadores disponibles en este momento.</p>
    }
    else
    {
        <div class="row mt-3 g-3">
            @foreach (var p in Model)
            {
                <div class="col-md-6">
                    <div class="card h-100 p-3 shadow-sm border-0 directorio-card">
                        <div class="d-flex align-items-center gap-3">
                            @if (!string.IsNullOrWhiteSpace(p.FotoUrl))
                            {
                                <img src="@p.FotoUrl"
                                     alt="Foto de @p.Usuario.Nombre @p.Usuario.Apellido"
                                     class="directorio-foto" />
                            }
                            else
                            {
                                <div class="directorio-foto-placeholder">🐾</div>
                            }

                            <div class="flex-grow-1">
                                <h6 class="mb-0">@p.Usuario.Nombre @p.Usuario.Apellido</h6>
                                <small class="text-muted">$@p.TarifaPorHora / hora</small>
                            </div>

                            <div class="text-end">
                                <div style="color:#ffc107">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span>@(i <= Math.Round((double)p.CalificacionPromedio) ? "★" : "☆")</span>
                                    }
                                </div>
                                <small class="text-muted">@p.CalificacionPromedio.ToString("0.0")</small>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(p.Descripcion))
                        {
                            <p class="mt-3 mb-2 small text-muted">@p.Descripcion</p>
                        }

                        <a asp-action="Perfil" asp-route-id="@p.Id"
                               class="btn btn-outline-primary btn-sm mt-auto">
                            Ver perfil
                        </a>

                        @if (User.IsInRole("Duenio"))
                        {
                            var perros = ViewBag.Perros as List<Perro>;

                            if (perros != null && perros.Any())
                            {
                                <form asp-controller="Paseo" asp-action="Crear" method="post" class="mt-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="paseadorId" value="@p.Id" />

                                    <div class="mb-2">
                                        <select name="perroId" class="form-select form-select-sm" required>
                                            <option value="">Selecciona uno de tus perros</option>
                                            @foreach (var perro in perros)
                                            {
                                                <option value="@perro.Id">@perro.Nombre</option>
                                            }
                                        </select>
                                    </div>

                                    <div class="mb-2">
                                        <input type="number"
                                               name="precio"
                                               class="form-control form-control-sm"
                                               step="0.01"
                                               min="0"
                                               value="@p.TarifaPorHora"
                                               placeholder="Precio"
                                               required />
                                    </div>

                                    <div class="mb-2">
                                        <label class="form-label small fw-semibold mb-1">Duración del paseo</label>
                                        <select name="duracionMinutos" class="form-select form-select-sm" required>
                                            <option value="">Selecciona duración</option>
                                            <option value="30">30 minutos</option>
                                            <option value="60">60 minutos</option>
                                            <option value="90">90 minutos</option>
                                            <option value="120">120 minutos</option>
                                        </select>
                                    </div>

                                    <div class="mb-2">
                                        <label class="form-label small fw-semibold mb-1">Tipo de paseo</label>

                                        <div class="form-check">
                                            <input class="form-check-input tipo-paseo"
                                                   type="radio"
                                                   name="esProgramado"
                                                   id="ahora_@p.Id"
                                                   value="false"
                                                   checked>
                                            <label class="form-check-label" for="ahora_@p.Id">
                                                Paseo ahora
                                            </label>
                                        </div>

                                        <div class="form-check">
                                            <input class="form-check-input tipo-paseo"
                                                   type="radio"
                                                   name="esProgramado"
                                                   id="programado_@p.Id"
                                                   value="true"
                                                   data-target="fecha-programada-@p.Id">
                                            <label class="form-check-label" for="programado_@p.Id">
                                                Programar paseo
                                            </label>
                                        </div>
                                    </div>

                                    <div class="mb-2 fecha-programada d-none" id="fecha-programada-@p.Id">
                                        <label class="form-label small fw-semibold mb-1">Fecha y hora</label>
                                        <input type="datetime-local"
                                               name="fechaProgramada"
                                               class="form-control form-control-sm" />
                                    </div>

                                    <button type="submit" class="btn btn-primary btn-sm w-100">
                                        Solicitar paseo
                                    </button>
                                </form>
                            }
                            else
                            {
                                <div class="alert alert-warning mt-2 mb-0 p-2 small">
                                    Primero registra al menos un perro para poder solicitar paseos.
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const radios = document.querySelectorAll(".tipo-paseo");

        radios.forEach(radio => {
            radio.addEventListener("change", function () {
                const form = this.closest("form");
                if (!form) return;

                const contenedorFecha = form.querySelector(".fecha-programada");
                const inputFecha = contenedorFecha?.querySelector("input[name='fechaProgramada']");

                if (!contenedorFecha || !inputFecha) return;

                const programado = form.querySelector("input[name='esProgramado'][value='true']");

                if (programado && programado.checked) {
                    contenedorFecha.classList.remove("d-none");
                    inputFecha.required = true;
                } else {
                    contenedorFecha.classList.add("d-none");
                    inputFecha.required = false;
                    inputFecha.value = "";
                }
            });
        });
    });
</script>

<style>
    .directorio-card {
        border-radius: 16px;
    }

    .directorio-foto {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid #ddd;
        flex-shrink: 0;
    }

    .directorio-foto-placeholder {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        border: 1px solid #ddd;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        background: #f8f9fa;
        flex-shrink: 0;
    }
</style>