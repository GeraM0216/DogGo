    <!-- ══ CTA FINAL ══ -->
    <section class="cta-section">
        <div class="cta-inner">
            <div class="cta-header">
                <div class="cta-badge">🎉 ¿Te convencimos?</div>
                <h2 class="cta-title">Prueba nuestros <span class="cta-em">servicios hoy</span></h2>
                <p class="cta-sub">Únete a la comunidad de dueños que ya le dan a sus mascotas la mejor experiencia de paseo.</p>
            </div>
            <div class="cta-grid">
                <div class="cta-card">
                    <span class="cta-card-icon">🔒</span>
                    <div class="cta-card-title">Paseadores verificados</div>
                    <div class="cta-card-desc">Perfiles reales con calificaciones de otros dueños.</div>
                </div>
                <div class="cta-card">
                    <span class="cta-card-icon">📍</span>
                    <div class="cta-card-title">Seguimiento GPS</div>
