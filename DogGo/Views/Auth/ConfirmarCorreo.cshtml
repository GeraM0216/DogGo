
@{
    Layout = null;
    ViewData["Title"] = "Confirmar correo";
    var email = ViewBag.Email as string;
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="confirm-container">
    <div class="confirm-card">

        <h2 class="fw-bold mb-2">Confirmar correo</h2>
        <p class="text-muted">
            Ingresa el correo y el código de 6 dígitos que te enviamos.
        </p>

        @if (!string.IsNullOrWhiteSpace(email))
        {
            <div class="alert alert-info">
                Código enviado para: <strong>@email</strong>
            </div>
        }

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form asp-action="ConfirmarCorreo" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label class="form-label">Correo</label>
                <input name="email" class="form-control" value="@email" />
            </div>

            <div class="mb-3">
                <label class="form-label">Código</label>
                <input name="codigo" class="form-control" maxlength="6" />
            </div>

            <button type="submit" class="btn btn-dark w-100">
                Confirmar correo
            </button>
        </form>

        @if (!string.IsNullOrWhiteSpace(email))
        {
            <form asp-action="ReenviarCodigo" method="post" class="mt-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="email" value="@email" />

                <button type="submit" class="btn btn-outline-secondary w-100">
                    Reenviar código
                </button>
            </form>
        }

        <div class="confirm-footer">
             <a asp-action="Login">Volver al inicio de sesión</a>
        </div>

    </div>
</div>


<style>
/* Box */
.confirm-container {
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;

    background: url('/Images/parque-ecologico.jpg') center/cover no-repeat;
    position: relative;
}

/* Blur */
.confirm-container::before {
    content: "";
    position: absolute;
    inset: 0;

    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);

    background: rgba(0,0,0,0.2);
}

/* Card */
.confirm-card {
    width: 400px;
    max-width: 90%;
    padding: 30px;
    border-radius: 20px;

    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);

    border: 1px solid rgba(255,255,255,0.3);
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);

    position: relative;
    z-index: 2;

    animation: aparecer 0.6s ease;
}

/* Inputs */
.confirm-card .form-control {
    background: rgba(255,255,255,0.6);
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.4);
    transition: all 0.2s ease;
}

.confirm-card .form-control:focus {
    background: rgba(255,255,255,0.85);
    transform: scale(1.02);
    box-shadow: none;
}

/* Boton principal */
.confirm-card .btn-dark {
    background: linear-gradient(135deg, #4f46e5, #6366f1);
    border: none;
    border-radius: 10px;
    transition: all 0.2s ease;
}

.confirm-card .btn-dark:hover {
    transform: scale(1.03);
    filter: brightness(1.1);
}

/* Boton secundario */
.confirm-card .btn-outline-secondary {
    border-radius: 10px;
}

/* Animacion */
@@keyframes aparecer {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}
.confirm-footer {
    margin-top: 20px;
    padding: 15px;
    text-align: center;

    background: rgba(0, 0, 0, 0.35);
    border-radius: 12px;

    backdrop-filter: blur(10px);
}

.confirm-footer a {
    color: #fff;
    font-weight: 500;
    text-decoration: none;
}

.confirm-footer a:hover {
    text-decoration: underline;
}
</style>