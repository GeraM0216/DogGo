@model DogGo.Models.Paseo
@using System.Globalization

@{
    ViewData["Title"] = "Mapa del paseo";
    var esPaseador = (bool)ViewBag.EsPaseador;
    var lat = Model.LatitudActual != 0 ? Model.LatitudActual : 25.6866m;
    var lng = Model.LongitudActual != 0 ? Model.LongitudActual : -100.3161m;

    var nombresPerros = (Model.PaseoPerros != null && Model.PaseoPerros.Any(pp => pp.Perro != null))
        ? string.Join(", ",
            Model.PaseoPerros
                .Where(pp => pp.Perro != null && !string.IsNullOrWhiteSpace(pp.Perro.Nombre))
                .Select(pp => pp.Perro!.Nombre)
                .Distinct())
        : (Model.Perro?.Nombre ?? "Perro");

    var cantidadPerros = (Model.PaseoPerros != null && Model.PaseoPerros.Any(pp => pp.Perro != null))
        ? Model.PaseoPerros
            .Where(pp => pp.Perro != null)
            .Select(pp => pp.PerroId)
            .Distinct()
            .Count()
        : (Model.Perro != null ? 1 : 0);

    var variosPerros = cantidadPerros > 1;
    var etiquetaPerros = variosPerros ? "Perros" : "Perro";
    var textoFotoInicio = variosPerros ? "Sube una foto de los perros para poder comenzar el paseo." : "Sube una foto del perro para poder comenzar el paseo.";
    var textoFotoInicioError = variosPerros ? "Debes subir una foto de inicio de los perros para iniciar el paseo." : "Debes subir una foto del perro para iniciar el paseo.";
    var textoFotoFin = variosPerros ? "Antes de finalizar el paseo, sube una foto final de los perros como comprobante." : "Antes de finalizar el paseo, sube una foto final como comprobante.";
    var textoFotoFinError = variosPerros ? "Debes subir una foto final de los perros antes de terminar el paseo." : "Debes subir una foto final antes de terminar el paseo.";
}

<div class="mapa-container">

    <div class="mapa-header">
        <h5>
            Paseo de: @nombresPerros —
            <span id="estadoBadge" class="badge
                @(Model.Estado == "EnCurso" ? "bg-success" :
                                                     Model.Estado == "Finalizado" ? "bg-secondary" : "bg-warning text-dark")">
                @Model.Estado
            </span>

            @if (variosPerros)
            {
                <span class="badge bg-primary ms-2">@cantidadPerros perros</span>
            }

            @if (Model.EsProgramado)
            {
                <span class="badge bg-info text-dark ms-2">Programado</span>
            }
        </h5>

        <div class="mapa-info">
            <span>🐶 @etiquetaPerros: @nombresPerros</span>
            <span>👤 @Model.Paseador.Usuario.Nombre @Model.Paseador.Usuario.Apellido</span>
            <span>⏱ Duración solicitada: @Model.DuracionMinutos min</span>

            @if (Model.FechaInicio != null)
            {
                <span>▶ Inicio real: @Model.FechaInicio?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
            }
            else
            {
                <span>▶ Aún no inicia</span>
            }

            @if (Model.Estado == "EnCurso" && Model.FechaInicio != null)
            {
                var duracionActual = DateTime.UtcNow - Model.FechaInicio.Value;
                <span>🕒 Duración actual: @((int)duracionActual.TotalMinutes) min</span>
            }

            @if (Model.FechaFin != null)
            {
                <span>⏹ Fin real: @Model.FechaFin?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
            }

            @if (Model.FechaInicio != null && Model.FechaFin != null)
            {
                var duracionReal = Model.FechaFin.Value - Model.FechaInicio.Value;
                <span>✅ Duración real: @((int)duracionReal.TotalMinutes) min</span>
            }
        </div>

        @if (Model.EsProgramado && Model.FechaProgramada != null)
        {
            <div class="mapa-programado">
                <strong>Programado para:</strong>
                @Model.FechaProgramada?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
            </div>
        }
    </div>

    <div id="map"></div>

    <div class="evidencias-box">
        <h6 class="evidencias-titulo">📸 Evidencia del paseo</h6>
        <p class="evidencias-sub">Aquí puedes revisar las fotos registradas al inicio y al final del paseo.</p>

        <div class="evidencias-grid">
            <div class="evidencia-card">
                <div class="evidencia-header">Foto de inicio</div>

                @if (!string.IsNullOrWhiteSpace(Model.FotoInicioUrl))
                {
                    <img src="@Model.FotoInicioUrl"
                         alt="Foto de inicio del paseo"
                         class="evidencia-img" />
                }
                else
                {
                    <div class="evidencia-empty">
                        Aún no se ha subido evidencia de inicio.
                    </div>
                }
            </div>

            <div class="evidencia-card">
                <div class="evidencia-header">Foto final</div>

                @if (!string.IsNullOrWhiteSpace(Model.FotoFinUrl))
                {
                    <img src="@Model.FotoFinUrl"
                         alt="Foto final del paseo"
                         class="evidencia-img" />
                }
                else
                {
                    <div class="evidencia-empty">
                        Aún no se ha subido evidencia de finalización.
                    </div>
                }
            </div>
        </div>
    </div>

    @if (esPaseador)
    {
        <div class="mapa-controles">

            @if (Model.Estado == "Pendiente")
            {
                <div class="accion-box">
                    <h6 class="mb-2">Para iniciar el paseo</h6>
                    <p class="text-muted small mb-3">
                        Presiona <strong>Iniciar paseo</strong>. Si aún no hay evidencia, se te pedirá subir la foto de inicio.
                    </p>

                    <button id="btnIniciar"
                            class="btn btn-success w-100"
                            onclick="cambiarEstado('EnCurso')">
                        ▶ Iniciar paseo
                    </button>
                </div>

                <div id="panelFotoInicio"
                     class="foto-box mt-3"
                     style="display:@(string.IsNullOrWhiteSpace(Model.FotoInicioUrl) ? "none" : "block")">
                    <h6 class="mb-2">Evidencia de inicio</h6>
                    <p class="text-muted small mb-3">
                        @textoFotoInicio
                    </p>

                    <form asp-controller="Paseo"
                          asp-action="SubirFotoInicio"
                          method="post"
                          enctype="multipart/form-data"
                          class="mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="paseoId" value="@Model.Id" />

                        <div class="mb-2">
                            <input type="file"
                                   name="fotoInicio"
                                   class="form-control"
                                   accept=".jpg,.jpeg,.png,.webp"
                                   required />
                        </div>

                        <button type="submit" class="btn btn-outline-primary w-100">
                            @(string.IsNullOrWhiteSpace(Model.FotoInicioUrl) ? "Subir foto de inicio" : "Reemplazar foto de inicio")
                        </button>
                    </form>

                    @if (!string.IsNullOrWhiteSpace(Model.FotoInicioUrl))
                    {
                        <div class="alert alert-success py-2 mb-0">
                            Foto de inicio lista. Ya puedes presionar <strong>Iniciar paseo</strong>.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning py-2 mb-0">
                            Primero sube la foto de inicio y después vuelve a presionar <strong>Iniciar paseo</strong>.
                        </div>
                    }
                </div>
            }

            @if (Model.Estado == "EnCurso")
            {
                <div class="foto-box">
                    <h6 class="mb-2">Evidencia de finalización</h6>
                    <p class="text-muted small mb-3">
                        @textoFotoFin
                    </p>

                    <form asp-controller="Paseo"
                          asp-action="SubirFotoFin"
                          method="post"
                          enctype="multipart/form-data"
                          class="mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="paseoId" value="@Model.Id" />

                        <div class="mb-2">
                            <input type="file"
                                   name="fotoFin"
                                   class="form-control"
                                   accept=".jpg,.jpeg,.png,.webp"
                                   required="@string.IsNullOrWhiteSpace(Model.FotoFinUrl)" />
                        </div>

                        <button type="submit" class="btn btn-outline-primary w-100">
                            @(string.IsNullOrWhiteSpace(Model.FotoFinUrl) ? "Subir foto final" : "Reemplazar foto final")
                        </button>
                    </form>

                    @if (!string.IsNullOrWhiteSpace(Model.FotoFinUrl))
                    {
                        <div class="alert alert-success py-2 mb-0">
                            Ya subiste la foto final. Ya puedes terminar el paseo.
                        </div>
                    }
                </div>

                <button id="btnFinalizar"
                        class="btn btn-danger w-100"
                        onclick="cambiarEstado('Finalizado')"
                        disabled="@(string.IsNullOrWhiteSpace(Model.FotoFinUrl) ? "disabled" : null)">
                    ⏹ Finalizar paseo
                </button>

                @if (string.IsNullOrWhiteSpace(Model.FotoFinUrl))
                {
                    <small class="text-danger d-block mt-2">
                        Debes subir una foto final antes de finalizar el paseo.
                    </small>
                }
            }

            @if (Model.Estado == "Finalizado")
            {
                <div class="alert alert-secondary mb-0">
                    El paseo ya fue finalizado.
                </div>
            }
        </div>
    }

    <div class="mapa-footer d-flex gap-2">
        <a asp-controller="Paseo" asp-action="MisPaseos"
               class="btn btn-outline-secondary w-100">
            ← Volver a mis paseos
        </a>

        <a asp-controller="Chat" asp-action="Index"
               asp-route-paseoId="@Model.Id"
               class="btn btn-outline-primary w-100">
            Abrir chat del paseo
        </a>
    </div>

</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <script>
        const paseoId = @Model.Id;
        const esPaseador = @(esPaseador ? "true" : "false");
        const tieneFotoInicio = @(!string.IsNullOrWhiteSpace(Model.FotoInicioUrl) ? "true" : "false");
        const tieneFotoFin = @(!string.IsNullOrWhiteSpace(Model.FotoFinUrl) ? "true" : "false");
        const latInicial = @lat.ToString(CultureInfo.InvariantCulture);
        const lngInicial = @lng.ToString(CultureInfo.InvariantCulture);

        let watchId = null;
        let marker = null;
        let ruta = [];
        let polyline = null;
        let map = null;
        let ultimaPosicionEnviada = null;
        const DISTANCIA_MINIMA_METROS = 3;

        const connection = new signalR.HubConnectionBuilder()
        .withUrl("/paseohub")
        .withAutomaticReconnect()
        .build();

        function calcularDistanciaMetros(lat1, lng1, lat2, lng2) {
        const R = 6371000;
        const dLat = (lat2 - lat1) * Math.PI / 180;
        const dLng = (lng2 - lng1) * Math.PI / 180;

        const a =
        Math.sin(dLat / 2) * Math.sin(dLat / 2) +
        Math.cos(lat1 * Math.PI / 180) *
        Math.cos(lat2 * Math.PI / 180) *
        Math.sin(dLng / 2) * Math.sin(dLng / 2);

        const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
        return R * c;
        }

        try {
        map = L.map("map").setView([latInicial, lngInicial], 15);

        L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
        attribution: "© OpenStreetMap contributors"
        }).addTo(map);

        const iconoPaseo = L.divIcon({
        className: "",
        html: `<div style="font-size:28px;filter:drop-shadow(0 2px 4px rgba(0,0,0,.4))">🐕</div>`,
        iconSize: [32, 32],
        iconAnchor: [16, 32]
        });

        marker = L.marker([latInicial, lngInicial], { icon: iconoPaseo })
        .addTo(map)
        .bindPopup("Ubicación actual del paseo");

        @if (Model.Ubicaciones != null && Model.Ubicaciones.Any())
        {
            <text>
                const historial = [
                @foreach (var u in Model.Ubicaciones)
                {
                    @:[@u.Latitud.ToString(CultureInfo.InvariantCulture), @u.Longitud.ToString(CultureInfo.InvariantCulture)],
                }
                ];

                ruta = [...historial];

                if (historial.length > 1) {
                polyline = L.polyline(historial, {
                color: "#0d6efd",
                weight: 3,
                opacity: 0.7
                }).addTo(map);

                map.fitBounds(polyline.getBounds(), { padding: [20, 20] });
                }
            </text>
        }
        } catch (err) {
        console.error("Error al inicializar el mapa:", err);
        }

        connection.on("RecibirUbicacion", (lat, lng) => {
        const pos = [lat, lng];

        if (marker) {
        marker.setLatLng(pos);
        }

        const ultimoPunto = ruta.length > 0 ? ruta[ruta.length - 1] : null;

        if (!ultimoPunto || calcularDistanciaMetros(ultimoPunto[0], ultimoPunto[1], lat, lng) >= DISTANCIA_MINIMA_METROS) {
        ruta.push(pos);

        if (!polyline && map && ruta.length > 1) {
        polyline = L.polyline(ruta, {
        color: "#0d6efd",
        weight: 3,
        opacity: 0.7
        }).addTo(map);
        } else if (polyline) {
        polyline.setLatLngs(ruta);
        }
        }
        });

        connection.on("EstadoCambiado", (estado) => {
        const badge = document.getElementById("estadoBadge");
        badge.textContent = estado;

        badge.classList.remove("bg-warning", "text-dark", "bg-success", "bg-secondary");

        if (estado === "Pendiente") {
        badge.classList.add("bg-warning", "text-dark");
        } else if (estado === "EnCurso") {
        badge.classList.add("bg-success");
        } else if (estado === "Finalizado") {
        badge.classList.add("bg-secondary");
        }

        if (estado === "EnCurso" && esPaseador) {
        iniciarGPS();
        }

        if (estado === "Finalizado") {
        detenerGPS();
        }

        setTimeout(() => {
        location.reload();
        }, 600);
        });

        connection.start()
        .then(() => connection.invoke("UnirseAPaseo", paseoId))
        .catch(err => console.error("SignalR error:", err));

        function iniciarGPS() {
        if (!navigator.geolocation) {
        alert("Tu navegador no soporta geolocalización");
        return;
        }

        if (watchId !== null) return;

        watchId = navigator.geolocation.watchPosition(
        (pos) => {
        const lat = pos.coords.latitude;
        const lng = pos.coords.longitude;

        if (ultimaPosicionEnviada) {
        const distancia = calcularDistanciaMetros(
        ultimaPosicionEnviada.lat,
        ultimaPosicionEnviada.lng,
        lat,
        lng
        );

        if (distancia < DISTANCIA_MINIMA_METROS) {
        return;
        }
        }

        ultimaPosicionEnviada = { lat, lng };

        connection.invoke("EnviarUbicacion", paseoId, lat, lng)
        .catch(err => console.error("Error GPS:", err));
        },
        (err) => {
        console.error("Error geolocalización:", err);
        },
        {
        enableHighAccuracy: true,
        maximumAge: 0,
        timeout: 8000
        }
        );
        }

        function detenerGPS() {
        if (watchId !== null) {
        navigator.geolocation.clearWatch(watchId);
        watchId = null;
        }

        ultimaPosicionEnviada = null;
        }

        function mostrarPanelFotoInicio() {
        const panel = document.getElementById("panelFotoInicio");
        if (panel) {
        panel.style.display = "block";
        panel.scrollIntoView({ behavior: "smooth", block: "center" });
        }
        }

        async function cambiarEstado(nuevoEstado) {
        if (nuevoEstado === "EnCurso") {
        if (!tieneFotoInicio) {
        mostrarPanelFotoInicio();
        alert("Para iniciar el paseo, primero sube la foto de inicio.");
        return;
        }

        const esProgramado = @(Model.EsProgramado ? "true" : "false");
        const fechaProgramada = "@(Model.FechaProgramada?.ToString("yyyy-MM-ddTHH:mm:ss") ?? "")";

        if (esProgramado && fechaProgramada) {
        const ahora = new Date();
        const programada = new Date(fechaProgramada);
        const inicioPermitido = new Date(programada.getTime() - 15 * 60 * 1000);

        if (ahora < inicioPermitido) {
        alert("Este paseo programado solo puede iniciarse 15 minutos antes de la hora programada.");
        return;
        }
        }

        if (!navigator.geolocation) {
        alert("Tu navegador no soporta geolocalización");
        return;
        }

        try {
        await new Promise((resolve, reject) => {
        navigator.geolocation.getCurrentPosition(
        (pos) => {
        const lat = pos.coords.latitude;
        const lng = pos.coords.longitude;

        ultimaPosicionEnviada = { lat, lng };

        if (marker) {
        marker.setLatLng([lat, lng]);
        }

        const ultimoPunto = ruta.length > 0 ? ruta[ruta.length - 1] : null;

        if (!ultimoPunto || calcularDistanciaMetros(ultimoPunto[0], ultimoPunto[1], lat, lng) >= DISTANCIA_MINIMA_METROS) {
        ruta.push([lat, lng]);

        if (!polyline && map && ruta.length > 1) {
        polyline = L.polyline(ruta, {
        color: "#0d6efd",
        weight: 3,
        opacity: 0.7
        }).addTo(map);
        } else if (polyline) {
        polyline.setLatLngs(ruta);
        }
        }

        connection.invoke("EnviarUbicacion", paseoId, lat, lng)
        .then(() => {
        iniciarGPS();
        resolve(pos);
        })
        .catch(err => reject(err));
        },
        (err) => reject(err),
        { enableHighAccuracy: true, maximumAge: 0, timeout: 10000 }
        );
        });
        } catch (err) {
        console.error("Error geolocalización al iniciar:", err);
        alert("No se pudo obtener tu ubicación. Revisa los permisos del navegador.");
        return;
        }
        }

        if (nuevoEstado === "Finalizado") {
        if (!tieneFotoFin) {
        alert("Debes subir una foto final antes de finalizar el paseo.");
        return;
        }
        }

        connection.invoke("CambiarEstado", paseoId, nuevoEstado)
        .catch(err => console.error("Error al cambiar estado:", err));
        }

        @if (Model.Estado == "EnCurso" && esPaseador)
        {
            <text>iniciarGPS();</text>
        }
    </script>
}
@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/css/mapa.css")" />
}