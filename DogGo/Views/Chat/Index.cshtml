@{
    ViewData["Title"] = "Chat del paseo";
    var paseoId     = (int)ViewBag.PaseoId;
    var usuarioId   = (int)ViewBag.UsuarioId;
    var receptorId  = (int)ViewBag.ReceptorId;
    var nombrePerro = (string)ViewBag.NombrePerro;
    var mensajes    = (List<DogGo.Models.Mensaje>)ViewBag.Mensajes;
}

@section Styles {
<style>
/* ═══════════════════════════════════════════════════════
   DogGo Chat — Awwwards-tier · Editorial Luxury
   Double-Bezel · Spring Physics · Z-Axis Cascade
   ═══════════════════════════════════════════════════════ */

.chat-page {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem 1rem 2rem;
    background: var(--cream);
    position: relative;
}

/* Orbs decorativos de fondo */
.chat-page::before {
    content: '';
    position: fixed;
    top: -160px; right: -160px;
    width: 500px; height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(15,155,142,.07) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
}
.chat-page::after {
    content: '';
    position: fixed;
    bottom: -120px; left: -120px;
    width: 420px; height: 420px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(245,166,35,.05) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
}

/* ── Double-Bezel outer shell ── */
.chat-outer {
    position: relative; z-index: 1;
    width: 100%; max-width: 680px;
    background: rgba(237,232,224,.4);
    border: 1px solid rgba(237,232,224,.85);
    border-radius: 2rem;
    padding: 5px;
    box-shadow:
        0 2px 0 rgba(255,255,255,.9) inset,
        0 32px 80px rgba(45,49,66,.1),
        0 8px 24px rgba(45,49,66,.06);
    animation: chatShellIn .7s cubic-bezier(0.32,0.72,0,1) both;
}

@@keyframes chatShellIn {
    from { opacity:0; transform:translateY(28px) scale(.97); }
    to   { opacity:1; transform:translateY(0) scale(1); }
}

/* ── Double-Bezel inner core ── */
.chat-inner {
    background: var(--card);
    border-radius: calc(2rem - 5px);
    display: flex;
    flex-direction: column;
    height: 78vh;
    min-height: 500px;
    overflow: hidden;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.95);
}

/* ── Header ── */
.chat-hdr {
    display: flex;
    align-items: center;
    gap: .8rem;
    padding: 1.1rem 1.4rem;
    background: linear-gradient(130deg, #0F9B8E 0%, #0a7a70 100%);
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
}

/* Shimmer en header */
.chat-hdr::after {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 60%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,.07), transparent);
    animation: shimmer 4s ease infinite;
}
@@keyframes shimmer {
    0%   { left: -100%; }
    50%, 100% { left: 150%; }
}

.chat-hdr-back {
    width: 34px; height: 34px;
    border-radius: 50%;
    background: rgba(255,255,255,.15);
    border: 1px solid rgba(255,255,255,.25);
    display: flex; align-items: center; justify-content: center;
    color: white; font-size: .9rem; text-decoration: none;
    flex-shrink: 0; position: relative; z-index: 1;
    transition: background .2s cubic-bezier(0.32,0.72,0,1),
                transform .3s cubic-bezier(0.34,1.56,0.64,1);
    will-change: transform;
}
.chat-hdr-back:hover {
    background: rgba(255,255,255,.28);
    transform: scale(1.1) translateX(-2px);
    color: white;
}

.chat-hdr-avatar {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,.2);
    border: 1.5px solid rgba(255,255,255,.35);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.2rem; flex-shrink: 0;
    position: relative; z-index: 1;
    animation: float 4s ease-in-out infinite;
}

.chat-hdr-info { flex: 1; position: relative; z-index: 1; }
.chat-hdr-title {
    font-family: 'Nunito', sans-serif;
    font-weight: 900; font-size: .97rem;
    color: white; margin: 0; line-height: 1.2;
    letter-spacing: -.2px;
}
.chat-hdr-sub {
    font-size: .72rem; font-weight: 600;
    color: rgba(255,255,255,.7); margin-top: .1rem;
}

.chat-status {
    display: flex; align-items: center; gap: .35rem;
    font-size: .7rem; font-weight: 700;
    color: rgba(255,255,255,.8);
    position: relative; z-index: 1;
}
.status-pip {
    width: 7px; height: 7px; border-radius: 50%;
    background: #7ee8c4;
    animation: pip 2.2s ease infinite;
}
@@keyframes pip {
    0%,100% { opacity:1; transform:scale(1); }
    50%      { opacity:.45; transform:scale(.65); }
}

/* ── Mensajes ── */
.chat-body {
    flex: 1;
    overflow-y: auto;
    padding: 1.4rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: .35rem;
    background: linear-gradient(180deg, #faf8f4 0%, var(--cream) 100%);
    scroll-behavior: smooth;
}

/* Scrollbar minimalista */
.chat-body::-webkit-scrollbar { width: 3px; }
.chat-body::-webkit-scrollbar-track { background: transparent; }
.chat-body::-webkit-scrollbar-thumb {
    background: rgba(180,175,168,.5);
    border-radius: 999px;
}

/* ── Separador de fecha ── */
.date-sep {
    display: flex; align-items: center; gap: .7rem;
    margin: .6rem 0 .3rem;
}
.date-sep::before,
.date-sep::after {
    content: ''; flex: 1; height: 1px;
    background: linear-gradient(90deg, transparent, var(--border), transparent);
}
.date-sep-label {
    font-size: .65rem; font-weight: 800;
    color: var(--muted); text-transform: uppercase;
    letter-spacing: .08em; white-space: nowrap;
    background: var(--cream); padding: 0 .5rem;
}

/* ── Burbuja — Z-Axis cascade ── */
.msg {
    display: flex;
    flex-direction: column;
    max-width: 68%;
    will-change: transform;
    animation: bubbleIn .38s cubic-bezier(0.34,1.56,0.64,1) both;
}

@@keyframes bubbleIn {
    from { opacity:0; transform:translateY(12px) scale(.92); }
    to   { opacity:1; transform:translateY(0) scale(1); }
}

.msg.mio   { align-self: flex-end;   align-items: flex-end; }
.msg.suyo  { align-self: flex-start; align-items: flex-start; }

/* Nombre (solo otros) */
.msg-from {
    font-size: .68rem; font-weight: 800;
    color: var(--teal); margin-bottom: .22rem;
    padding: 0 .35rem; letter-spacing: .01em;
}

/* Burbuja: outer shell (doppelrand) */
.burbuja-shell {
    padding: 2px;
    border-radius: 20px;
    position: relative;
}

.msg.mio .burbuja-shell {
    background: linear-gradient(140deg, #12b3a4, #0a7a70);
    border-radius: 20px 20px 5px 20px;
    box-shadow:
        0 4px 16px rgba(15,155,142,.3),
        0 1px 0 rgba(255,255,255,.15) inset;
}

.msg.suyo .burbuja-shell {
    background: linear-gradient(140deg, rgba(237,232,224,.9), rgba(237,232,224,.4));
    border-radius: 20px 20px 20px 5px;
    box-shadow:
        0 2px 10px rgba(45,49,66,.06),
        0 1px 0 rgba(255,255,255,.9) inset;
}

/* Burbuja: inner core */
.burbuja-core {
    padding: .6rem .95rem;
    border-radius: inherit;
    font-family: 'Nunito', sans-serif;
    font-size: .88rem; font-weight: 600;
    line-height: 1.55; word-break: break-word;
}

.msg.mio .burbuja-core {
    background: linear-gradient(140deg, #0F9B8E, #0c8a80);
    color: white;
    border-radius: 18px 18px 4px 18px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.18);
}

.msg.suyo .burbuja-core {
    background: var(--card);
    color: var(--text);
    border-radius: 18px 18px 18px 4px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.95);
}

/* Hora + check */
.msg-footer {
    display: flex; align-items: center; gap: .3rem;
    margin-top: .2rem; padding: 0 .35rem;
}
.msg-hora {
    font-size: .63rem; font-weight: 700; color: var(--muted);
}
.msg-check {
    font-size: .65rem; color: var(--teal-m);
    animation: checkIn .3s cubic-bezier(0.34,1.56,0.64,1) both;
}
@@keyframes checkIn {
    from { opacity:0; transform:scale(0) rotate(-20deg); }
    to   { opacity:1; transform:scale(1) rotate(0deg); }
}

/* ── Empty state ── */
.chat-empty {
    flex: 1; display: flex; flex-direction: column;
    align-items: center; justify-content: center; gap: .65rem;
    padding: 2rem;
}
.chat-empty-icon {
    font-size: 2.8rem;
    animation: float 3.5s ease-in-out infinite;
}
.chat-empty h4 {
    font-weight: 900; font-size: 1rem;
    color: var(--text); margin: 0;
    letter-spacing: -.2px;
}
.chat-empty p {
    font-size: .82rem; font-weight: 600;
    color: var(--muted); margin: 0;
}

/* ── Typing indicator ── */
.typing-wrap {
    display: none;
    align-self: flex-start;
    animation: bubbleIn .3s cubic-bezier(0.34,1.56,0.64,1) both;
}
.typing-shell {
    padding: 2px;
    background: linear-gradient(140deg, rgba(237,232,224,.9), rgba(237,232,224,.4));
    border-radius: 20px 20px 20px 5px;
    box-shadow: 0 2px 10px rgba(45,49,66,.06), 0 1px 0 rgba(255,255,255,.9) inset;
}
.typing-core {
    background: var(--card);
    border-radius: 18px 18px 18px 4px;
    padding: .65rem 1rem;
    display: flex; align-items: center; gap: 5px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.95);
}
.typing-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--muted);
    animation: typDot 1.3s ease infinite;
}
.typing-dot:nth-child(2) { animation-delay: .18s; }
.typing-dot:nth-child(3) { animation-delay: .36s; }
@@keyframes typDot {
    0%,60%,100% { transform:translateY(0); opacity:.35; }
    30%          { transform:translateY(-6px); opacity:1; }
}

/* ── Input area — Button-in-Button architecture ── */
.chat-footer {
    flex-shrink: 0;
    padding: .9rem 1.1rem;
    background: var(--card);
    border-top: 1px solid rgba(237,232,224,.85);
    display: flex; align-items: flex-end; gap: .6rem;
}

/* Input outer shell */
.input-shell {
    flex: 1;
    background: rgba(237,232,224,.45);
    border: 1px solid rgba(237,232,224,.9);
    border-radius: 999px;
    padding: 3px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.9);
    transition: border-color .25s cubic-bezier(0.32,0.72,0,1),
                box-shadow .25s cubic-bezier(0.32,0.72,0,1);
}
.input-shell:focus-within {
    border-color: rgba(15,155,142,.4);
    box-shadow: 0 0 0 3px rgba(15,155,142,.08), inset 0 1px 0 rgba(255,255,255,.9);
}

/* Input inner core */
.chat-input {
    width: 100%;
    padding: .55rem 1rem;
    border: none; outline: none;
    background: var(--card);
    border-radius: 999px;
    font-family: 'Nunito', sans-serif;
    font-size: .88rem; font-weight: 600;
    color: var(--text); resize: none;
    min-height: 40px; max-height: 110px;
    line-height: 1.5; overflow-y: auto;
    box-shadow: inset 0 1px 0 rgba(255,255,255,.95);
}
.chat-input::placeholder { color: var(--muted); opacity: .7; }

/* Send button — pill with nested icon */
.send-shell {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: rgba(15,155,142,.12);
    border: none; padding: 2px;
    cursor: pointer; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s cubic-bezier(0.32,0.72,0,1),
                transform .3s cubic-bezier(0.34,1.56,0.64,1);
    will-change: transform;
}
.send-shell:hover {
    background: rgba(15,155,142,.18);
    transform: scale(1.08);
}
.send-shell:active { transform: scale(.93); }
.send-shell:disabled {
    opacity: .45; cursor: not-allowed; transform: none;
}

.send-core {
    width: 100%; height: 100%;
    border-radius: 50%;
    background: linear-gradient(135deg, #0F9B8E, #0a7a70);
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem; color: white;
    box-shadow: 0 4px 14px rgba(15,155,142,.35),
                inset 0 1px 0 rgba(255,255,255,.2);
    transition: transform .25s cubic-bezier(0.34,1.56,0.64,1);
}
.send-shell:hover .send-core { transform: rotate(-15deg) scale(1.06); }

/* ── Responsive ── */
@@media (max-width: 600px) {
    .chat-page { padding: 0; justify-content: flex-start; }
    .chat-outer { border-radius: 0; padding: 0; box-shadow: none; }
    .chat-inner { border-radius: 0; height: 100dvh; }
    .msg { max-width: 82%; }
}
</style>
}

<div class="chat-page">
    <div class="chat-outer">
        <div class="chat-inner">

            @* Header *@
            <div class="chat-hdr">
                <a asp-controller="Paseo" asp-action="Mapa" asp-route-id="@paseoId"
                   class="chat-hdr-back" title="Volver al mapa">←</a>

                <div class="chat-hdr-avatar">🐾</div>

                <div class="chat-hdr-info">
                    <div class="chat-hdr-title">@nombrePerro</div>
                    <div class="chat-hdr-sub">Paseo #@paseoId</div>
                </div>

                <div class="chat-status">
                    <span class="status-pip"></span>
                    En vivo
                </div>
            </div>

            @* Mensajes *@
            <div class="chat-body" id="chatBody">

                @if (!mensajes.Any())
                {
                    <div class="chat-empty">
                        <div class="chat-empty-icon">💬</div>
                        <h4>Aún no hay mensajes</h4>
                        <p>Sé el primero en escribir algo</p>
                    </div>
                }
                else
                {
                    DateTime? fechaAnterior = null;
                    @foreach (var m in mensajes)
                    {
                        var esMio      = m.EmisorId == usuarioId;
                        var fechaMsg   = m.FechaEnvio.Date;

                        @if (fechaAnterior == null || fechaMsg != fechaAnterior)
                        {
                            var lbl = fechaMsg == DateTime.Today ? "Hoy"
                                    : fechaMsg == DateTime.Today.AddDays(-1) ? "Ayer"
                                    : m.FechaEnvio.ToString("dd MMM yyyy");
                            <div class="date-sep">
                                <span class="date-sep-label">@lbl</span>
                            </div>
                            fechaAnterior = fechaMsg;
                        }

                        <div class="msg @(esMio ? "mio" : "suyo")">
                            @if (!esMio)
                            {
                                <span class="msg-from">@m.Emisor.Nombre</span>
                            }
                            <div class="burbuja-shell">
                                <div class="burbuja-core">@m.Contenido</div>
                            </div>
                            <div class="msg-footer">
                                <span class="msg-hora">@m.FechaEnvio.ToString("HH:mm")</span>
                                @if (esMio)
                                {
                                    <span class="msg-check">✓✓</span>
                                }
                            </div>
                        </div>
                    }
                }

                @* Typing indicator *@
                <div class="typing-wrap" id="typingWrap">
                    <div class="typing-shell">
                        <div class="typing-core">
                            <span class="typing-dot"></span>
                            <span class="typing-dot"></span>
                            <span class="typing-dot"></span>
                        </div>
                    </div>
                </div>

            </div>

            @* Input — Button-in-Button *@
            <div class="chat-footer">
                <div class="input-shell">
                    <textarea id="chatInput"
                              class="chat-input"
                              placeholder="Escribe un mensaje..."
                              rows="1"></textarea>
                </div>
                <button class="send-shell" id="sendBtn">
                    <div class="send-core">➤</div>
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
(function () {
    const ME          = @usuarioId;
    const PASEO_ID    = @paseoId;
    const RECEPTOR_ID = @receptorId;

    const bodyEl    = document.getElementById('chatBody');
    const inputEl   = document.getElementById('chatInput');
    const sendBtn   = document.getElementById('sendBtn');
    const typingWrap = document.getElementById('typingWrap');

    /* ── SignalR ────────────────────────────────── */
    const conn = new signalR.HubConnectionBuilder()
        .withUrl('/chatHub')
        .withAutomaticReconnect()
        .build();

    conn.on('RecibirMensaje', data => {
        ocultarTyping();
        agregarBurbuja({
            nombre   : data.emisorId === ME ? '' : data.nombreEmisor,
            contenido: data.contenido,
            hora     : data.fechaEnvio,
            esMio    : data.emisorId === ME
        });
    });

    conn.on('UsuarioEscribiendo', () => {
        mostrarTyping();
        clearTimeout(window._tTimeout);
        window._tTimeout = setTimeout(ocultarTyping, 2800);
    });

    conn.start()
        .then(() => conn.invoke('UnirseAPaseo', PASEO_ID))
        .catch(err => console.error('SignalR:', err));

    /* ── Enviar ─────────────────────────────────── */
    function enviar() {
        const txt = inputEl.value.trim();
        if (!txt) { shake(inputEl); return; }

        conn.invoke('EnviarMensaje', PASEO_ID, RECEPTOR_ID, txt)
            .catch(err => console.error('Error envío:', err));

        inputEl.value = '';
        inputEl.style.height = 'auto';
        sendBtn.disabled = true;
        setTimeout(() => sendBtn.disabled = false, 280);
    }

    /* ── Agregar burbuja al DOM ─────────────────── */
    function agregarBurbuja({ nombre, contenido, hora, esMio }) {
        const empty = bodyEl.querySelector('.chat-empty');
        if (empty) empty.remove();

        const wrap = document.createElement('div');
        wrap.className = `msg ${esMio ? 'mio' : 'suyo'}`;

        const check = esMio ? '<span class="msg-check">✓✓</span>' : '';
        const from  = (!esMio && nombre)
            ? `<span class="msg-from">${esc(nombre)}</span>`
            : '';

        wrap.innerHTML = `
            ${from}
            <div class="burbuja-shell">
                <div class="burbuja-core">${esc(contenido)}</div>
            </div>
            <div class="msg-footer">
                <span class="msg-hora">${fmtHora(hora)}</span>
                ${check}
            </div>
        `;

        bodyEl.insertBefore(wrap, typingWrap);
        scrollFondo();
    }

    /* ── Typing ─────────────────────────────────── */
    function mostrarTyping() {
        typingWrap.style.display = 'flex';
        scrollFondo();
    }
    function ocultarTyping() {
        typingWrap.style.display = 'none';
    }

    /* ── Scroll al fondo ────────────────────────── */
    function scrollFondo() {
        bodyEl.scrollTo({ top: bodyEl.scrollHeight, behavior: 'smooth' });
    }

    /* ── Shake (feedback error) ─────────────────── */
    function shake(el) {
        el.style.animation = 'none';
        el.style.animation = 'chatShake .4s cubic-bezier(0.36,0.07,0.19,0.97)';
        setTimeout(() => el.style.animation = '', 420);
    }

    /* ── Textarea auto-resize ───────────────────── */
    inputEl.addEventListener('input', () => {
        inputEl.style.height = 'auto';
        inputEl.style.height = Math.min(inputEl.scrollHeight, 110) + 'px';
        conn.invoke('UsuarioEscribiendo', PASEO_ID, RECEPTOR_ID).catch(() => {});
    });

    /* ── Enter envía / Shift+Enter salto ─────────── */
    inputEl.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            enviar();
        }
    });

    sendBtn.addEventListener('click', enviar);

    /* ── Ripple en send btn ─────────────────────── */
    sendBtn.addEventListener('click', function(e) {
        const core = this.querySelector('.send-core');
        core.style.transform = 'rotate(-15deg) scale(.88)';
        setTimeout(() => core.style.transform = '', 280);
    });

    /* ── Helpers ────────────────────────────────── */
    function esc(s) {
        return String(s)
            .replace(/&/g,'&amp;').replace(/</g,'&lt;')
            .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function fmtHora(h) {
        if (!h) return '';
        if (/^\d{2}:\d{2}$/.test(h)) return h;
        try {
            return new Date(h).toLocaleTimeString('es-MX', {
                hour:'2-digit', minute:'2-digit'
            });
        } catch { return h; }
    }

    /* ── Shake keyframe ─────────────────────────── */
    const s = document.createElement('style');
    s.textContent = `
        @@keyframes chatShake {
            10%,90%  { transform:translateX(-2px); }
            20%,80%  { transform:translateX(4px); }
            30%,50%,70% { transform:translateX(-5px); }
            40%,60%  { transform:translateX(5px); }
        }
    `;
    document.head.appendChild(s);

    /* ── Init: scroll al fondo ──────────────────── */
    scrollFondo();
})();
</script>
}
