@model DogGo.Models.Paseador
@{
    ViewData["Title"] = "Editar perfil";
}

<div style="max-width:520px; margin:2rem auto; padding:0 1rem">
    <h4>✏️ Editar mi perfil</h4>

    <form asp-action="Editar" method="post" class="mt-3">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="form-group mb-3">
            <label>Descripción</label>
            <textarea asp-for="Descripcion" class="form-control" rows="3"
                      placeholder="Cuéntales a los dueños sobre ti..."></textarea>
        </div>

        <div class="form-group mb-3">
            <label asp-for="TarifaPorHora">Tarifa por hora ($)</label>
            <input asp-for="TarifaPorHora" type="number" step="0.01"
                   class="form-control" min="0" />
        </div>

        <div class="form-check mb-3">
            <input asp-for="Disponible" class="form-check-input" />
            <label asp-for="Disponible" class="form-check-label">
                Estoy disponible para paseos
            </label>
        </div>

        <button type="submit" class="btn btn-primary w-100">Guardar cambios</button>
        <a asp-action="Perfil" class="btn btn-outline-secondary w-100 mt-2">Cancelar</a>
    </form>
</div>