@{
    ViewData["Title"] = "Chat del paseo";
    var paseoId = (int)ViewBag.PaseoId;
    var usuarioId = (int)ViewBag.UsuarioId;
    var receptorId = (int)ViewBag.ReceptorId;
    var mensajes = (List<DogGo.Models.Mensaje>)ViewBag.Mensajes;
}

<div class="chat-container">
    <div class="chat-header">
        <h5> Chat del paseo #@paseoId</h5>
    </div>

    <div class="chat-messages" id="chatMessages">
        @foreach (var m in mensajes)
        {
            var esMio = m.EmisorId == usuarioId;
            <div class="mensaje @(esMio ? "mio" : "suyo")">
                @if (!esMio)
                {
                    <span class="nombre">@m.Emisor.Nombre</span>
                }
                <div class="burbuja">@m.Contenido</div>
                <span class="hora">@m.FechaEnvio.ToString("HH:mm")</span>
            </div>
        }
    </div>

    <div class="chat-input">
        <input type="text" id="inputMensaje"
               placeholder="Escribe un mensaje..."
               class="form-control"
               onkeypress="if(event.key==='Enter') enviarMensaje()" />
        <button onclick="enviarMensaje()" class="btn btn-primary">Enviar</button>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .withAutomaticReconnect()
            .build();

        const usuarioId  = @usuarioId;
        const paseoId    = @paseoId;
        const receptorId = @receptorId;

        // Recibir mensaje entrante
        connection.on("RecibirMensaje", (data) => {
            const esMio = data.emisorId === usuarioId;
            agregarMensaje({
                nombre    : esMio ? "Tú" : data.nombreEmisor,
                contenido : data.contenido,
                hora      : data.fechaEnvio,
                esMio
            });
        });

        // Iniciar conexión y unirse al grupo del paseo
        connection.start()
            .then(() => connection.invoke("UnirseAPaseo", paseoId))
            .catch(err => console.error("SignalR error:", err));

        function enviarMensaje() {
            const input = document.getElementById("inputMensaje");
            const texto = input.value.trim();
            if (!texto) return;

            connection.invoke("EnviarMensaje", paseoId, receptorId, texto)
                .catch(err => console.error("Error al enviar:", err));

            input.value = "";
        }

        function agregarMensaje({ nombre, contenido, hora, esMio }) {
            const div = document.createElement("div");
            div.className = `mensaje ${esMio ? "mio" : "suyo"}`;
            div.innerHTML = `
                ${!esMio ? `<span class="nombre">${nombre}</span>` : ""}
                <div class="burbuja">${contenido}</div>
                <span class="hora">${hora}</span>
            `;
            const chat = document.getElementById("chatMessages");
            chat.appendChild(div);
            chat.scrollTop = chat.scrollHeight;
        }
    </script>
}

<style>
    .chat-container {
        max-width: 680px;
        margin: 2rem auto;
        border: 1px solid #ddd;
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        height: 75vh;
    }
    .chat-header {
        padding: 1rem;
        background: #f8f9fa;
        border-bottom: 1px solid #ddd;
    }
    .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .mensaje { display: flex; flex-direction: column; max-width: 70%; }
    .mensaje.mio  { align-self: flex-end;  align-items: flex-end; }
    .mensaje.suyo { align-self: flex-start; align-items: flex-start; }
    .burbuja {
        padding: 0.5rem 0.9rem;
        border-radius: 18px;
        font-size: 0.95rem;
    }
    .mensaje.mio  .burbuja { background: #0d6efd; color: white; }
    .mensaje.suyo .burbuja { background: #e9ecef; color: #212529; }
    .nombre { font-size: 0.75rem; color: #6c757d; margin-bottom: 2px; }
    .hora   { font-size: 0.7rem;  color: #adb5bd; margin-top: 2px; }
    .chat-input {
        display: flex;
        gap: 0.5rem;
        padding: 0.75rem;
        border-top: 1px solid #ddd;
        background: #f8f9fa;
    }
</style>