@model DogGo.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — DogGo</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body>

<div class="auth-container">

    <!-- Panel izquierdo -->
    <div class="auth-left">
        <div class="auth-left-circle"></div>
        <div class="auth-left-circle2"></div>
        <img src="https://cdn.phototourl.com/free/2026-04-07-4b0ab729-6be0-43c9-96bb-2189d1589f86.png"
             alt="DogGo" class="auth-logo-img" />
        <h1 class="auth-left-title">DogGo</h1>
        <p class="auth-left-sub">Conecta con paseadores de confianza cerca de ti</p>
        <div class="auth-trust">
            <div class="trust-item"><span class="trust-dot"></span> Paseadores verificados</div>
            <div class="trust-item"><span class="trust-dot"></span> GPS en tiempo real</div>
            <div class="trust-item"><span class="trust-dot"></span> Chat directo</div>
        </div>
    </div>

    <!-- Panel derecho -->
    <div class="auth-right">
        <div class="auth-card">
            <div class="auth-card-header">
                <h2>Bienvenido de vuelta</h2>
                <p>Inicia sesión en tu cuenta</p>
            </div>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="auth-error"></div>

                <div class="field-group">
                    <label asp-for="Email">Correo electrónico</label>
                    <input asp-for="Email" placeholder="tu@correo.com" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <div class="field-group">
                    <label asp-for="Password">Contraseña</label>
                    <input asp-for="Password" type="password" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>

                <div class="auth-row">
                    <div class="remember">
                        <input asp-for="RememberMe" />
                        <label asp-for="RememberMe">Recordarme</label>
                    </div>
                    <a asp-action="ForgotPassword" class="forgot-link">¿Olvidaste tu contraseña?</a>
                </div>

                <button type="submit" class="auth-btn">Entrar</button>
            </form>

            <div class="auth-footer">
                ¿No tienes cuenta? <a asp-action="Register">Regístrate gratis</a>
            </div>
        </div>
    </div>

</div>

@if (TempData["Success"] != null)
{
    <div id="overlay" class="overlay"></div>
    <div id="toast" class="custom-toast">@TempData["Success"]</div>
}

<script>
    setTimeout(() => {
        document.getElementById('toast')?.remove();
        document.getElementById('overlay')?.remove();
    }, 6000);
</script>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}

<style>
    *, *::before, *::after { box-sizing: border-box; }

    body {
        margin: 0;
        font-family: 'Nunito', system-ui, sans-serif;
        background: #FFFBF5;
        color: #2D3142;
    }

    .auth-container {
        display: flex;
        height: 100vh;
        width: 100%;
    }

    /* ── Panel izquierdo ── */
    .auth-left {
        width: 38%;
        max-width: 420px;
        background: linear-gradient(145deg, #0F9B8E, #0d8a7e);
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 60px 50px;
        position: relative;
        overflow: hidden;
    }

    .auth-left-circle {
        position: absolute;
        width: 320px; height: 320px;
        background: rgba(255,255,255,0.08);
        border-radius: 50%;
        top: -80px; left: -80px;
    }

    .auth-left-circle2 {
        position: absolute;
        width: 200px; height: 200px;
        background: rgba(255,255,255,0.06);
        border-radius: 50%;
        bottom: -40px; right: -40px;
    }

    .auth-logo-img {
        height: 52px;
        width: auto;
        object-fit: contain;
        margin-bottom: 1.5rem;
        position: relative;
        z-index: 1;
    }

    .auth-left-title {
        font-size: 3.2rem;
        font-weight: 900;
        margin: 0 0 .6rem;
        letter-spacing: -.5px;
        position: relative;
        z-index: 1;
    }

    .auth-left-sub {
        font-size: 1rem;
        font-weight: 600;
        opacity: .88;
        line-height: 1.6;
        max-width: 280px;
        margin-bottom: 2rem;
        position: relative;
        z-index: 1;
    }

    .auth-trust {
        display: flex;
        flex-direction: column;
        gap: .55rem;
        position: relative;
        z-index: 1;
    }

    .trust-item {
        display: flex;
        align-items: center;
        gap: .5rem;
        font-size: .85rem;
        font-weight: 700;
        opacity: .9;
    }

    .trust-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        background: #5DCAA5;
        flex-shrink: 0;
    }

    /* ── Panel derecho ── */
    .auth-right {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        background: url('/images/parque-ecologico.jpg') center/cover no-repeat;
        position: relative;
    }

    .auth-right::before {
        content: "";
        position: absolute;
        inset: 0;
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        background: rgba(15, 155, 142, 0.12);
    }

    /* ── Card ── */
    .auth-card {
        width: 360px;
        max-width: 90%;
        padding: 2.2rem;
        border-radius: 24px;
        background: rgba(255,255,255,0.88);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1.5px solid rgba(255,255,255,0.7);
        box-shadow: 0 20px 48px rgba(15,155,142,.18);
        position: relative;
        z-index: 2;
        animation: fadeUp .5s ease both;
    }

    .auth-card-header { margin-bottom: 1.4rem; }

    .auth-card-header h2 {
        font-size: 1.5rem;
        font-weight: 900;
        color: #2D3142;
        margin: 0 0 .25rem;
    }

    .auth-card-header p {
        font-size: .88rem;
        font-weight: 600;
        color: #7B8194;
        margin: 0;
    }

    /* ── Campos ── */
    .field-group {
        display: flex;
        flex-direction: column;
        gap: .3rem;
        margin-bottom: 1rem;
    }

    .field-group label {
        font-size: .82rem;
        font-weight: 800;
        color: #2D3142;
        letter-spacing: .02em;
    }

    .field-group input,
    .auth-card input[type="email"],
    .auth-card input[type="password"],
    .auth-card input[type="text"] {
        width: 100%;
        padding: .75rem 1rem;
        border-radius: 12px;
        background: #F0FAF9;
        border: 1.5px solid #C5E8E5;
        outline: none;
        font-family: 'Nunito', sans-serif;
        font-size: .92rem;
        font-weight: 600;
        color: #2D3142;
        transition: border-color .18s, background .18s, transform .15s;
    }

    .field-group input:focus,
    .auth-card input:focus {
        background: #fff;
        border-color: #0F9B8E;
        transform: scale(1.01);
    }

    .field-error {
        font-size: .78rem;
        color: #dc2626;
        font-weight: 700;
    }

    .auth-error {
        background: rgba(220,38,38,.08);
        border: 1px solid rgba(220,38,38,.2);
        color: #991b1b;
        border-radius: 10px;
        padding: .65rem 1rem;
        font-size: .85rem;
        font-weight: 700;
        margin-bottom: 1rem;
    }

    /* ── Fila recordar / olvidé ── */
    .auth-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.2rem;
    }

    .remember {
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .remember input {
        width: 15px; height: 15px;
        accent-color: #0F9B8E;
        cursor: pointer;
        margin: 0;
        padding: 0;
        background: none;
        border: none;
        transform: none;
    }

    .remember label {
        font-size: .82rem;
        font-weight: 700;
        color: #7B8194;
        cursor: pointer;
    }

    .forgot-link {
        font-size: .82rem;
        font-weight: 700;
        color: #0F9B8E;
        text-decoration: none;
    }

    .forgot-link:hover { text-decoration: underline; }

    /* ── Botón principal ── */
    .auth-btn {
        width: 100%;
        padding: .82rem;
        border-radius: 999px;
        background: #0F9B8E;
        color: #fff;
        border: none;
        font-family: 'Nunito', sans-serif;
        font-size: .97rem;
        font-weight: 900;
        cursor: pointer;
        box-shadow: 0 4px 14px rgba(15,155,142,.35);
        transition: background .18s, transform .15s, box-shadow .15s;
    }

    .auth-btn:hover {
        background: #0d8a7e;
        transform: translateY(-2px);
        box-shadow: 0 7px 20px rgba(15,155,142,.45);
    }

    /* ── Footer card ── */
    .auth-footer {
        margin-top: 1.2rem;
        text-align: center;
        font-size: .85rem;
        font-weight: 700;
        color: #7B8194;
        padding: .9rem;
        background: #F0FAF9;
        border-radius: 12px;
    }

    .auth-footer a {
        color: #0F9B8E;
        font-weight: 800;
        text-decoration: none;
    }

    .auth-footer a:hover { text-decoration: underline; }

    /* ── Toast ── */
    .custom-toast {
        position: fixed;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        background: rgba(15,155,142,.95);
        color: white;
        padding: 1.5rem 2rem;
        border-radius: 16px;
        font-family: 'Nunito', sans-serif;
        font-weight: 700;
        font-size: 1rem;
        text-align: center;
        z-index: 9999;
        animation: fadeInOut 6s ease forwards;
    }

    .overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,.4);
        z-index: 9998;
    }

    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(16px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @@keyframes fadeInOut {
        0%   { opacity: 0; transform: translate(-50%, -20px); }
        10%  { opacity: 1; transform: translate(-50%, 0); }
        90%  { opacity: 1; }
        100% { opacity: 0; transform: translate(-50%, -20px); }
    }

    @@media (max-width: 700px) {
        .auth-left { display: none; }
        .auth-right { width: 100%; }
    }
</style>
</body>
</html>