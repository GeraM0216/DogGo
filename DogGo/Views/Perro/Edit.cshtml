@model DogGo.Models.Perro

@{
    ViewData["Title"] = "Editar perro";
}

<h1>Editar perro</h1>

<h4>Perro</h4>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImagenUrl" />

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Raza" class="form-label"></label>
                <input asp-for="Raza" class="form-control" />
                <span asp-validation-for="Raza" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Edad" class="form-label"></label>
                <input asp-for="Edad" class="form-control" />
                <span asp-validation-for="Edad" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Tamaño" class="form-label"></label>
                <select asp-for="Tamaño" class="form-control">
                    <option value="">Selecciona un tamaño</option>
                    <option value="Pequeño">Pequeño</option>
                    <option value="Mediano">Mediano</option>
                    <option value="Grande">Grande</option>
                </select>
                <span asp-validation-for="Tamaño" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Notas" class="form-label"></label>
                <textarea asp-for="Notas" class="form-control"></textarea>
                <span asp-validation-for="Notas" class="text-danger"></span>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
            {
                <div class="mb-3">
                    <label class="form-label">Foto actual</label>
                    <div>
                        <img src="@Model.ImagenUrl" alt="Foto de @Model.Nombre"
                             style="max-width: 220px; border-radius: 12px;" class="img-fluid border" />
                    </div>
                </div>
            }

            <div class="mb-3">
                <label for="imagenArchivo" class="form-label">Nueva foto</label>
                <input type="file" name="imagenArchivo" id="imagenArchivo" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                <small class="text-muted">Opcional. Formatos permitidos: JPG, JPEG, PNG, WEBP. Máximo 5 MB.</small>
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Guardar cambios</button>
                <a asp-action="Index" class="btn btn-secondary">Volver</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}