@{
    ViewData["Title"] = "Inicio";
    var nombreUsuario = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "Usuario";
    var esDuenio = User.IsInRole("Duenio");
    var esPaseador = User.IsInRole("Paseador");
}

@if (User.Identity.IsAuthenticated)
{
    <!-- ══ HERO — USUARIO LOGUEADO ══ -->
    <section class="hero-section">
        <div class="hero-inner">
            <div class="hero-left">
                <div class="hero-eyebrow">👋 Bienvenido de vuelta</div>
                <h1 class="hero-title">
                    Hola, <span class="hero-name">@nombreUsuario</span>.<br>
                    ¿Listo para el paseo de hoy?
                </h1>
                <p class="hero-sub">
                    Aquí tienes todo lo de tus mascotas y paseos en un solo lugar. Rápido y sencillo.
                </p>

                @if (esDuenio)
                {
                    <div class="paseo-banner" id="paseo-banner" style="display:none">
                        <div class="pb-icon">🦮</div>
                        <div class="pb-info">
                            <div class="pb-title" id="pb-title">Próximo paseo</div>
                            <div class="pb-sub">Revisa tus paseos activos para más detalles.</div>
                        </div>
                        <a asp-controller="Paseo" asp-action="MisPaseos" class="pb-btn">Ver detalles</a>
                    </div>
                }

                <div class="hero-ctas">
                    <a asp-controller="Paseo" asp-action="MisPaseos" class="btn-primary-doggo">Ver mis paseos</a>
                    @if (esDuenio)
                    {
                        <a asp-controller="Paseador" asp-action="Directorio" class="btn-secondary-doggo">Buscar paseador</a>
                    }
                    @if (esPaseador)
                    {
                        <a asp-controller="Paseador" asp-action="Perfil" class="btn-secondary-doggo">Ver mi perfil</a>
                    }
                </div>
            </div>

            @if (esDuenio)
            {
                <div class="hero-right">
                    <div class="pet-widget">
                        <div class="pw-header">
                            <div>
                                <div class="pw-title">Tus mascotas</div>
                                <div class="pw-subtitle">Toca las flechas para cambiar</div>
                            </div>
                            <a asp-controller="Perro" asp-action="Create" class="pw-add-btn">+ Añadir</a>
                        </div>

                        <div id="pw-loading" class="pw-state">
                            <div class="pw-spinner"></div>
                            <p>Cargando tus mascotas...</p>
                        </div>

                        <div id="pw-empty" class="pw-state" style="display:none">
                            <div class="pw-empty-icon">🐾</div>
                            <p>Aún no tienes mascotas registradas.</p>
                            <a asp-controller="Perro" asp-action="Create" class="btn-primary-doggo" style="margin-top:.75rem;display:inline-block">
                                Registrar mi primer perro
                            </a>
                        </div>

                        <div id="pw-card" style="display:none">
                            <div class="pet-photo-wrap">
                                <img id="pw-foto" src="" alt="" class="pet-photo-img" style="display:none" />
                                <div id="pw-foto-fallback" class="pet-photo-fallback">🐶</div>
                            </div>
                            <div class="pet-info">
                                <div class="pet-name" id="pw-nombre"></div>
                                <div class="pet-breed" id="pw-raza"></div>
                            </div>
                            <div class="pet-stats">
                                <div class="pstat">
                                    <div class="pstat-val" id="pw-edad"></div>
                                    <div class="pstat-lbl">Edad</div>
                                </div>
                                <div class="pstat">
                                    <div class="pstat-val" id="pw-tamaño"></div>
                                    <div class="pstat-lbl">Tamaño</div>
                                </div>
                            </div>
                            <div id="pw-notas-wrap" class="pet-notas" style="display:none">
                                <span class="notas-label">📝 Notas:</span>
                                <span id="pw-notas"></span>
                            </div>
                            <div class="pet-nav">
                                <button class="pnav-btn" onclick="DogGoWidget.prev()" aria-label="Anterior">&#8249;</button>
                                <div class="pet-dots" id="pw-dots"></div>
                                <button class="pnav-btn" onclick="DogGoWidget.next()" aria-label="Siguiente">&#8250;</button>
                            </div>
                            <a id="pw-ver-perfil" href="#" class="pet-ver-perfil">Ver perfil completo →</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- ══ BANDA ESTADÍSTICAS ══ -->
    <div class="stats-band">
        <div class="stat-item">
            <div class="stat-num" id="s1">247+</div>
            <div class="stat-lbl">Paseos realizados</div>
        </div>
        <div class="stat-item">
            <div class="stat-num" id="s2">38+</div>
            <div class="stat-lbl">Paseadores activos</div>
        </div>
        <div class="stat-item">
            <div class="stat-num" id="s3">183+</div>
            <div class="stat-lbl">Mascotas felices</div>
        </div>
        <div class="stat-item">
            <div class="stat-num">4.9★</div>
            <div class="stat-lbl">Calificación promedio</div>
        </div>
    </div>

    <!-- ══ CARRUSEL POR QUÉ DOGGO ══ -->
    <section class="why-section">
        <div class="why-header">
            <div class="sec-label">¿Por qué DogGo?</div>
            <h2 class="sec-title">Somos la mejor opción para tu mascota</h2>
            <p class="sec-sub">Cada detalle fue pensado para darte paz mental y a tu perro, la mejor experiencia.</p>
        </div>
        <div class="carousel-wrap">
            <div class="carousel-track" id="carousel">
                <div class="why-card">
                    <span class="wc-icon">🔒</span>
                    <span class="wc-tag tag-teal">Seguridad</span>
                    <div class="wc-title">Paseadores 100% verificados</div>
                    <div class="wc-desc">Revisamos identidad, referencias y antecedentes de cada paseador antes de que pueda aparecer en la plataforma. Tu perro siempre en manos confiables.</div>
                    <div class="wc-stat">✓ Verificación de identidad obligatoria</div>
                </div>
                <div class="why-card">
                    <span class="wc-icon">📍</span>
                    <span class="wc-tag tag-amber">Seguimiento</span>
                    <div class="wc-title">GPS en tiempo real</div>
                    <div class="wc-desc">Sigue cada paso del paseo desde tu celular. Recibe actualizaciones de ubicación y sabe exactamente por dónde va tu mejor amigo en todo momento.</div>
                    <div class="wc-stat">✓ Actualizaciones en tiempo real</div>
                </div>
                <div class="why-card">
                    <span class="wc-icon">💬</span>
                    <span class="wc-tag tag-coral">Comunicación</span>
                    <div class="wc-title">Chat directo con el paseador</div>
                    <div class="wc-desc">Comunícate sin intermediarios antes, durante y después del paseo. Fotos, mensajes y actualizaciones directamente desde el paseador a tu teléfono.</div>
                    <div class="wc-stat">✓ Mensajería instantánea incluida</div>
                </div>
                <div class="why-card">
                    <span class="wc-icon">⭐</span>
                    <span class="wc-tag tag-teal">Calidad</span>
                    <div class="wc-title">Calificaciones transparentes</div>
                    <div class="wc-desc">Cada paseo puede ser calificado. Los puntajes son públicos y acumulativos, así siempre sabes con quién confiar basándote en experiencias reales.</div>
                    <div class="wc-stat">✓ 4.9 de promedio en la plataforma</div>
                </div>
                <div class="why-card">
                    <span class="wc-icon">🐾</span>
                    <span class="wc-tag tag-amber">Personalización</span>
                    <div class="wc-title">Perfil completo de tu mascota</div>
                    <div class="wc-desc">Registra raza, edad, tamaño, notas especiales y foto. El paseador llega preparado y ya conoce a tu perro antes de su primer paseo juntos.</div>
                    <div class="wc-stat">✓ Información siempre disponible</div>
                </div>
            </div>
            <div class="carousel-nav">
                <button class="cnav-btn" onclick="CarouselDG.prev()">&#8249;</button>
                <div class="cdots" id="cdots"></div>
                <button class="cnav-btn" onclick="CarouselDG.next()">&#8250;</button>
            </div>
        </div>
    </section>

    <!-- ══ CÓMO FUNCIONA ══ -->
    <section class="how-section">
        <div class="how-inner">
            <div class="how-header">
                <div class="sec-label">Proceso simple</div>
                <h2 class="sec-title">¿Cómo funciona DogGo?</h2>
                <p class="sec-sub">En cuatro pasos sencillos tu perro ya está listo para su próximo paseo.</p>
            </div>
            <div class="steps-grid">
                <div class="step">
                    <div class="step-num">1</div>
                    <div class="step-icon">📝</div>
                    <div class="step-title">Regístrate</div>
                    <div class="step-desc">Crea tu cuenta en minutos y registra el perfil de tu mascota con foto y datos.</div>
                </div>
                <div class="step">
                    <div class="step-num">2</div>
                    <div class="step-icon">🔍</div>
                    <div class="step-title">Elige paseador</div>
                    <div class="step-desc">Explora perfiles, lee calificaciones y elige al paseador que más te convenza.</div>
                </div>
                <div class="step">
                    <div class="step-num">3</div>
                    <div class="step-icon">📅</div>
                    <div class="step-title">Agenda el paseo</div>
                    <div class="step-desc">Selecciona fecha y hora. El paseador confirma y listo, todo queda registrado.</div>
                </div>
                <div class="step">
                    <div class="step-num">4</div>
                    <div class="step-icon">🦮</div>
                    <div class="step-title">¡Disfruta!</div>
                    <div class="step-desc">Sigue el paseo en tiempo real y recibe actualizaciones directo de tu paseador.</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ══ TESTIMONIOS ══ -->
    <section class="test-section">
        <div class="test-inner">
            <div class="test-header">
                <div class="sec-label">Lo que dicen nuestros usuarios</div>
                <h2 class="sec-title">Dueños que ya confían en DogGo</h2>
            </div>
            <div class="test-grid">
                <div class="test-card">
                    <div class="test-stars">★★★★★</div>
                    <p class="test-text">"Desde que uso DogGo duermo tranquila. Puedo ver en el mapa exactamente dónde está mi perro y el paseador me manda fotos a cada rato. ¡Increíble!"</p>
                    <div class="test-author">
                        <div class="test-avatar av-t">MG</div>
                        <div>
                            <div class="test-aname">María González</div>
                            <div class="test-asub">Dueña de Luna, Poodle</div>
                        </div>
                    </div>
                </div>
                <div class="test-card">
                    <div class="test-stars">★★★★★</div>
                    <p class="test-text">"Lo mejor es que puedo ver las calificaciones reales de cada paseador. Encontré al indicado para Rocky en 5 minutos. Ya lleva 3 meses paseando con él."</p>
                    <div class="test-author">
                        <div class="test-avatar av-a">CR</div>
                        <div>
                            <div class="test-aname">Carlos Rodríguez</div>
                            <div class="test-asub">Dueño de Rocky, Labrador</div>
                        </div>
                    </div>
                </div>
                <div class="test-card">
                    <div class="test-stars">★★★★★</div>
                    <p class="test-text">"El chat con el paseador es muy útil. Le puedo dar instrucciones especiales sobre Max y él las sigue al pie de la letra. Muy fácil de usar."</p>
                    <div class="test-author">
                        <div class="test-avatar av-c">AL</div>
                        <div>
                            <div class="test-aname">Ana López</div>
                            <div class="test-asub">Dueña de Max, Golden Retriever</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ══ CTA ACCESOS RÁPIDOS ══ -->
    <section class="cta-section">
        <div class="cta-inner">
            <div class="cta-header">
                <div class="cta-badge">🎉 ¡Todo listo para ti!</div>
                <h2 class="cta-title">Prueba nuestros <span class="cta-em">servicios hoy</span></h2>
                <p class="cta-sub">Las funciones que más usas, siempre a un clic de distancia.</p>
            </div>
            <div class="cta-grid">
                <a asp-controller="Paseo" asp-action="MisPaseos" class="cta-card">
                    <span class="cta-card-icon">🦮</span>
                    <div class="cta-card-title">Ver mis paseos</div>
                    <div class="cta-card-desc">Activos, historial y seguimiento en tiempo real.</div>
                </a>
                @if (esDuenio)
                {
                    <a asp-controller="Paseador" asp-action="Directorio" class="cta-card">
                        <span class="cta-card-icon">🔍</span>
                        <div class="cta-card-title">Buscar paseador</div>
                        <div class="cta-card-desc">Encuentra al paseador perfecto para tu mascota.</div>
                    </a>
                    <a asp-controller="Perro" asp-action="Index" class="cta-card">
                        <span class="cta-card-icon">🐶</span>
                        <div class="cta-card-title">Mis perros</div>
                        <div class="cta-card-desc">Administra perfiles, fotos y datos de tus mascotas.</div>
                    </a>
                }
                @if (esPaseador)
                {
                    <a asp-controller="Paseador" asp-action="Perfil" class="cta-card">
                        <span class="cta-card-icon">⭐</span>
                        <div class="cta-card-title">Mi perfil</div>
                        <div class="cta-card-desc">Revisa calificaciones y mantén tu info al día.</div>
                    </a>
                }
            </div>
        </div>
    </section>
}
else
