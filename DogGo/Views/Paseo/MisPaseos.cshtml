@model List<DogGo.Models.Paseo>
@{
    ViewData["Title"] = "Mis paseos";
    var enCurso = Model.Where(p => p.Estado == "EnCurso").ToList();
    var pendientes = Model.Where(p => p.Estado == "Pendiente").ToList();
    var finalizados = Model.Where(p => p.Estado == "Finalizado").ToList();
    var cancelados = Model.Where(p => p.Estado == "Cancelado").ToList();
    var esDuenio = User.IsInRole("Duenio");
    var esPaseador = User.IsInRole("Paseador");

    string ObtenerNombresPerros(DogGo.Models.Paseo paseo)
    {
        if (paseo.PaseoPerros != null && paseo.PaseoPerros.Any(pp => pp.Perro != null))
        {
            var nombres = paseo.PaseoPerros
                .Where(pp => pp.Perro != null)
                .Select(pp => pp.Perro.Nombre)
                .Where(n => !string.IsNullOrWhiteSpace(n))
                .Distinct()
                .ToList();

            if (nombres.Any())
                return string.Join(", ", nombres);
        }

        return paseo.Perro?.Nombre ?? "Perro";
    }

    string? ObtenerImagenPerro(DogGo.Models.Paseo paseo)
    {
        if (paseo.PaseoPerros != null && paseo.PaseoPerros.Any(pp => pp.Perro != null && !string.IsNullOrWhiteSpace(pp.Perro.ImagenUrl)))
        {
            return paseo.PaseoPerros
                .Where(pp => pp.Perro != null && !string.IsNullOrWhiteSpace(pp.Perro.ImagenUrl))
                .Select(pp => pp.Perro!.ImagenUrl)
                .FirstOrDefault();
        }

        return paseo.Perro?.ImagenUrl;
    }

    int ObtenerCantidadPerros(DogGo.Models.Paseo paseo)
    {
        if (paseo.PaseoPerros != null && paseo.PaseoPerros.Any(pp => pp.Perro != null))
        {
            return paseo.PaseoPerros
                .Where(pp => pp.Perro != null)
                .Select(pp => pp.PerroId)
                .Distinct()
                .Count();
        }

        return paseo.Perro != null ? 1 : 0;
    }
}

<div class="page-header-wrap">
    <div class="page-header-inner">
        <div class="page-eyebrow">Tu historial</div>
        <h1 class="page-title">Mis paseos</h1>
        <p class="page-sub">Revisa el estado de todos tus paseos, activos e históricos.</p>

        @if (Model.Any())
        {
            <div class="header-stats">
                @if (enCurso.Any())
                {
                    <div class="hstat hstat-green">
                        <span class="hstat-num">@enCurso.Count</span>
                        <span class="hstat-lbl">En curso</span>
                    </div>
                }
                @if (pendientes.Any())
                {
                    <div class="hstat hstat-amber">
                        <span class="hstat-num">@pendientes.Count</span>
                        <span class="hstat-lbl">Pendiente@(pendientes.Count > 1 ? "s" : "")</span>
                    </div>
                }
                <div class="hstat hstat-muted">
                    <span class="hstat-num">@finalizados.Count</span>
                    <span class="hstat-lbl">Finalizado@(finalizados.Count != 1 ? "s" : "")</span>
                </div>
                @if (cancelados.Any())
                {
                    <div class="hstat hstat-red">
                        <span class="hstat-num">@cancelados.Count</span>
                        <span class="hstat-lbl">Cancelado@(cancelados.Count > 1 ? "s" : "")</span>
                    </div>
                }
            </div>
        }
    </div>
</div>

<div class="paseos-container">

    <form asp-action="MisPaseos" method="get" class="filtros-card">
        <div class="filtros-grid">

            <div class="filtro-group">
                <label>Buscar</label>
                <input type="text"
                       name="busqueda"
                       value="@ViewBag.Busqueda"
                       placeholder="Perro o paseador"
                       class="form-ctrl" />
            </div>

            <div class="filtro-group">
                <label>Estado</label>
                <select name="estado" class="form-ctrl form-sel">
                    <option value="">Todos</option>
                    <option value="Pendiente" selected="@(ViewBag.Estado == "Pendiente")">Pendiente</option>
                    <option value="EnCurso" selected="@(ViewBag.Estado == "EnCurso")">En curso</option>
                    <option value="Finalizado" selected="@(ViewBag.Estado == "Finalizado")">Finalizado</option>
                    <option value="Cancelado" selected="@(ViewBag.Estado == "Cancelado")">Cancelado</option>
                </select>
            </div>

            <div class="filtro-group">
                <label>Tipo</label>
                <select name="tipo" class="form-ctrl form-sel">
                    <option value="">Todos</option>
                    <option value="Ahora" selected="@(ViewBag.Tipo == "Ahora")">Ahora</option>
                    <option value="Programado" selected="@(ViewBag.Tipo == "Programado")">Programado</option>
                </select>
            </div>

            <div class="filtro-group">
                <label>Ordenar</label>
                <select name="orden" class="form-ctrl form-sel">
                    <option value="fecha_desc" selected="@(ViewBag.Orden == "fecha_desc")">Más recientes</option>
                    <option value="fecha_asc" selected="@(ViewBag.Orden == "fecha_asc")">Más antiguos</option>
                    <option value="precio_desc" selected="@(ViewBag.Orden == "precio_desc")">Mayor precio</option>
                    <option value="precio_asc" selected="@(ViewBag.Orden == "precio_asc")">Menor precio</option>
                </select>
            </div>

            <div class="filtros-actions">
                <button type="submit" class="btn-solicitar">Filtrar</button>
                <a asp-action="MisPaseos" class="btn-ver-perfil">Limpiar</a>
            </div>

        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">🦮</div>
            <h3>No se encontraron paseos</h3>
            <p>Intenta cambiar los filtros o limpiar la búsqueda.</p>
            <a asp-controller="Paseador" asp-action="Directorio" class="btn-primary-doggo" style="margin-top:.75rem;display:inline-block">
                Buscar paseador
            </a>
        </div>
    }
    else
    {
        @if (enCurso.Any())
        {
            <div class="seccion">
                <div class="seccion-header">
                    <span class="seccion-dot dot-green"></span>
                    <h2 class="seccion-titulo">En curso</h2>
                    <span class="seccion-count count-green">@enCurso.Count</span>
                </div>
                <div class="paseos-list">
                    @foreach (var p in enCurso)
                    {
                        var nombresPerros = ObtenerNombresPerros(p);
                        var imagenPerro = ObtenerImagenPerro(p);
                        var cantidadPerros = ObtenerCantidadPerros(p);

                        <div class="paseo-card card-green">
                            <a asp-action="Mapa" asp-route-id="@p.Id" class="paseo-link">
                                <div class="paseo-card-inner">
                                    <div class="card-left">
                                        <div class="dog-photo-wrap">
                                            @if (!string.IsNullOrWhiteSpace(imagenPerro))
                                            {
                                                <img src="@imagenPerro" alt="Foto de @nombresPerros" class="dog-photo-img" />
                                            }
                                            else
                                            {
                                                <div class="dog-photo-placeholder">🐶</div>
                                            }
                                        </div>
                                    </div>

                                    <div class="card-center">
                                        <div class="paseo-top-row">
                                            <span class="paseo-id">Paseo #@p.Id</span>
                                            <span class="paseo-perro">🐶 @nombresPerros</span>
                                            @if (cantidadPerros > 1)
                                            {
                                                <span class="paseo-badge badge-teal">@cantidadPerros perros</span>
                                            }
                                            @if (p.EsProgramado)
                                            {
                                                <span class="paseo-badge badge-blue">Programado</span>
                                            }
                                        </div>

                                        <div class="paseo-meta">
                                            <span>📅 @(p.FechaInicio?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Sin inicio")</span>
                                            <span>⏱ @p.DuracionMinutos min</span>
                                            @if (p.EsProgramado && p.FechaProgramada != null)
                                            {
                                                <span>🗓 @p.FechaProgramada?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                            }
                                        </div>

                                        <div class="paseo-extra">
                                            @if (esDuenio && p.Paseador?.Usuario != null)
                                            {
                                                <span>👤 Paseador: @p.Paseador.Usuario.Nombre @p.Paseador.Usuario.Apellido</span>
                                            }
                                            @if (esPaseador && p.Perro?.Dueño != null)
                                            {
                                                <span>👤 Dueño: @p.Perro.Dueño.Nombre @p.Perro.Dueño.Apellido</span>
                                            }
                                        </div>
                                    </div>

                                    <div class="card-right card-right-inline">
                                        <span class="estado-badge estado-green">● En curso</span>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        }

        @if (pendientes.Any())
        {
            <div class="seccion">
                <div class="seccion-header">
                    <span class="seccion-dot dot-amber"></span>
                    <h2 class="seccion-titulo">Pendientes</h2>
                    <span class="seccion-count count-amber">@pendientes.Count</span>
                </div>
                <div class="paseos-list">
                    @foreach (var p in pendientes)
                    {
                        var nombresPerros = ObtenerNombresPerros(p);
                        var imagenPerro = ObtenerImagenPerro(p);
                        var cantidadPerros = ObtenerCantidadPerros(p);

                        <div class="paseo-card card-amber">
                            <div class="paseo-card-inner">
                                <a asp-action="Mapa" asp-route-id="@p.Id" class="paseo-link paseo-link-full">
                                    <div class="card-left">
                                        <div class="dog-photo-wrap">
                                            @if (!string.IsNullOrWhiteSpace(imagenPerro))
                                            {
                                                <img src="@imagenPerro" alt="Foto de @nombresPerros" class="dog-photo-img" />
                                            }
                                            else
                                            {
                                                <div class="dog-photo-placeholder">🐶</div>
                                            }
                                        </div>
                                    </div>

                                    <div class="card-center">
                                        <div class="paseo-top-row">
                                            <span class="paseo-id">Paseo #@p.Id</span>
                                            <span class="paseo-perro">🐶 @nombresPerros</span>
                                            @if (cantidadPerros > 1)
                                            {
                                                <span class="paseo-badge badge-teal">@cantidadPerros perros</span>
                                            }
                                            @if (p.EsProgramado)
                                            {
                                                <span class="paseo-badge badge-blue">Programado</span>
                                            }
                                        </div>

                                        <div class="paseo-meta">
                                            @if (p.EsProgramado && p.FechaProgramada != null)
                                            {
                                                <span>🗓 @p.FechaProgramada?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                            }
                                            else
                                            {
                                                <span>📅 @(p.FechaInicio?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Pendiente")</span>
                                            }
                                            <span>⏱ @p.DuracionMinutos min</span>
                                        </div>

                                        <div class="paseo-extra">
                                            @if (esDuenio && p.Paseador?.Usuario != null)
                                            {
                                                <span>👤 Paseador: @p.Paseador.Usuario.Nombre @p.Paseador.Usuario.Apellido</span>
                                            }
                                            @if (esPaseador && p.Perro?.Dueño != null)
                                            {
                                                <span>👤 Dueño: @p.Perro.Dueño.Nombre @p.Perro.Dueño.Apellido</span>
                                            }
                                        </div>
                                    </div>
                                </a>

                                <div class="card-right card-right-actions">
                                    <span class="estado-badge estado-amber">● Pendiente</span>
                                    <button class="btn-cancelar-toggle"
                                            onclick="toggleCancelar(@p.Id)"
                                            title="Cancelar paseo">
                                        ✕
                                    </button>
                                </div>
                            </div>

                            <div class="cancelar-panel" id="cancelar-@p.Id" style="display:none">
                                <form asp-action="Cancelar" asp-route-id="@p.Id" method="post" class="cancelar-form">
                                    @Html.AntiForgeryToken()
                                    <input type="text" name="motivo" class="form-ctrl" placeholder="Motivo de cancelación (opcional)" />
                                    <div class="cancelar-actions">
                                        <button type="button" class="btn-no-cancelar" onclick="toggleCancelar(@p.Id)">Volver</button>
                                        <button type="submit" class="btn-confirmar-cancelar"
                                                onclick="return confirm('¿Seguro que quieres cancelar este paseo?')">
                                            Confirmar cancelación
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (finalizados.Any())
        {
            <div class="seccion">
                <div class="seccion-header">
                    <span class="seccion-dot dot-muted"></span>
                    <h2 class="seccion-titulo">Finalizados</h2>
                    <span class="seccion-count count-muted">@finalizados.Count</span>
                </div>
                <div class="paseos-list">
                    @foreach (var p in finalizados)
                    {
                        var nombresPerros = ObtenerNombresPerros(p);
                        var imagenPerro = ObtenerImagenPerro(p);
                        var cantidadPerros = ObtenerCantidadPerros(p);

                        <div class="paseo-card card-muted">
                            <div class="paseo-card-inner">
                                <a asp-action="Mapa" asp-route-id="@p.Id" class="paseo-link paseo-link-full">
                                    <div class="card-left">
                                        <div class="dog-photo-wrap">
                                            @if (!string.IsNullOrWhiteSpace(imagenPerro))
                                            {
                                                <img src="@imagenPerro" alt="Foto de @nombresPerros" class="dog-photo-img" />
                                            }
                                            else
                                            {
                                                <div class="dog-photo-placeholder">🐶</div>
                                            }
                                        </div>
                                    </div>

                                    <div class="card-center">
                                        <div class="paseo-top-row">
                                            <span class="paseo-id">Paseo #@p.Id</span>
                                            <span class="paseo-perro">🐶 @nombresPerros</span>
                                            @if (cantidadPerros > 1)
                                            {
                                                <span class="paseo-badge badge-teal">@cantidadPerros perros</span>
                                            }
                                            @if (p.EsProgramado)
                                            {
                                                <span class="paseo-badge badge-blue">Programado</span>
                                            }
                                        </div>

                                        <div class="paseo-meta">
                                            <span>▶ @(p.FechaInicio?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Sin registro")</span>
                                            @if (p.FechaFin != null)
                                            {
                                                <span>⏹ @p.FechaFin?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                            }
                                            <span>⏱ @p.DuracionMinutos min</span>
                                        </div>

                                        <div class="paseo-extra">
                                            @if (esDuenio && p.Paseador?.Usuario != null)
                                            {
                                                <span>👤 Paseador: @p.Paseador.Usuario.Nombre @p.Paseador.Usuario.Apellido</span>
                                            }
                                            @if (esPaseador && p.Perro?.Dueño != null)
                                            {
                                                <span>👤 Dueño: @p.Perro.Dueño.Nombre @p.Perro.Dueño.Apellido</span>
                                            }
                                        </div>

                                        @if (p.Calificacion != null)
                                        {
                                            <div class="calificacion-inline">
                                                <span class="cal-stars">
                                                    @for (int i = 1; i <= 5; i++)
                                                    {
                                                        <span class="@(i <= p.Calificacion.Puntaje ? "star-on" : "star-off")">★</span>
                                                    }
                                                </span>
                                                @if (!string.IsNullOrWhiteSpace(p.Calificacion.Comentario))
                                                {
                                                    <span class="cal-texto">"@p.Calificacion.Comentario"</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </a>

                                <div class="card-right card-right-stack">
                                    <span class="estado-badge estado-muted">● Finalizado</span>

                                    @if (p.Calificacion == null && User.IsInRole("Duenio"))
                                    {
                                        <a asp-controller="Calificacion"
                                               asp-action="Crear"
                                               asp-route-paseoId="@p.Id"
                                               class="btn-calificar">
                                            ⭐ Calificar
                                        </a>
                                    }
                                    else if (p.Calificacion != null)
                                    {
                                        <span class="ya-calificado">✓ Calificado</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (cancelados.Any())
        {
            <div class="seccion">
                <div class="seccion-header">
                    <span class="seccion-dot dot-red"></span>
                    <h2 class="seccion-titulo">Cancelados</h2>
                    <span class="seccion-count count-red">@cancelados.Count</span>
                </div>
                <div class="paseos-list">
                    @foreach (var p in cancelados)
                    {
                        var nombresPerros = ObtenerNombresPerros(p);
                        var imagenPerro = ObtenerImagenPerro(p);
                        var cantidadPerros = ObtenerCantidadPerros(p);
                        var fotoCancelador = p.CanceladoPor == "Paseador" ? p.Paseador?.FotoUrl : null;

                        <div class="paseo-card card-red">
                            <a asp-action="Mapa" asp-route-id="@p.Id" class="paseo-link">
                                <div class="paseo-card-inner">
                                    <div class="card-left">
                                        <div class="dog-photo-wrap">
                                            @if (!string.IsNullOrWhiteSpace(imagenPerro))
                                            {
                                                <img src="@imagenPerro" alt="Foto de @nombresPerros" class="dog-photo-img" />
                                            }
                                            else
                                            {
                                                <div class="dog-photo-placeholder">🐶</div>
                                            }
                                        </div>
                                    </div>

                                    <div class="card-center">
                                        <div class="paseo-top-row">
                                            <span class="paseo-id">Paseo #@p.Id</span>
                                            <span class="paseo-perro">🐶 @nombresPerros</span>
                                            @if (cantidadPerros > 1)
                                            {
                                                <span class="paseo-badge badge-teal">@cantidadPerros perros</span>
                                            }
                                        </div>

                                        <div class="paseo-meta">
                                            <span>📅 @(p.FechaInicio?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Sin registro")</span>
                                            <span>⏱ @p.DuracionMinutos min</span>
                                        </div>

                                        <div class="paseo-extra">
                                            @if (esDuenio && p.Paseador?.Usuario != null)
                                            {
                                                <span>👤 Paseador: @p.Paseador.Usuario.Nombre @p.Paseador.Usuario.Apellido</span>
                                            }
                                            @if (esPaseador && p.Perro?.Dueño != null)
                                            {
                                                <span>👤 Dueño: @p.Perro.Dueño.Nombre @p.Perro.Dueño.Apellido</span>
                                            }
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(p.CanceladoPor) || !string.IsNullOrWhiteSpace(p.MotivoCancelacion))
                                        {
                                            <div class="cancelacion-info">
                                                <div class="cancelador-avatar-wrap">
                                                    @if (!string.IsNullOrWhiteSpace(fotoCancelador))
                                                    {
                                                        <img src="@fotoCancelador" alt="Foto de quien canceló" class="cancelador-avatar-img" />
                                                    }
                                                    else
                                                    {
                                                        <div class="cancelador-avatar-placeholder">👤</div>
                                                    }
                                                </div>

                                                <div class="cancelacion-texto">
                                                    <div class="cancelacion-linea">
                                                        @if (!string.IsNullOrWhiteSpace(p.CanceladoPor))
                                                        {
                                                            <span>👤 Cancelado por: @p.CanceladoPor</span>
                                                        }
                                                        @if (p.FechaCancelacion != null)
                                                        {
                                                            <span>🗓 @p.FechaCancelacion?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                                        }
                                                    </div>

                                                    @if (!string.IsNullOrWhiteSpace(p.MotivoCancelacion))
                                                    {
                                                        <div class="cancelacion-linea">
                                                            <span>💬 @p.MotivoCancelacion</span>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>

                                    <div class="card-right card-right-stack">
                                        <span class="estado-badge estado-red">● Cancelado</span>
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/css/paseo.css")" />
}

@section Scripts {
    <script src="@Url.Content("~/js/paseo.js")"></script>
}