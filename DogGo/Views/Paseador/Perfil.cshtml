@model DogGo.ViewModels.PaseadorPerfilViewModel
@{
    ViewData["Title"] = "Perfil del paseador";
    var esPropietario = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                        == Model.Paseador.UsuarioId.ToString();
}

<div class="perfil-container">

    <!-- Encabezado -->
    <div class="perfil-header">
        <div class="perfil-avatar">🐾</div>
        <div class="perfil-info">
            <h3>@Model.Paseador.Usuario.Nombre @Model.Paseador.Usuario.Apellido</h3>
            <p class="text-muted">@Model.Paseador.Descripcion</p>

            <div class="perfil-stats">
                <div class="stat">
                    <span class="stat-valor">@Model.TotalPaseos</span>
                    <span class="stat-label">Paseos</span>
                </div>
                <div class="stat">
                    <span class="stat-valor">@Model.Promedio.ToString("0.0") ⭐</span>
                    <span class="stat-label">Promedio</span>
                </div>
                <div class="stat">
                    <span class="stat-valor">$@Model.Paseador.TarifaPorHora</span>
                    <span class="stat-label">Por hora</span>
                </div>
                <div class="stat">
                    <span class="stat-valor @(Model.Paseador.Disponible ? "text-success" : "text-danger")">
                        @(Model.Paseador.Disponible ? "Disponible" : "No disponible")
                    </span>
                    <span class="stat-label">Estado</span>
                </div>
            </div>
        </div>

        @if (esPropietario)
        {
            <a asp-action="Editar" class="btn btn-outline-primary btn-sm">✏️ Editar perfil</a>
        }
    </div>

    <!-- Estrellas visuales del promedio -->
    <div class="perfil-estrellas">
        @for (int i = 1; i <= 5; i++)
        {
            <span class="@(i <= Math.Round(Model.Promedio) ? "estrella-llena" : "estrella-vacia")">★</span>
        }
        <span class="ms-2 text-muted small">(@Model.Calificaciones.Count reseñas)</span>
    </div>

    <!-- Reseñas -->
    <div class="perfil-resenas">
        <h5 class="mb-3">Reseñas</h5>

        @if (!Model.Calificaciones.Any())
        {
            <p class="text-muted">Aún no hay reseñas para este paseador.</p>
        }
        else
        {
            @foreach (var c in Model.Calificaciones)
            {
                <div class="resena-card">
                    <div class="resena-header">
                        <strong>@c.Dueño.Nombre @c.Dueño.Apellido</strong>
                        <span class="resena-fecha text-muted">@c.Fecha.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="resena-estrellas">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span class="@(i <= c.Puntaje ? "estrella-llena" : "estrella-vacia")">★</span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(c.Comentario))
                    {
                        <p class="resena-comentario">@c.Comentario</p>
                    }
                </div>
            }
        }
    </div>
</div>

<style>
.perfil-container { max-width: 720px; margin: 2rem auto; padding: 0 1rem; }
.perfil-header {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    background: white;
    border: 1px solid #ddd;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1rem;
}
.perfil-avatar { font-size: 3.5rem; }
.perfil-info { flex: 1; }
.perfil-info h3 { margin: 0 0 4px; }
.perfil-stats { display: flex; gap: 1.5rem; margin-top: 0.75rem; flex-wrap: wrap; }
.stat { display: flex; flex-direction: column; }
.stat-valor { font-size: 1.1rem; font-weight: 500; }
.stat-label { font-size: 0.75rem; color: #6c757d; }
.perfil-estrellas { font-size: 1.5rem; margin-bottom: 1.5rem; }
.estrella-llena { color: #ffc107; }
.estrella-vacia { color: #dee2e6; }
.perfil-resenas { display: flex; flex-direction: column; gap: 1rem; }
.resena-card {
    background: white;
    border: 1px solid #eee;
    border-radius: 10px;
    padding: 1rem 1.25rem;
}
.resena-header { display: flex; justify-content: space-between; margin-bottom: 4px; }
.resena-fecha { font-size: 0.82rem; }
.resena-estrellas { font-size: 1rem; margin-bottom: 6px; }
.resena-comentario { margin: 0; color: #444; font-size: 0.92rem; }
</style>