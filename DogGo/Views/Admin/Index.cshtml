@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const doggoChartColors = {
        teal: '#0f9b8e',
        amber: '#f59e0b',
        green: '#16a34a',
        red: '#dc2626',
        blue: '#2563eb',
        muted: '#7b8194'
        };

        Chart.defaults.font.family = 'Nunito, sans-serif';
        Chart.defaults.color = '#7b8194';

        const estadosLabels = @Html.Raw(JsonSerializer.Serialize(estadosLabels));
        const estadosData = @Html.Raw(JsonSerializer.Serialize(estadosData));

        const rolesLabels = @Html.Raw(JsonSerializer.Serialize(rolesLabels));
        const rolesData = @Html.Raw(JsonSerializer.Serialize(rolesData));

        const topPaseadoresLabels = @Html.Raw(JsonSerializer.Serialize(topPaseadoresLabels));
        const topPaseadoresData = @Html.Raw(JsonSerializer.Serialize(topPaseadoresData));

        const ingresosLabels = @Html.Raw(JsonSerializer.Serialize(ingresosLabels));
        const ingresosData = @Html.Raw(JsonSerializer.Serialize(ingresosData));

        function crearGraficaDona(id, labels, data, colors) {
        const canvas = document.getElementById(id);
        if (!canvas) return;

        new Chart(canvas, {
        type: 'doughnut',
        data: {
        labels: labels,
        datasets: [{
        data: data,
        backgroundColor: colors,
        borderColor: '#ffffff',
        borderWidth: 3,
        hoverOffset: 8
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '62%',
        plugins: {
        legend: {
        position: 'bottom',
        labels: {
        usePointStyle: true,
        boxWidth: 8,
        font: {
        weight: '800',
        size: 11
        }
        }
        }
        }
        }
        });
        }

        function crearGraficaBarras(id, labels, data, label, formatter) {
        const canvas = document.getElementById(id);
        if (!canvas) return;

        new Chart(canvas, {
        type: 'bar',
        data: {
        labels: labels,
        datasets: [{
        label: label,
        data: data,
        backgroundColor: doggoChartColors.teal,
        borderRadius: 12,
        borderSkipped: false,
        maxBarThickness: 46
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        indexAxis: 'y',
        scales: {
        x: {
        beginAtZero: true,
        grid: {
        color: 'rgba(123,129,148,.16)'
        },
        ticks: {
        callback: function(value) {
        return formatter ? formatter(value) : value;
        },
        font: {
        weight: '800'
        }
        }
        },
        y: {
        grid: {
        display: false
        },
        ticks: {
        font: {
        weight: '800'
        }
        }
        }
        },
        plugins: {
        legend: {
        display: false
        },
        tooltip: {
        callbacks: {
        label: function(context) {
        const value = context.raw ?? 0;
        return formatter ? `${label}: ${formatter(value)}` : `${label}: ${value}`;
        }
        }
        }
        }
        }
        });
        }

        crearGraficaDona(
        'chartPaseosEstado',
        estadosLabels,
        estadosData,
        [
        doggoChartColors.amber,
        doggoChartColors.green,
        doggoChartColors.muted,
        doggoChartColors.red
        ]
        );

        crearGraficaDona(
        'chartUsuariosRol',
        rolesLabels,
        rolesData,
        [
        doggoChartColors.teal,
        doggoChartColors.blue,
        doggoChartColors.amber
        ]
        );

        crearGraficaBarras(
        'chartTopPaseadores',
        topPaseadoresLabels,
        topPaseadoresData,
        'Paseos finalizados',
        function(value) { return value; }
        );

        crearGraficaBarras(
        'chartIngresosPaseador',
        ingresosLabels,
        ingresosData,
        'Ingresos finalizados',
        function(value) {
        return '$' + Number(value).toLocaleString('es-MX', {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
        });
        }
        );
    </script>
}