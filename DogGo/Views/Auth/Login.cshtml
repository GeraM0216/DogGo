@model DogGo.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesión";
}


@{
    Layout = null;
}

<div class="login-container">

    <div class="login-left">
        <h1>DogGo 🐶 </h1>
        <p>Conecta con paseadores cerca de ti</p>
    </div>

    <div class="login-right">
        <div class="login-card">

            <h2>Bienvenido</h2>
            <p>Inicia sesión</p>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="error"></div>

                <input asp-for="Email" placeholder="Correo" />
                <span asp-validation-for="Email"></span>

                <input asp-for="Password" type="password" placeholder="Contraseña" />
                <span asp-validation-for="Password"></span>

                <div class="remember">
                    <input asp-for="RememberMe" />
                    <label asp-for="RememberMe">Recordarme</label>
                </div>

                <button type="submit">Entrar</button>
            </form>

            <p class="register">
                ¿No tienes cuenta?
                <a asp-action="Register">Regístrate</a>
            </p>

        </div>
    </div>

</div>


 <!-- PopUp Elegante -->

 @if (TempData["Success"] != null)
{
    <div id="overlay" class="overlay"></div>

    <div id="toast" class="custom-toast">
        @TempData["Success"]
    </div>
}

<script>
    setTimeout(() => {
        const toast = document.getElementById('toast');
        const overlay = document.getElementById('overlay');

        if (toast) toast.remove();
        if (overlay) overlay.remove();
    }, 6000);
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}



<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
}

.login-container {    
    display: flex;
    height: 100vh;
    width: 100%;
}

/* IZQUIERDA */
.login-left {
    width: 35%; 
    max-width: 400px;
    backdrop-filter: blur(10px);
    background: linear-gradient(135deg, #4f46e5cc, #6366f1cc);
    color: white;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 60px;
}

.login-left::before {
    content: "";
    position: absolute;
    width: 300px;
    height: 300px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    top: -50px;
    left: -50px;
}

.login-left p {
    opacity: 0.85;
    font-size: 18px;
    line-height: 1.5;
    max-width: 300px;
}

.login-left h1 {
    font-size: 56px;
    font-weight: bold;
    margin-bottom: 10px;
}

/* DERECHA */
.login-right {
    flex: 1;

    display: flex;
    justify-content: center;
    align-items: center;

    background: url('/images/parque-ecologico.jpg') center/cover no-repeat;
    
    position: relative;

}

.login-right::before {
    content: "";
    position: absolute;
    inset: 0;

    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
   
    background: rgba(0,0,0,0.2);
}



.login-card {
    width: 320px;
    padding: 30px;
    border-radius: 20px;

    /* Efecto vidrio */
    backdrop-filter: blur(20px);
    background: rgba(255, 255, 255, 0.25);
    -webkit-backdrop-filter: blur(20px);
        
    border: 1px solid rgba(255,255,255,0.4);
       
    box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    /* Sobreposicion */
    position: relative;
    z-index: 2;
   
}

.login-card input {        
    width: 100%;
    padding: 12px;
    margin-bottom: 12px;
    border-radius: 10px;
    background: rgba(255,255,255,0.6); 
    border: 1px solid rgba(255,255,255,0.4);
    outline: none;
}

.login-card h2 {
    color: #111;
}


.login-card p {
    color: rgba(0,0,0,0.6);
}

.login-card input:focus {
    background: rgba(255,255,255,0.8);
    border: 1px solid #6366f1;
}

.login-card button {
    width: 100%;
    padding: 12px;
    background: linear-gradient(135deg, #4f46e5, #6366f1);
    color: white;
    border: none;
    border-radius: 10px;
    font-weight: bold;
}

.login-card button:hover {
    background: #4338ca;
}

.register {
    text-align: center;
    margin-top: 10px;
}
    /* Checkbox y label limpios */
.remember {
    display: flex;
    align-items: center;
    gap: 8px; 
    margin: 10px 0;
}

.remember input {
    width: 16px;
    height: 16px;
    cursor: pointer;
}
.remember label {
    font-size: 14px;
    color: rgba(0,0,0,0.7);
    cursor: pointer;
}

.custom-toast {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);

    background: rgba(0, 0, 0, 0.85);
    color: white;

    padding: 25px 35px;
    border-radius: 15px;

    font-weight: 500;
    font-size: 18px;
    text-align: center;

    z-index: 9999;

    animation: fadeInOut 6s ease forwards;
}

@@keyframes fadeInOut {
    0% { opacity: 0; transform: translate(-50%, -20px); }
    10% { opacity: 1; transform: translate(-50%, 0); }
    90% { opacity: 1; }
    100% { opacity: 0; transform: translate(-50%, -20px); }
}
.overlay {
    position: fixed;
    inset: 0;

    background: rgba(0, 0, 0, 0.5); /* oscuridad */

    z-index: 9998;
}

</style>

