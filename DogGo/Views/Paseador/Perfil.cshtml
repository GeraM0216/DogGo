@model DogGo.ViewModels.PaseadorPerfilViewModel
@{
    ViewData["Title"] = "Perfil del paseador";
    var esPropietario = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value
                        == Model.Paseador.UsuarioId.ToString();
    var zonas = string.IsNullOrWhiteSpace(Model.Paseador.ZonaServicio)
        ? new List<string>()
        : Model.Paseador.ZonaServicio.Split(',')
            .Select(z => z.Trim())
            .Where(z => !string.IsNullOrWhiteSpace(z))
            .ToList();
}

<div class="perfil-container">

    <!-- ── Hero card ── -->
    <div class="perfil-hero-card">

        <!-- Avatar -->
        <div class="perfil-avatar-wrap">
            @if (!string.IsNullOrWhiteSpace(Model.Paseador.FotoUrl))
            {
                <img src="@Model.Paseador.FotoUrl" alt="Foto de @Model.Paseador.Usuario.Nombre" class="perfil-foto" />
            }
            else
            {
                <div class="perfil-foto-placeholder">🐾</div>
            }
            <div class="perfil-disp @(Model.Paseador.Disponible ? "disp-si" : "disp-no")">
                ● @(Model.Paseador.Disponible ? "Disponible" : "No disponible")
            </div>
        </div>

        <!-- Info principal -->
        <div class="perfil-info">
            <div class="perfil-top-row">
                <h2 class="perfil-name">@Model.Paseador.Usuario.Nombre @Model.Paseador.Usuario.Apellido</h2>
                @if (esPropietario)
                {
                    <a asp-action="Editar" class="btn-editar">✏️ Editar perfil</a>
                }
            </div>

            <!-- Chips -->
            <div class="perfil-chips">
                @if (zonas.Any())
                {
                    @foreach (var zona in zonas)
                    {
                        <span class="chip chip-teal">@zona</span>
                    }
                }
                @if (Model.Paseador.ExperienciaAnios != null)
                {
                    <span class="chip chip-amber">@Model.Paseador.ExperienciaAnios año(s) de experiencia</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Paseador.Usuario.Telefono))
                {
                    <span class="chip chip-muted">📞 @Model.Paseador.Usuario.Telefono</span>
                }
            </div>

            <!-- Descripción -->
            <p class="perfil-desc">
                @(string.IsNullOrWhiteSpace(Model.Paseador.Descripcion)
                    ? "Este paseador aún no ha agregado una descripción."
                    : Model.Paseador.Descripcion)
            </p>

            <!-- Stats -->
            <div class="perfil-stats">
                <div class="pstat">
                    <div class="pstat-val">@Model.TotalPaseos</div>
                    <div class="pstat-lbl">Paseos</div>
                </div>
                <div class="pstat">
                    <div class="pstat-val">@Model.Promedio.ToString("0.0") ⭐</div>
                    <div class="pstat-lbl">Promedio</div>
                </div>
                <div class="pstat">
                    <div class="pstat-val">@Model.Calificaciones.Count</div>
                    <div class="pstat-lbl">Reseñas</div>
                </div>
                <div class="pstat">
                    <div class="pstat-val">$@Model.Paseador.TarifaPorHora.ToString("0.##")</div>
                    <div class="pstat-lbl">Por hora</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── Banner resumen estrellas ── -->
    <div class="perfil-stars-banner">
        <div class="psb-stars">
            @for (int i = 1; i <= 5; i++)
            {
                <span class="@(i <= Math.Round(Model.Promedio) ? "star-on" : "star-off")">★</span>
            }
        </div>
        <span class="psb-texto">
            @Model.Promedio.ToString("0.0") de 5 &mdash; @Model.Calificaciones.Count reseña(s)
        </span>
    </div>

    <!-- ── Reseñas ── -->
    <div class="resenas-card">
        <h3 class="resenas-title">Reseñas recientes</h3>

        @if (!Model.Calificaciones.Any())
        {
            <div class="resenas-empty">
                <span>🐾</span> Aún no hay reseñas para este paseador.
            </div>
        }
        else
        {
            <div class="resenas-list">
                @foreach (var c in Model.Calificaciones)
                {
                    <div class="resena-item">
                        <div class="resena-top">
                            <div class="resena-autor-wrap">
                                <div class="resena-avatar">
                                    @c.Dueño.Nombre.Substring(0,1)@c.Dueño.Apellido.Substring(0,1)
                                </div>
                                <div>
                                    <div class="resena-autor">@c.Dueño.Nombre @c.Dueño.Apellido</div>
                                    <div class="resena-fecha">@c.Fecha.ToString("dd/MM/yyyy")</div>
                                </div>
                            </div>
                            <div class="resena-stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="@(i <= c.Puntaje ? "star-on" : "star-off")">★</span>
                                }
                            </div>
                        </div>
                        <p class="resena-comentario">
                            @(string.IsNullOrWhiteSpace(c.Comentario)
                                ? "Sin comentario adicional."
                                : c.Comentario)
                        </p>
                    </div>
                }
            </div>
        }
    </div>

</div>

@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/css/paseador.css")" />
}
