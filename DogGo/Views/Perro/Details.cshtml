@model DogGo.Models.Perro
@{
    ViewData["Title"] = "Perfil de " + Model.Nombre;
}

<div class="details-wrap">

    <!-- ── Hero card ── -->
    <div class="details-hero">

        <!-- Foto -->
        <div class="details-foto-wrap">
            @if (!string.IsNullOrEmpty(Model.ImagenUrl))
            {
                <img src="@Model.ImagenUrl" alt="@Model.Nombre" class="details-foto" />
            }
            else
            {
                <div class="details-foto-placeholder">🐶</div>
            }
        </div>

        <!-- Info -->
        <div class="details-info">
            <div class="details-top-row">
                <div>
                    <div class="page-eyebrow">🐾 Perfil de mascota</div>
                    <h1 class="details-nombre">@Model.Nombre</h1>
                </div>
                <div class="details-actions-top">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-edit-top">✏️ Editar</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-delete-top">🗑</a>
                </div>
            </div>

            <!-- Chips -->
            <div class="details-chips">
                @if (!string.IsNullOrWhiteSpace(Model.Raza))
                {
                    <span class="chip chip-teal">@Model.Raza</span>
                }
                @if (Model.Edad > 0)
                {
                    <span class="chip chip-amber">@Model.Edad año@(Model.Edad != 1 ? "s" : "")</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Tamaño))
                {
                    <span class="chip chip-muted">@Model.Tamaño</span>
                }
            </div>

            <!-- Stats grid -->
            <div class="details-stats">
                <div class="dstat">
                    <div class="dstat-val">@Model.Edad</div>
                    <div class="dstat-lbl">Año@(Model.Edad != 1 ? "s" : "")</div>
                </div>
                <div class="dstat">
                    <div class="dstat-val">@(string.IsNullOrWhiteSpace(Model.Tamaño) ? "—" : Model.Tamaño)</div>
                    <div class="dstat-lbl">Tamaño</div>
                </div>
                <div class="dstat">
                    <div class="dstat-val">
                        @(Model.Dueño != null ? Model.Dueño.Nombre : "—")
                    </div>
                    <div class="dstat-lbl">Dueño</div>
                </div>
            </div>

            <!-- Notas -->
            @if (!string.IsNullOrWhiteSpace(Model.Notas))
            {
                <div class="details-notas">
                    <div class="notas-title">📝 Notas especiales</div>
                    <p class="notas-texto">@Model.Notas</p>
                </div>
            }
        </div>
    </div>

    <!-- Volver -->
    <div class="details-footer">
        <a asp-action="Index" class="btn-volver">← Volver a mis perros</a>
    </div>

</div>

@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/css/perro.css")" />
}
