@model DogGo.ViewModels.SuperAdminDashboardViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Super Admin";
    var mx = new CultureInfo("es-MX");
}

<div class="super-admin-page">

    <section class="super-hero">
        <div>
            <span class="super-kicker">PANEL TÉCNICO DEL SISTEMA</span>
            <h1>Super Admin</h1>
            <p>
                Control técnico de DogGo: seguridad, roles, estado del sistema, módulos internos,
                alertas, calidad de datos, soporte de cuentas y actividad reciente.
            </p>
        </div>

        <div class="super-hero-card">
            <span>Vista general</span>
            <strong>@Model.FechaVista.ToString("dd/MM/yyyy")</strong>
            <small>@Model.Ambiente</small>
        </div>
    </section>

    <nav class="super-tabs">
        <a href="#resumen" class="active">Resumen</a>
        <a href="#alertas">Alertas</a>
        <a href="#calidad">Calidad</a>
        <a href="#roles">Roles</a>
        <a href="#usuarios">Usuarios</a>
        <a href="#sistema">Sistema</a>
        <a href="#modulos">Módulos</a>
        <a href="#actividad">Actividad</a>
        <a href="/Admin">Admin negocio</a>
    </nav>

    <section id="resumen" class="super-grid super-grid-4">
        <article class="super-card">
            <div class="card-icon purple">👥</div>
            <h3>@Model.TotalUsuarios</h3>
            <p>Usuarios totales</p>
        </article>

        <article class="super-card">
            <div class="card-icon green">🟢</div>
            <h3>@Model.TotalUsuariosActivos</h3>
            <p>Usuarios activos</p>
        </article>

        <article class="super-card">
            <div class="card-icon red">🚷</div>
            <h3>@Model.TotalUsuariosDesactivados</h3>
            <p>Desactivados</p>
        </article>

        <article class="super-card">
            <div class="card-icon dark">⚙️</div>
            <h3>@Model.TotalSuperAdmins</h3>
            <p>Super admins</p>
        </article>
    </section>

    <section class="super-grid super-grid-4">
        <article class="super-card soft-blue">
            <div class="card-icon blue">👤</div>
            <h3>@Model.TotalDuenios</h3>
            <p>Dueños registrados</p>
        </article>

        <article class="super-card soft-green">
            <div class="card-icon green">🐕‍🦺</div>
            <h3>@Model.TotalPaseadoresUsuarios</h3>
            <p>Usuarios paseadores</p>
        </article>

        <article class="super-card soft-yellow">
            <div class="card-icon yellow">🐶</div>
            <h3>@Model.TotalPerros</h3>
            <p>Perros registrados</p>
        </article>

        <article class="super-card soft-red">
            <div class="card-icon red">🚶</div>
            <h3>@Model.TotalPaseos</h3>
            <p>Paseos registrados</p>
        </article>
    </section>

    <section class="super-grid super-grid-4">
        <article class="super-card border-yellow">
            <div class="card-icon yellow">⏳</div>
            <h3>@Model.PaseosPendientes</h3>
            <p>Paseos pendientes</p>
        </article>

        <article class="super-card border-green">
            <div class="card-icon green">▶</div>
            <h3>@Model.PaseosEnCurso</h3>
            <p>Paseos en curso</p>
        </article>

        <article class="super-card border-blue">
            <div class="card-icon blue">✅</div>
            <h3>@Model.PaseosFinalizados</h3>
            <p>Paseos finalizados</p>
        </article>

        <article class="super-card border-red">
            <div class="card-icon red">✕</div>
            <h3>@Model.PaseosCancelados</h3>
            <p>Paseos cancelados</p>
        </article>
    </section>

    <section class="super-grid super-grid-3">
        <article class="super-wide-card">
            <div class="wide-icon green">💰</div>
            <div>
                <span>Ingresos finalizados</span>
                <strong>@Model.IngresosFinalizados.ToString("C", mx)</strong>
                <p>Calculado solo con paseos finalizados</p>
            </div>
        </article>

        <article class="super-wide-card">
            <div class="wide-icon blue">🎫</div>
            <div>
                <span>Ticket promedio</span>
                <strong>@Model.TicketPromedio.ToString("C", mx)</strong>
                <p>Promedio por paseo finalizado</p>
            </div>
        </article>

        <article class="super-wide-card warning">
            <div class="wide-icon yellow">⚠️</div>
            <div>
                <span>Usuarios sin confirmar</span>
                <strong>@Model.UsuariosSinConfirmar</strong>
                <p>Cuentas pendientes de validación por correo</p>
            </div>
        </article>
    </section>

    <section id="alertas" class="super-panel">
        <div class="panel-header">
            <div>
                <h2>Alertas técnicas</h2>
                <p>Situaciones que el SuperAdmin puede revisar para mantener estable la plataforma.</p>
            </div>
            <span class="pill neutral">@Model.Alertas.Count alertas</span>
        </div>

        <div class="maintenance-actions">
            <form asp-controller="SuperAdmin" asp-action="LimpiarCodigosExpirados" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="maintenance-btn">
                    Limpiar códigos de confirmación expirados
                </button>
            </form>

            <form asp-controller="SuperAdmin" asp-action="LimpiarRecuperacionesExpiradas" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="maintenance-btn danger-soft">
                    Limpiar recuperaciones expiradas
                </button>
            </form>
        </div>

        <div class="alert-grid">
            @foreach (var alerta in Model.Alertas)
            {
                <article class="alert-card @alerta.Tipo">
                    <div class="alert-icon">@alerta.Icono</div>
                    <div>
                        <span>@alerta.Titulo</span>
                        <strong>@alerta.Valor</strong>
                        <p>@alerta.Descripcion</p>
                    </div>
                </article>
            }
        </div>
    </section>

    <section id="calidad" class="super-panel">
        <div class="panel-header">
            <div>
                <h2>Calidad de datos</h2>
                <p>Campos incompletos que pueden afectar la experiencia de usuarios, paseadores o dueños.</p>
            </div>
            <span class="pill neutral">Auditoría rápida</span>
        </div>

        <div class="quality-grid">
            @foreach (var item in Model.CalidadDatos)
            {
                <article class="quality-card @item.Tipo">
                    <div class="quality-icon">@item.Icono</div>
                    <div>
                        <span>@item.Titulo</span>
                        <strong>@item.Valor</strong>
                        <p>@item.Descripcion</p>
                    </div>
                </article>
            }
        </div>
    </section>

    <section id="roles" class="super-roles-layout">
        <div class="super-panel">
            <div class="panel-header">
                <div>
                    <h2>Distribución de roles</h2>
                    <p>Resumen de permisos y tipo de usuarios registrados en DogGo.</p>
                </div>
                <span class="pill neutral">@Model.TotalUsuarios usuarios</span>
            </div>

            <div class="role-grid">
                @foreach (var rol in Model.DistribucionRoles)
                {
                    <article class="role-card @rol.Tipo">
                        <div class="role-icon">@rol.Icono</div>
                        <div>
                            <span>@rol.Rol</span>
                            <strong>@rol.Total</strong>
                        </div>
                    </article>
                }
            </div>
        </div>

        <div class="super-panel">
            <div class="panel-header">
                <div>
                    <h2>Usuarios administrativos</h2>
                    <p>Cuentas con acceso a paneles internos.</p>
                </div>
                <span class="pill neutral">@Model.UsuariosAdministrativos.Count cuentas</span>
            </div>

            <div class="admin-user-list">
                @if (Model.UsuariosAdministrativos.Any())
                {
                    foreach (var usuario in Model.UsuariosAdministrativos)
                    {
                        <article class="admin-user-item">
                            <div class="admin-avatar">
                                @(string.IsNullOrWhiteSpace(usuario.NombreCompleto) ? "AD" : usuario.NombreCompleto.Substring(0, 1).ToUpper())
                            </div>

                            <div>
                                <strong>@usuario.NombreCompleto</strong>
                                <p>@usuario.Email</p>
                                <small>@usuario.Rol · @usuario.Estado · @usuario.FechaRegistro.ToString("dd/MM/yyyy")</small>
                            </div>
                        </article>
                    }
                }
                else
                {
                    <div class="empty-state">No hay usuarios administrativos registrados.</div>
                }
            </div>
        </div>
    </section>

    <section id="usuarios" class="super-panel">
        <div class="panel-header">
            <div>
                <h2>Usuarios del sistema</h2>
                <p>Gestión funcional de roles, edición, activación, desactivación, eliminación segura y limpieza de códigos.</p>
            </div>
            <span class="pill neutral">@Model.UsuariosSistema.Count usuarios cargados</span>
        </div>

        <div class="users-table-wrap">
            <table class="users-table">
                <thead>
                    <tr>
                        <th>Usuario</th>
                        <th>Estado</th>
                        <th>Rol</th>
                        <th>Correo</th>
                        <th>Teléfono</th>
                        <th>Códigos</th>
                        <th>Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var usuario in Model.UsuariosSistema)
                    {
                        <tr class="@(usuario.Activo ? "" : "inactive-row")">
                            <td>
                                <div class="user-cell">
                                    <div class="admin-avatar @(usuario.Activo ? "" : "avatar-disabled")">
                                        @(string.IsNullOrWhiteSpace(usuario.NombreCompleto) ? "U" : usuario.NombreCompleto.Substring(0, 1).ToUpper())
                                    </div>
                                    <div>
                                        <strong>@usuario.NombreCompleto</strong>
                                        <span>@usuario.Email</span>
                                        <small>Registro: @usuario.FechaRegistro.ToString("dd/MM/yyyy")</small>

                                        @if (usuario.EsUsuarioActual)
                                        {
                                            <em>Cuenta actual</em>
                                        }
                                    </div>
                                </div>
                            </td>

                            <td>
                                <div class="account-status">
                                    @if (usuario.Activo)
                                    {
                                        <span class="status-pill success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="status-pill danger">Desactivado</span>

                                        @if (usuario.FechaDesactivacion != null)
                                        {
                                            <small>Desde: @usuario.FechaDesactivacion.Value.ToString("dd/MM/yyyy")</small>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(usuario.MotivoDesactivacion))
                                        {
                                            <p>@usuario.MotivoDesactivacion</p>
                                        }
                                    }
                                </div>
                            </td>

                            <td>
                                <form asp-controller="SuperAdmin" asp-action="CambiarRol" method="post" class="role-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="usuarioId" value="@usuario.Id" />

                                    <select name="nuevoRol" class="role-select" disabled="@usuario.EsUsuarioActual">
                                        <option value="Duenio" selected="@(usuario.Rol == "Duenio" || usuario.Rol == "Dueño")">Duenio</option>
                                        <option value="Paseador" selected="@(usuario.Rol == "Paseador")">Paseador</option>
                                        <option value="Admin" selected="@(usuario.Rol == "Admin")">Admin</option>
                                        <option value="SuperAdmin" selected="@(usuario.Rol == "SuperAdmin")">SuperAdmin</option>
                                    </select>

                                    <button type="submit" class="mini-btn" disabled="@usuario.EsUsuarioActual">
                                        Guardar rol
                                    </button>
                                </form>
                            </td>

                            <td>
                                @if (usuario.EmailConfirmado)
                                {
                                    <span class="status-pill success">Confirmado</span>
                                }
                                else
                                {
                                    <span class="status-pill warning">Sin confirmar</span>
                                }
                            </td>

                            <td>
                                <span class="muted-text">@usuario.Telefono</span>
                            </td>

                            <td>
                                <div class="code-status-list">
                                    @if (usuario.TieneCodigoConfirmacionActivo)
                                    {
                                        <span class="status-pill info">Confirmación activa</span>
                                    }

                                    @if (usuario.TieneCodigoConfirmacionExpirado)
                                    {
                                        <span class="status-pill warning">Confirmación expirada</span>
                                    }

                                    @if (usuario.TieneRecuperacionActiva)
                                    {
                                        <span class="status-pill info">Recuperación activa</span>
                                    }

                                    @if (usuario.TieneRecuperacionExpirada)
                                    {
                                        <span class="status-pill warning">Recuperación expirada</span>
                                    }

                                    @if (!usuario.TieneCodigoConfirmacionActivo &&
                                         !usuario.TieneCodigoConfirmacionExpirado &&
                                         !usuario.TieneRecuperacionActiva &&
                                         !usuario.TieneRecuperacionExpirada)
                                    {
                                        <span class="status-pill success">Sin códigos pendientes</span>
                                    }
                                </div>
                            </td>

                            <td>
                                <div class="user-actions">

                                    <details class="edit-user-box">
                                        <summary>Editar usuario</summary>

                                        <form asp-controller="SuperAdmin" asp-action="EditarUsuario" method="post" class="edit-user-form">
                                            @Html.AntiForgeryToken()

                                            <input type="hidden" name="usuarioId" value="@usuario.Id" />

                                            <label>
                                                Nombre
                                                <input type="text" name="nombre" value="@usuario.Nombre" required />
                                            </label>

                                            <label>
                                                Apellido
                                                <input type="text" name="apellido" value="@usuario.Apellido" required />
                                            </label>

                                            <label>
                                                Correo
                                                <input type="email" name="email" value="@usuario.Email" required />
                                            </label>

                                            <label>
                                                Teléfono
                                                <input type="text" name="telefono" value="@(usuario.Telefono == "Sin teléfono" ? "" : usuario.Telefono)" />
                                            </label>

                                            <button type="submit" class="mini-btn success">
                                                Guardar cambios
                                            </button>
                                        </form>
                                    </details>

                                    @if (!usuario.EmailConfirmado)
                                    {
                                        <form asp-controller="SuperAdmin" asp-action="ConfirmarCorreo" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="usuarioId" value="@usuario.Id" />
                                            <button type="submit" class="mini-btn success">Confirmar correo</button>
                                        </form>
                                    }

                                    @if (usuario.TieneCodigoConfirmacionActivo || usuario.TieneCodigoConfirmacionExpirado)
                                    {
                                        <form asp-controller="SuperAdmin" asp-action="LimpiarCodigoConfirmacionUsuario" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="usuarioId" value="@usuario.Id" />
                                            <button type="submit" class="mini-btn warning">Limpiar confirmación</button>
                                        </form>
                                    }

                                    @if (usuario.TieneRecuperacionActiva || usuario.TieneRecuperacionExpirada)
                                    {
                                        <form asp-controller="SuperAdmin" asp-action="LimpiarRecuperacionUsuario" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="usuarioId" value="@usuario.Id" />
                                            <button type="submit" class="mini-btn danger">Limpiar recuperación</button>
                                        </form>
                                    }

                                    @if (!usuario.EsUsuarioActual)
                                    {
                                        @if (usuario.Activo)
                                        {
                                            <details class="deactivate-user-box">
                                                <summary>Desactivar</summary>

                                                <form asp-controller="SuperAdmin"
                                                      asp-action="DesactivarUsuario"
                                                      method="post"
                                                      class="deactivate-user-form"
                                                      onsubmit="return confirm('¿Seguro que quieres desactivar este usuario? Ya no podrá iniciar sesión.');">
                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden" name="usuarioId" value="@usuario.Id" />

                                                    <label>
                                                        Motivo
                                                        <textarea name="motivo" maxlength="300" placeholder="Ej. Cuenta de prueba, suspensión temporal, solicitud interna..."></textarea>
                                                    </label>

                                                    <button type="submit" class="mini-btn warning">
                                                        Confirmar desactivación
                                                    </button>
                                                </form>
                                            </details>
                                        }
                                        else
                                        {
                                            <form asp-controller="SuperAdmin"
                                                  asp-action="ReactivarUsuario"
                                                  method="post"
                                                  onsubmit="return confirm('¿Seguro que quieres reactivar este usuario?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="usuarioId" value="@usuario.Id" />
                                                <button type="submit" class="mini-btn success">Reactivar</button>
                                            </form>
                                        }

                                        <form asp-controller="SuperAdmin"
                                              asp-action="EliminarUsuario"
                                              method="post"
                                              onsubmit="return confirm('¿Seguro que quieres ELIMINAR este usuario? Esta acción no se puede deshacer. Solo funcionará si no tiene datos relacionados.');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="usuarioId" value="@usuario.Id" />
                                            <button type="submit" class="mini-btn danger">Eliminar</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section id="sistema" class="super-system-layout">
        <div class="super-panel">
            <div class="panel-header">
                <div>
                    <h2>Estado del sistema</h2>
                    <p>Resumen técnico de la aplicación DogGo.</p>
                </div>
                <span class="pill success">Operativo</span>
            </div>

            <div class="system-list">
                <div class="system-row">
                    <span>Ambiente</span>
                    <strong>@Model.Ambiente</strong>
                </div>

                <div class="system-row">
                    <span>Servidor</span>
                    <strong>@Model.EstadoServidor</strong>
                </div>

                <div class="system-row">
                    <span>Base de datos</span>
                    <strong>@Model.EstadoBaseDatos</strong>
                </div>

                <div class="system-row">
                    <span>Usuarios activos</span>
                    <strong>@Model.TotalUsuariosActivos</strong>
                </div>

                <div class="system-row">
                    <span>Usuarios desactivados</span>
                    <strong>@Model.TotalUsuariosDesactivados</strong>
                </div>

                <div class="system-row">
                    <span>Recuperaciones de contraseña activas</span>
                    <strong>@Model.RecuperacionesPasswordActivas</strong>
                </div>

                <div class="system-row">
                    <span>Total paseadores perfil</span>
                    <strong>@Model.TotalPaseadores</strong>
                </div>

                <div class="system-row">
                    <span>Paseos en curso atorados</span>
                    <strong>@Model.PaseosEnCursoAtorados</strong>
                </div>
            </div>
        </div>

        <div class="super-panel">
            <div class="panel-header">
                <div>
                    <h2>Herramientas rápidas</h2>
                    <p>Atajos para soporte, revisión y pruebas técnicas.</p>
                </div>
                <span class="pill neutral">Soporte</span>
            </div>

            <div class="quick-actions">
                <a href="/Admin">
                    <strong>Dashboard Admin</strong>
                    <span>Métricas del negocio</span>
                </a>

                <a href="/Usuarios">
                    <strong>Usuarios</strong>
                    <span>Revisión de cuentas</span>
                </a>

                <a href="/Paseos">
                    <strong>Paseos</strong>
                    <span>Operación y estados</span>
                </a>

                <a href="/Perros">
                    <strong>Perros</strong>
                    <span>Mascotas registradas</span>
                </a>

                <a href="/Paseadores">
                    <strong>Paseadores</strong>
                    <span>Perfiles de servicio</span>
                </a>

                <a href="/swagger">
                    <strong>Swagger API</strong>
                    <span>Pruebas backend/API</span>
                </a>
            </div>
        </div>
    </section>

    <section id="modulos" class="super-main-layout">
        <div class="super-panel">
            <div class="panel-header">
                <div>
                    <h2>Módulos internos</h2>
                    <p>Estado general de las partes principales del sistema.</p>
                </div>
                <span class="pill neutral">@Model.Modulos.Count módulos</span>
            </div>

            <div class="module-grid">
                @foreach (var modulo in Model.Modulos)
                {
                    <article class="module-card @modulo.Tipo">
                        <div class="module-icon">@modulo.Icono</div>
                        <div>
                            <h3>@modulo.Nombre</h3>
                            <p>@modulo.Descripcion</p>
                            <span>@modulo.Estado</span>
                        </div>
                    </article>
                }
            </div>
        </div>

        <aside id="actividad" class="super-panel activity-panel">
            <div class="panel-header">
                <div>
                    <h2>Actividad reciente</h2>
                    <p>Últimos movimientos del sistema.</p>
                </div>
                <span class="pill neutral">@Model.ActividadReciente.Count movimientos</span>
            </div>

            <div class="activity-list">
                @if (Model.ActividadReciente.Any())
                {
                    foreach (var item in Model.ActividadReciente)
                    {
                        <article class="activity-item @item.Tipo">
                            <div class="activity-dot">@item.Icono</div>
                            <div>
                                <strong>@item.Titulo</strong>
                                <p>@item.Detalle</p>
                                <small>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                        </article>
                    }
                }
                else
                {
                    <div class="empty-state">
                        No hay actividad reciente para mostrar.
                    </div>
                }
            </div>
        </aside>
    </section>
</div>

<style>
    :root {
        --doggo-bg: #fbf7ef;
        --doggo-panel: #fffaf3;
        --doggo-card: #ffffff;
        --doggo-text: #272b42;
        --doggo-muted: #748098;
        --doggo-line: #eadfd1;
        --doggo-teal: #12a79d;
        --doggo-teal-soft: #d8f5f2;
        --doggo-blue: #5b8def;
        --doggo-green: #22c55e;
        --doggo-yellow: #f59e0b;
        --doggo-red: #ef4444;
        --doggo-purple: #6b4fa3;
        --doggo-shadow: 0 18px 45px rgba(39, 43, 66, 0.08);
    }

    .super-admin-page {
        max-width: 1540px;
        margin: 0 auto;
        padding: 48px 32px 70px;
        color: var(--doggo-text);
    }

    .super-hero {
        background: rgba(255, 250, 243, 0.96);
        border: 1px solid var(--doggo-line);
        border-radius: 26px;
        padding: 34px 36px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 28px;
        box-shadow: var(--doggo-shadow);
        margin-bottom: 18px;
    }

    .super-kicker {
        display: inline-flex;
        padding: 8px 24px;
        background: var(--doggo-teal-soft);
        color: #008d84;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 900;
        letter-spacing: 0.14em;
