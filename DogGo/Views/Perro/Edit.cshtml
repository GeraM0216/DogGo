@model DogGo.Models.Perro
@{
    ViewData["Title"] = "Editar a " + Model.Nombre;
}

<div class="form-page-wrap">
    <div class="form-card">

        <div class="form-card-header">
            <div class="page-eyebrow">✏️ Editar mascota</div>
            <h1 class="form-title">Editar a @Model.Nombre</h1>
            <p class="form-sub">Actualiza el perfil de tu mascota cuando lo necesites.</p>
        </div>

        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImagenUrl" />

            <!-- Foto -->
            <div class="foto-section">
                <div class="foto-preview" id="fotoPreview">
                    @if (!string.IsNullOrWhiteSpace(Model.ImagenUrl))
                    {
                        <img id="fotoImg" src="@Model.ImagenUrl" alt="@Model.Nombre" style="display:block" />
                        <span id="fotoEmoji" style="display:none">🐶</span>
                    }
                    else
                    {
                        <span id="fotoEmoji">🐶</span>
                        <img id="fotoImg" src="" alt="" style="display:none" />
                    }
                </div>
                <div>
                    <label class="file-upload-btn">
                        📷 Cambiar foto
                        <input type="file" name="imagenArchivo" id="imagenArchivo"
                               accept=".jpg,.jpeg,.png,.webp"
                               onchange="previewFoto(this)" />
                    </label>
                    <div class="file-hint" style="margin-top:.4rem">JPG, PNG o WEBP · Máx. 5 MB</div>
                </div>
            </div>

            <!-- Nombre -->
            <div class="form-group">
                <label asp-for="Nombre" class="form-lbl">Nombre</label>
                <input asp-for="Nombre" class="form-ctrl" />
                <span asp-validation-for="Nombre" class="val-error"></span>
            </div>

            <!-- Raza -->
            <div class="form-group">
                <label asp-for="Raza" class="form-lbl">Raza</label>
                <input asp-for="Raza" class="form-ctrl" />
                <span asp-validation-for="Raza" class="val-error"></span>
            </div>

            <!-- Edad + Tamaño -->
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Edad" class="form-lbl">Edad (años)</label>
                    <input asp-for="Edad" type="number" min="0" class="form-ctrl" />
                    <span asp-validation-for="Edad" class="val-error"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Tamaño" class="form-lbl">Tamaño</label>
                    <select asp-for="Tamaño" class="form-ctrl form-sel">
                        <option value="">Selecciona</option>
                        <option value="Pequeño">Pequeño</option>
                        <option value="Mediano">Mediano</option>
                        <option value="Grande">Grande</option>
                    </select>
                    <span asp-validation-for="Tamaño" class="val-error"></span>
                </div>
            </div>

            <!-- Notas -->
            <div class="form-group">
                <label asp-for="Notas" class="form-lbl">Notas especiales</label>
                <textarea asp-for="Notas" class="form-ctrl form-ta" rows="3"
                          placeholder="Alergias, comportamiento, instrucciones para el paseador..."></textarea>
                <span asp-validation-for="Notas" class="val-error"></span>
            </div>

            <!-- Acciones -->
            <div class="form-actions">
                <button type="submit" class="btn-save">Guardar cambios</button>
                <a asp-action="Index" class="btn-cancel">Cancelar</a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        function previewFoto(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => {
                    const img   = document.getElementById('fotoImg');
                    const emoji = document.getElementById('fotoEmoji');
                    img.src     = e.target.result;
                    img.style.display   = 'block';
                    emoji.style.display = 'none';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}

@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/css/perro.css")" />
}
