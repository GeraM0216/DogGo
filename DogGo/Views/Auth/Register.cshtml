@model DogGo.ViewModels.RegisterViewModel


@{
    Layout = null;
    ViewData["Title"] = "Crear cuenta";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="register-container">
    <div class="register-card">
        <div class="auth-logo">🐾 DogGo</div>
        <h2>Crea tu cuenta</h2>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row">
                <div class="col-md-6 form-group">
                    <label asp-for="Nombre">Nombre</label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>
                <div class="col-md-6 form-group">
                    <label asp-for="Apellido">Apellido</label>
                    <input asp-for="Apellido" class="form-control" />
                    <span asp-validation-for="Apellido" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Telefono">Teléfono</label>
                <input asp-for="Telefono" class="form-control" />
                <span asp-validation-for="Telefono" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Rol">Quiero registrarme como</label>
                <select asp-for="Rol" class="form-control">
                    <option value="">-- Selecciona --</option>
                    <option value="Duenio">Dueño de mascota</option>
                    <option value="Paseador">Paseador</option>
                </select>
                <span asp-validation-for="Rol" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Contraseña</label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword">Confirmar contraseña</label>
                <input asp-for="ConfirmPassword" class="form-control" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 mt-3">Crear cuenta</button>
        </form>

        <div class="register-footer">
           ¿Ya tienes cuenta? <a asp-action="Login">Inicia sesión</a>
       </div>
    </div>
</div>

<style>
/* Box General */
.register-container {
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;

    background: url('/Images/parque-ecologico.jpg') center/cover no-repeat;
    position: relative;
}

/* Capa blur */
.register-container::before {
    content: "";
    position: absolute;
    inset: 0;

    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);

    background: rgba(0,0,0,0.2);
}

/* Card */
.register-card {
    width: 450px;
    max-width: 90%;

    padding: 30px;
    border-radius: 20px;

    background: rgba(255,255,255,0.2);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);

    border: 1px solid rgba(255,255,255,0.3);
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);

    position: relative;
    z-index: 2;
}

.register-card {
    animation: aparecer 0.6s ease;
}

@@keyframes aparecer {
    from {
        opacity: 0;
        transform: translateY(20px) scale(0.98);
    }
    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
}

.register-card .form-control {
    background: rgba(255,255,255,0.6);
    border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.4);
 }

.register-card .form-control:focus {
    background: rgba(255,255,255,0.85);
    box-shadow: none;
}

.register-card .form-control {
    transition: all 0.2s ease;
}

.register-card .form-control:focus {
    transform: scale(1.02);
}
.register-card .btn-primary {
    transition: all 0.2s ease;
}

.register-card .btn-primary:hover {
    transform: scale(1.03);
    filter: brightness(1.1);
}

.register-footer {
    margin-top: 20px;
    padding: 15px;

    text-align: center;

    background: rgba(255, 255, 255, 0.4); 
    border-radius: 12px;

    backdrop-filter: blur(5px);

    font-size: 14px;
}

.register-footer a {
    color: #2563eb;
    font-weight: 500;
    text-decoration: none;
}

.register-footer a:hover {
    text-decoration: underline;
}
</style>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}