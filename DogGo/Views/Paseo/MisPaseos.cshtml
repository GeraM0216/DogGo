@model List<DogGo.Models.Paseo>
@using System.Globalization

@{
    var esPaseadorTemp = User.IsInRole("Paseador");
    ViewData["Title"] = esPaseadorTemp ? "Mis servicios" : "Mis paseos";

    var enCurso = Model.Where(p => p.Estado == "EnCurso").ToList();
    var pendientes = Model.Where(p => p.Estado == "Pendiente").ToList();
    var finalizados = Model.Where(p => p.Estado == "Finalizado").ToList();
    var cancelados = Model.Where(p => p.Estado == "Cancelado").ToList();

    var solicitudesFinalizacion = Model
        .Where(p => p.Estado == "EnCurso"
            && p.FinalizacionAnticipadaSolicitada
            && p.FinalizacionAnticipadaAprobada == null)
        .ToList();

    var esDuenio = User.IsInRole("Duenio");
    var esPaseador = User.IsInRole("Paseador");

    var totalActivos = enCurso.Count + pendientes.Count;
    var totalFinalizados = finalizados.Count;
    var totalCancelados = cancelados.Count;
    var totalGastadoFinalizados = finalizados.Sum(p => p.Precio);

    string ObtenerNombresPerros(DogGo.Models.Paseo paseo)
    {
        if (paseo.PaseoPerros != null && paseo.PaseoPerros.Any(pp => pp.Perro != null))
        {
            var nombres = paseo.PaseoPerros
                .Where(pp => pp.Perro != null)
                .Select(pp => pp.Perro!.Nombre)
                .Where(n => !string.IsNullOrWhiteSpace(n))
                .Distinct()
                .ToList();

            if (nombres.Any())
                return string.Join(", ", nombres);
        }

        return paseo.Perro?.Nombre ?? "Perro";
    }

    string? ObtenerImagenPerro(DogGo.Models.Paseo paseo)
    {
        if (paseo.PaseoPerros != null && paseo.PaseoPerros.Any(pp => pp.Perro != null && !string.IsNullOrWhiteSpace(pp.Perro.ImagenUrl)))
        {
            return paseo.PaseoPerros
                .Where(pp => pp.Perro != null && !string.IsNullOrWhiteSpace(pp.Perro.ImagenUrl))
                .Select(pp => pp.Perro!.ImagenUrl)
                .FirstOrDefault();
        }

        return paseo.Perro?.ImagenUrl;
    }

    int ObtenerCantidadPerros(DogGo.Models.Paseo paseo)
    {
        if (paseo.PaseoPerros != null && paseo.PaseoPerros.Any(pp => pp.Perro != null))
        {
            return paseo.PaseoPerros
                .Where(pp => pp.Perro != null)
                .Select(pp => pp.PerroId)
                .Distinct()
                .Count();
        }

        return paseo.Perro != null ? 1 : 0;
    }

    bool TieneDatosRecoleccion(DogGo.Models.Paseo paseo)
    {
        return !string.IsNullOrWhiteSpace(paseo.DireccionRecogida)
            || !string.IsNullOrWhiteSpace(paseo.ZonaRecogida)
            || !string.IsNullOrWhiteSpace(paseo.ReferenciasRecogida)
            || (paseo.LatitudRecogida.HasValue && paseo.LongitudRecogida.HasValue);
    }

    string? ObtenerUrlMaps(DogGo.Models.Paseo paseo)
    {
        if (!paseo.LatitudRecogida.HasValue || !paseo.LongitudRecogida.HasValue)
            return null;

        var lat = paseo.LatitudRecogida.Value.ToString(CultureInfo.InvariantCulture);
        var lng = paseo.LongitudRecogida.Value.ToString(CultureInfo.InvariantCulture);

        return $"https://www.google.com/maps?q={lat},{lng}";
    }

    int? ObtenerDuracionReal(DogGo.Models.Paseo paseo)
    {
        if (paseo.DuracionRealMinutos.HasValue)
            return paseo.DuracionRealMinutos.Value;

        if (paseo.FechaInicio.HasValue && paseo.FechaFin.HasValue)
        {
            return Math.Max(1, (int)Math.Ceiling((paseo.FechaFin.Value - paseo.FechaInicio.Value).TotalMinutes));
        }

        if (paseo.Estado == "EnCurso" && paseo.FechaInicio.HasValue)
        {
            return Math.Max(1, (int)Math.Ceiling((DateTime.UtcNow - paseo.FechaInicio.Value).TotalMinutes));
        }

        return null;
    }

    bool TieneSolicitudFinalizacion(DogGo.Models.Paseo paseo)
    {
        return paseo.Estado == "EnCurso"
            && paseo.FinalizacionAnticipadaSolicitada
            && paseo.FinalizacionAnticipadaAprobada == null;
    }

    bool FueFinalizadoAnticipadamente(DogGo.Models.Paseo paseo)
    {
        return paseo.Estado == "Finalizado"
            && paseo.FinalizacionAnticipadaAprobada == true
            && paseo.DuracionRealMinutos.HasValue
            && paseo.DuracionRealMinutos.Value < paseo.DuracionMinutos;
    }

    string PersonaContraria(DogGo.Models.Paseo paseo)
    {
        if (esDuenio && paseo.Paseador?.Usuario != null)
            return $"👤 Paseador: {paseo.Paseador.Usuario.Nombre} {paseo.Paseador.Usuario.Apellido}";

        if (esPaseador && paseo.Perro?.Dueño != null)
            return $"👤 Dueño: {paseo.Perro.Dueño.Nombre} {paseo.Perro.Dueño.Apellido}";

        return string.Empty;
    }
}

<div class="page-header-wrap">
    <div class="page-header-inner">
        <div class="page-eyebrow">Tu historial</div>
        <h1 class="page-title">@(esPaseador ? "Mis servicios" : "Mis paseos")</h1>
        <p class="page-sub">Revisa el estado de todos tus @(esPaseador ? "servicios" : "paseos"), activos e históricos.</p>

        @if (Model.Any())
        {
            <div class="header-stats">
                @if (enCurso.Any())
                {
                    <div class="hstat hstat-green">
                        <span class="hstat-num">@enCurso.Count</span>
                        <span class="hstat-lbl">En curso</span>
                    </div>
                }

                @if (pendientes.Any())
                {
                    <div class="hstat hstat-amber">
                        <span class="hstat-num">@pendientes.Count</span>
                        <span class="hstat-lbl">Pendiente@(pendientes.Count > 1 ? "s" : "")</span>
                    </div>
                }

                <div class="hstat hstat-muted">
                    <span class="hstat-num">@finalizados.Count</span>
                    <span class="hstat-lbl">Finalizado@(finalizados.Count != 1 ? "s" : "")</span>
                </div>

                @if (cancelados.Any())
                {
                    <div class="hstat hstat-red">
                        <span class="hstat-num">@cancelados.Count</span>
                        <span class="hstat-lbl">Cancelado@(cancelados.Count > 1 ? "s" : "")</span>
                    </div>
                }
            </div>
        }
    </div>
</div>

<div class="paseos-container">

    @if (Model.Any())
    {
        <div class="mis-paseos-dashboard">
            <div class="mp-kpi-card">
                <div class="mp-kpi-icon">🦮</div>
                <div>
                    <div class="mp-kpi-label">@(esPaseador ? "Servicios activos" : "Paseos activos")</div>
                    <div class="mp-kpi-value">@totalActivos</div>
                    <div class="mp-kpi-sub">Pendientes y en curso</div>
                </div>
            </div>

            <div class="mp-kpi-card">
                <div class="mp-kpi-icon">✅</div>
                <div>
                    <div class="mp-kpi-label">Finalizados</div>
                    <div class="mp-kpi-value">@totalFinalizados</div>
                    <div class="mp-kpi-sub">Historial completado</div>
                </div>
            </div>

            <div class="mp-kpi-card">
                <div class="mp-kpi-icon">💰</div>
                <div>
                    <div class="mp-kpi-label">@(esPaseador ? "Total ganado" : "Total gastado")</div>
                    <div class="mp-kpi-value">$@totalGastadoFinalizados.ToString("0.00")</div>
                    <div class="mp-kpi-sub">@(esPaseador ? "En servicios finalizados" : "Solo paseos finalizados")</div>
                </div>
            </div>

            <div class="mp-kpi-card @(solicitudesFinalizacion.Any() ? "mp-kpi-alert" : "")">
                <div class="mp-kpi-icon">⚠️</div>
                <div>
                    <div class="mp-kpi-label">Solicitudes</div>
                    <div class="mp-kpi-value">@solicitudesFinalizacion.Count</div>
                    <div class="mp-kpi-sub">Finalización anticipada</div>
                </div>
            </div>
        </div>

        @if (solicitudesFinalizacion.Any())
        {
            <div class="alert alert-warning shadow-sm border-warning mb-4">
                <strong>Atención:</strong>
                tienes @solicitudesFinalizacion.Count solicitud@(solicitudesFinalizacion.Count > 1 ? "es" : "")
                de finalización anticipada pendiente@(solicitudesFinalizacion.Count > 1 ? "s" : "").
                Abre el mapa del paseo para aceptar o rechazar.
            </div>
        }
    }

    <form asp-action="MisPaseos" method="get" class="filtros-card">
        <div class="filtros-grid">

            <div class="filtro-group">
                <label>Buscar</label>
                <input type="text"
                       name="busqueda"
                       value="@ViewBag.Busqueda"
                       placeholder="@(esPaseador ? "Perro o dueño" : "Perro o paseador")"
                       class="form-ctrl" />
            </div>

            <div class="filtro-group">
                <label>Estado</label>
                <select name="estado" class="form-ctrl form-sel">
                    <option value="">Todos</option>
                    <option value="Pendiente" selected="@(ViewBag.Estado == "Pendiente")">Pendiente</option>
                    <option value="EnCurso" selected="@(ViewBag.Estado == "EnCurso")">En curso</option>
                    <option value="Finalizado" selected="@(ViewBag.Estado == "Finalizado")">Finalizado</option>
                    <option value="Cancelado" selected="@(ViewBag.Estado == "Cancelado")">Cancelado</option>
                </select>
            </div>

            <div class="filtro-group">
                <label>Tipo</label>
                <select name="tipo" class="form-ctrl form-sel">
                    <option value="">Todos</option>
                    <option value="Ahora" selected="@(ViewBag.Tipo == "Ahora")">Ahora</option>
                    <option value="Programado" selected="@(ViewBag.Tipo == "Programado")">Programado</option>
                </select>
            </div>

            <div class="filtro-group">
                <label>Ordenar</label>
                <select name="orden" class="form-ctrl form-sel">
                    <option value="fecha_desc" selected="@(ViewBag.Orden == "fecha_desc")">Más recientes</option>
                    <option value="fecha_asc" selected="@(ViewBag.Orden == "fecha_asc")">Más antiguos</option>
                    <option value="precio_desc" selected="@(ViewBag.Orden == "precio_desc")">Mayor precio</option>
                    <option value="precio_asc" selected="@(ViewBag.Orden == "precio_asc")">Menor precio</option>
                </select>
            </div>

            <div class="filtros-actions">
                <button type="submit" class="btn-solicitar">Filtrar</button>
                <a asp-action="MisPaseos" class="btn-ver-perfil">Limpiar</a>
            </div>

        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">@(esPaseador ? "🦮" : "🐶")</div>
            <h3>@(esPaseador ? "No tienes servicios aún" : "No se encontraron paseos")</h3>
            <p>@(esPaseador ? "Cuando un dueño te contrate, aparecerá aquí." : "Intenta cambiar los filtros o limpiar la búsqueda.")</p>
            @if (!esPaseador)
            {
                <a asp-controller="Paseador" asp-action="Directorio" class="btn-primary-doggo" style="margin-top:.75rem;display:inline-block">
                    Buscar paseador
                </a>
            }
        </div>
    }
    else
    {
        @if (enCurso.Any())
        {
            <div class="seccion">
                <div class="seccion-header">
                    <span class="seccion-dot dot-green"></span>
                    <h2 class="seccion-titulo">En curso</h2>
                    <span class="seccion-count count-green">@enCurso.Count</span>
                </div>

                <div class="paseos-list">
                    @foreach (var p in enCurso)
                    {
                        var nombresPerros = ObtenerNombresPerros(p);
                        var imagenPerro = ObtenerImagenPerro(p);
                        var cantidadPerros = ObtenerCantidadPerros(p);
                        var mapsUrl = ObtenerUrlMaps(p);
                        var duracionReal = ObtenerDuracionReal(p);
                        var solicitudPendiente = TieneSolicitudFinalizacion(p);
                        var persona = PersonaContraria(p);

                        <div class="paseo-card card-green @(solicitudPendiente ? "card-alerta-finalizacion" : "")">
                            <div class="paseo-card-inner">
                                <a asp-action="Mapa" asp-route-id="@p.Id" class="paseo-link paseo-link-full">
                                    <div class="card-left">
                                        <div class="dog-photo-wrap">
                                            @if (!string.IsNullOrWhiteSpace(imagenPerro))
                                            {
                                                <img src="@imagenPerro" alt="Foto de @nombresPerros" class="dog-photo-img" />
                                            }
                                            else
                                            {
                                                <div class="dog-photo-placeholder">🐶</div>
                                            }
                                        </div>
                                    </div>

                                    <div class="card-center">
                                        <div class="paseo-top-row">
                                            <span class="paseo-id">Paseo #@p.Id</span>
                                            <span class="paseo-perro">🐶 @nombresPerros</span>

                                            @if (cantidadPerros > 1)
                                            {
                                                <span class="paseo-badge badge-teal">@cantidadPerros perros</span>
                                            }

                                            @if (p.EsProgramado)
                                            {
                                                <span class="paseo-badge badge-blue">Programado</span>
                                            }

                                            @if (solicitudPendiente)
                                            {
                                                <span class="paseo-badge badge-red">Finalización anticipada</span>
                                            }
                                        </div>

                                        <div class="paseo-meta">
                                            <span>📅 @(p.FechaInicio?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Sin inicio")</span>
                                            <span>⏱ Solicitado: @p.DuracionMinutos min</span>

                                            @if (duracionReal.HasValue)
                                            {
                                                <span>🕒 Actual: @duracionReal.Value min</span>
                                            }

                                            <span>💰 $@p.Precio.ToString("0.00")</span>

                                            @if (p.EsProgramado && p.FechaProgramada != null)
                                            {
                                                <span>🗓 @p.FechaProgramada?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                            }
                                        </div>

                                        <div class="paseo-extra">
                                            @if (!string.IsNullOrWhiteSpace(persona))
                                            {
                                                <span>@persona</span>
                                            }
                                        </div>

                                        @if (solicitudPendiente)
                                        {
                                            <div class="finalizacion-alerta-mini">
                                                <strong>⚠️ Solicitud pendiente:</strong>
                                                @(string.IsNullOrWhiteSpace(p.MotivoFinalizacionAnticipada)
                                                    ? "El paseador solicitó terminar antes de tiempo."
                                                    : p.MotivoFinalizacionAnticipada)
                                            </div>
                                        }

                                        @if (TieneDatosRecoleccion(p))
                                        {
                                            <div class="recoleccion-mini">
                                                <div class="recoleccion-mini-title">📍 Recolección</div>

                                                <div class="recoleccion-mini-lines">
                                                    @if (!string.IsNullOrWhiteSpace(p.DireccionRecogida))
                                                    {
                                                        <span><strong>Dirección:</strong> @p.DireccionRecogida</span>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(p.ZonaRecogida))
                                                    {
                                                        <span><strong>Zona:</strong> @p.ZonaRecogida</span>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(p.ReferenciasRecogida))
                                                    {
                                                        <span><strong>Referencias:</strong> @p.ReferenciasRecogida</span>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </a>

                                <div class="card-right card-right-stack">
                                    <span class="estado-badge estado-green">● En curso</span>

                                    @if (solicitudPendiente && esDuenio)
                                    {
                                        <a asp-action="Mapa"
                                               asp-route-id="@p.Id"
                                               class="btn-responder-finalizacion">
                                            Responder
                                        </a>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(mapsUrl))
                                    {
                                        <a href="@mapsUrl"
                                               target="_blank"
                                               rel="noopener noreferrer"
                                               class="btn-maps-mini">
                                            Abrir Maps
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (pendientes.Any())
        {
            <div class="seccion">
                <div class="seccion-header">
                    <span class="seccion-dot dot-amber"></span>
                    <h2 class="seccion-titulo">Pendientes</h2>
                    <span class="seccion-count count-amber">@pendientes.Count</span>
                </div>

                <div class="paseos-list">
                    @foreach (var p in pendientes)
                    {
                        var nombresPerros = ObtenerNombresPerros(p);
                        var imagenPerro = ObtenerImagenPerro(p);
                        var cantidadPerros = ObtenerCantidadPerros(p);
                        var mapsUrl = ObtenerUrlMaps(p);
                        var persona = PersonaContraria(p);

                        <div class="paseo-card card-amber">
                            <div class="paseo-card-inner">
                                <a asp-action="Mapa" asp-route-id="@p.Id" class="paseo-link paseo-link-full">
                                    <div class="card-left">
                                        <div class="dog-photo-wrap">
                                            @if (!string.IsNullOrWhiteSpace(imagenPerro))
                                            {
                                                <img src="@imagenPerro" alt="Foto de @nombresPerros" class="dog-photo-img" />
                                            }
                                            else
                                            {
                                                <div class="dog-photo-placeholder">🐶</div>
                                            }
                                        </div>
                                    </div>

                                    <div class="card-center">
                                        <div class="paseo-top-row">
                                            <span class="paseo-id">Paseo #@p.Id</span>
                                            <span class="paseo-perro">🐶 @nombresPerros</span>

                                            @if (cantidadPerros > 1)
                                            {
                                                <span class="paseo-badge badge-teal">@cantidadPerros perros</span>
                                            }

                                            @if (p.EsProgramado)
                                            {
                                                <span class="paseo-badge badge-blue">Programado</span>
                                            }
                                        </div>

                                        <div class="paseo-meta">
                                            @if (p.EsProgramado && p.FechaProgramada != null)
                                            {
                                                <span>🗓 @p.FechaProgramada?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                            }
                                            else
                                            {
                                                <span>📅 @(p.FechaInicio?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Pendiente")</span>
                                            }

                                            <span>⏱ @p.DuracionMinutos min</span>
                                            <span>💰 $@p.Precio.ToString("0.00")</span>
                                        </div>

                                        <div class="paseo-extra">
                                            @if (!string.IsNullOrWhiteSpace(persona))
                                            {
                                                <span>@persona</span>
                                            }
                                        </div>

                                        @if (TieneDatosRecoleccion(p))
                                        {
                                            <div class="recoleccion-mini">
                                                <div class="recoleccion-mini-title">📍 Recolección</div>

                                                <div class="recoleccion-mini-lines">
                                                    @if (!string.IsNullOrWhiteSpace(p.DireccionRecogida))
                                                    {
                                                        <span><strong>Dirección:</strong> @p.DireccionRecogida</span>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(p.ZonaRecogida))
                                                    {
                                                        <span><strong>Zona:</strong> @p.ZonaRecogida</span>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(p.ReferenciasRecogida))
                                                    {
                                                        <span><strong>Referencias:</strong> @p.ReferenciasRecogida</span>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </a>

                                <div class="card-right card-right-actions card-right-actions-wrap">
                                    <span class="estado-badge estado-amber">● Pendiente</span>

                                    @if (!string.IsNullOrWhiteSpace(mapsUrl))
                                    {
                                        <a href="@mapsUrl"
                                               target="_blank"
                                               rel="noopener noreferrer"
                                               class="btn-maps-mini">
                                            Abrir Maps
                                        </a>
                                    }

                                    <button class="btn-cancelar-toggle"
                                            onclick="toggleCancelar(@p.Id)"
                                            title="Cancelar paseo">
                                        ✕
                                    </button>
                                </div>
                            </div>

                            <div class="cancelar-panel" id="cancelar-@p.Id" style="display:none">
                                <form asp-action="Cancelar" asp-route-id="@p.Id" method="post" class="cancelar-form">
                                    @Html.AntiForgeryToken()
                                    <input type="text" name="motivo" class="form-ctrl" placeholder="Motivo de cancelación (opcional)" />

                                    <div class="cancelar-actions">
                                        <button type="button" class="btn-no-cancelar" onclick="toggleCancelar(@p.Id)">Volver</button>
                                        <button type="submit" class="btn-confirmar-cancelar"
                                                onclick="return confirm('¿Seguro que quieres cancelar este paseo?')">
                                            Confirmar cancelación
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (finalizados.Any())
        {
            <div class="seccion">
                <div class="seccion-header">
                    <span class="seccion-dot dot-muted"></span>
                    <h2 class="seccion-titulo">Finalizados</h2>
                    <span class="seccion-count count-muted">@finalizados.Count</span>
                </div>

                <div class="paseos-list">
                    @foreach (var p in finalizados)
                    {
                        var nombresPerros = ObtenerNombresPerros(p);
                        var imagenPerro = ObtenerImagenPerro(p);
                        var cantidadPerros = ObtenerCantidadPerros(p);
                        var mapsUrl = ObtenerUrlMaps(p);
                        var duracionReal = ObtenerDuracionReal(p);
                        var anticipado = FueFinalizadoAnticipadamente(p);
                        var persona = PersonaContraria(p);

                        <div class="paseo-card card-muted">
                            <div class="paseo-card-inner">
                                <a asp-action="Mapa" asp-route-id="@p.Id" class="paseo-link paseo-link-full">
                                    <div class="card-left">
                                        <div class="dog-photo-wrap">
                                            @if (!string.IsNullOrWhiteSpace(imagenPerro))
                                            {
                                                <img src="@imagenPerro" alt="Foto de @nombresPerros" class="dog-photo-img" />
                                            }
                                            else
                                            {
                                                <div class="dog-photo-placeholder">🐶</div>
                                            }
                                        </div>
                                    </div>

                                    <div class="card-center">
                                        <div class="paseo-top-row">
                                            <span class="paseo-id">Paseo #@p.Id</span>
                                            <span class="paseo-perro">🐶 @nombresPerros</span>

                                            @if (cantidadPerros > 1)
                                            {
                                                <span class="paseo-badge badge-teal">@cantidadPerros perros</span>
                                            }

                                            @if (p.EsProgramado)
                                            {
                                                <span class="paseo-badge badge-blue">Programado</span>
                                            }

                                            @if (anticipado)
                                            {
                                                <span class="paseo-badge badge-red">Anticipado</span>
                                            }
                                        </div>

                                        <div class="paseo-meta">
                                            <span>▶ @(p.FechaInicio?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Sin registro")</span>

                                            @if (p.FechaFin != null)
                                            {
                                                <span>⏹ @p.FechaFin?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                            }

                                            <span>⏱ Solicitado: @p.DuracionMinutos min</span>

                                            @if (duracionReal.HasValue)
                                            {
                                                <span>✅ Real: @duracionReal.Value min</span>
                                            }

                                            <span>💰 Final: $@p.Precio.ToString("0.00")</span>
                                        </div>

                                        <div class="paseo-extra">
                                            @if (!string.IsNullOrWhiteSpace(persona))
                                            {
                                                <span>@persona</span>
                                            }
                                        </div>

                                        @if (anticipado)
                                        {
                                            <div class="finalizacion-alerta-mini finalizacion-finalizada">
                                                <strong>Finalización anticipada aprobada.</strong>
                                                @(string.IsNullOrWhiteSpace(p.MotivoFinalizacionAnticipada)
                                                    ? ""
                                                    : $"Motivo: {p.MotivoFinalizacionAnticipada}")
                                            </div>
                                        }

                                        @if (TieneDatosRecoleccion(p))
                                        {
                                            <div class="recoleccion-mini">
                                                <div class="recoleccion-mini-title">📍 Recolección</div>

                                                <div class="recoleccion-mini-lines">
                                                    @if (!string.IsNullOrWhiteSpace(p.DireccionRecogida))
                                                    {
                                                        <span><strong>Dirección:</strong> @p.DireccionRecogida</span>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(p.ZonaRecogida))
                                                    {
                                                        <span><strong>Zona:</strong> @p.ZonaRecogida</span>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(p.ReferenciasRecogida))
                                                    {
                                                        <span><strong>Referencias:</strong> @p.ReferenciasRecogida</span>
                                                    }
                                                </div>
                                            </div>
                                        }

                                        @if (p.Calificacion != null)
                                        {
                                            <div class="calificacion-inline">
                                                <span class="cal-stars">
                                                    @for (int i = 1; i <= 5; i++)
                                                    {
                                                        <span class="@(i <= p.Calificacion.Puntaje ? "star-on" : "star-off")">★</span>
                                                    }
                                                </span>

                                                @if (!string.IsNullOrWhiteSpace(p.Calificacion.Comentario))
                                                {
                                                    <span class="cal-texto">"@p.Calificacion.Comentario"</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                </a>

                                <div class="card-right card-right-stack">
                                    <span class="estado-badge estado-muted">● Finalizado</span>

                                    @if (!string.IsNullOrWhiteSpace(mapsUrl))
                                    {
                                        <a href="@mapsUrl"
                                               target="_blank"
                                               rel="noopener noreferrer"
                                               class="btn-maps-mini">
                                            Abrir Maps
                                        </a>
                                    }

                                    @if (p.Calificacion == null && User.IsInRole("Duenio"))
                                    {
                                        <a asp-controller="Calificacion"
                                               asp-action="Crear"
                                               asp-route-paseoId="@p.Id"
                                               class="btn-calificar">
                                            ⭐ Calificar
                                        </a>
                                    }
                                    else if (p.Calificacion != null)
                                    {
                                        <span class="ya-calificado">✓ Calificado</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        @if (cancelados.Any())
        {
            <div class="seccion">
                <div class="seccion-header">
                    <span class="seccion-dot dot-red"></span>
                    <h2 class="seccion-titulo">Cancelados</h2>
                    <span class="seccion-count count-red">@cancelados.Count</span>
                </div>

                <div class="paseos-list">
                    @foreach (var p in cancelados)
                    {
                        var nombresPerros = ObtenerNombresPerros(p);
                        var imagenPerro = ObtenerImagenPerro(p);
                        var cantidadPerros = ObtenerCantidadPerros(p);
                        var fotoCancelador = p.CanceladoPor == "Paseador" ? p.Paseador?.FotoUrl : null;
                        var mapsUrl = ObtenerUrlMaps(p);
                        var persona = PersonaContraria(p);

                        <div class="paseo-card card-red">
                            <div class="paseo-card-inner">
                                <a asp-action="Mapa" asp-route-id="@p.Id" class="paseo-link paseo-link-full">
                                    <div class="card-left">
                                        <div class="dog-photo-wrap">
                                            @if (!string.IsNullOrWhiteSpace(imagenPerro))
                                            {
                                                <img src="@imagenPerro" alt="Foto de @nombresPerros" class="dog-photo-img" />
                                            }
                                            else
                                            {
                                                <div class="dog-photo-placeholder">🐶</div>
                                            }
                                        </div>
                                    </div>

                                    <div class="card-center">
                                        <div class="paseo-top-row">
                                            <span class="paseo-id">Paseo #@p.Id</span>
                                            <span class="paseo-perro">🐶 @nombresPerros</span>

                                            @if (cantidadPerros > 1)
                                            {
                                                <span class="paseo-badge badge-teal">@cantidadPerros perros</span>
                                            }

                                            @if (p.EsProgramado)
                                            {
                                                <span class="paseo-badge badge-blue">Programado</span>
                                            }
                                        </div>

                                        <div class="paseo-meta">
                                            <span>📅 @(p.FechaInicio?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "Sin registro")</span>
                                            <span>⏱ @p.DuracionMinutos min</span>
                                            <span>💰 $@p.Precio.ToString("0.00")</span>
                                        </div>

                                        <div class="paseo-extra">
                                            @if (!string.IsNullOrWhiteSpace(persona))
                                            {
                                                <span>@persona</span>
                                            }
                                        </div>

                                        @if (TieneDatosRecoleccion(p))
                                        {
                                            <div class="recoleccion-mini">
                                                <div class="recoleccion-mini-title">📍 Recolección</div>

                                                <div class="recoleccion-mini-lines">
                                                    @if (!string.IsNullOrWhiteSpace(p.DireccionRecogida))
                                                    {
                                                        <span><strong>Dirección:</strong> @p.DireccionRecogida</span>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(p.ZonaRecogida))
                                                    {
                                                        <span><strong>Zona:</strong> @p.ZonaRecogida</span>
                                                    }

                                                    @if (!string.IsNullOrWhiteSpace(p.ReferenciasRecogida))
                                                    {
                                                        <span><strong>Referencias:</strong> @p.ReferenciasRecogida</span>
                                                    }
                                                </div>
                                            </div>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(p.CanceladoPor) || !string.IsNullOrWhiteSpace(p.MotivoCancelacion))
                                        {
                                            <div class="cancelacion-info">
                                                <div class="cancelador-avatar-wrap">
                                                    @if (!string.IsNullOrWhiteSpace(fotoCancelador))
                                                    {
                                                        <img src="@fotoCancelador" alt="Foto de quien canceló" class="cancelador-avatar-img" />
                                                    }
                                                    else
                                                    {
                                                        <div class="cancelador-avatar-placeholder">👤</div>
                                                    }
                                                </div>

                                                <div class="cancelacion-texto">
                                                    <div class="cancelacion-linea">
                                                        @{
                                                            var canceladoPorTexto = p.CanceladoPor == "Duenio" ? "Dueño" : p.CanceladoPor;
                                                        }

                                                        @if (!string.IsNullOrWhiteSpace(p.CanceladoPor))
                                                        {
                                                            <span>👤 Cancelado por: @canceladoPorTexto</span>
                                                        }

                                                        @if (p.FechaCancelacion != null)
                                                        {
                                                            <span>🗓 @p.FechaCancelacion?.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                                                        }
                                                    </div>

                                                    @if (!string.IsNullOrWhiteSpace(p.MotivoCancelacion))
                                                    {
                                                        <div class="cancelacion-linea">
                                                            <span>💬 @p.MotivoCancelacion</span>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </a>

                                <div class="card-right card-right-stack">
                                    <span class="estado-badge estado-red">● Cancelado</span>

                                    @if (!string.IsNullOrWhiteSpace(mapsUrl))
                                    {
                                        <a href="@mapsUrl"
                                               target="_blank"
                                               rel="noopener noreferrer"
                                               class="btn-maps-mini">
                                            Abrir Maps
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/css/paseo.css")" />

    <style>
        .mis-paseos-dashboard {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: .9rem;
            margin-bottom: 1.25rem;
        }

        .mp-kpi-card {
            background: #fff;
            border: 1.5px solid var(--border);
            border-radius: 20px;
            padding: 1rem;
            display: flex;
            align-items: center;
            gap: .85rem;
            box-shadow: 0 4px 16px rgba(45,49,66,.06);
        }

        .mp-kpi-alert {
            background: #fff7ed;
            border-color: #f59e0b;
        }

        .mp-kpi-icon {
            width: 44px;
            height: 44px;
            border-radius: 16px;
            background: var(--warm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.35rem;
            flex-shrink: 0;
        }

        .mp-kpi-label {
            font-size: .74rem;
            font-weight: 900;
            color: var(--muted);
            text-transform: uppercase;
            letter-spacing: .04em;
        }

        .mp-kpi-value {
            font-size: 1.35rem;
            font-weight: 900;
            color: var(--text);
            line-height: 1.1;
        }

        .mp-kpi-sub {
            font-size: .78rem;
            font-weight: 700;
            color: var(--muted);
            margin-top: .1rem;
        }

        .badge-red {
            background: #fee2e2;
            color: #dc2626;
            border: 1px solid #fca5a5;
        }

        .card-alerta-finalizacion {
            border-color: #f59e0b !important;
            box-shadow: 0 8px 24px rgba(245, 158, 11, .16);
        }

        .finalizacion-alerta-mini {
            margin-top: .75rem;
            padding: .7rem .85rem;
            border-radius: 14px;
            background: #fff7ed;
            border: 1.5px solid #f59e0b;
            color: #92400e;
            font-size: .82rem;
            font-weight: 700;
        }

        .finalizacion-finalizada {
            background: #f8fafc;
            border-color: #cbd5e1;
            color: #475569;
        }

        .btn-responder-finalizacion {
            display: inline-flex;
            justify-content: center;
            align-items: center;
            border-radius: 999px;
            padding: .38rem .75rem;
            font-size: .76rem;
            font-weight: 900;
            background: #f59e0b;
            color: #fff;
            text-decoration: none;
            border: none;
            white-space: nowrap;
        }

            .btn-responder-finalizacion:hover {
                color: #fff;
                background: #d97706;
            }

        @@media (max-width: 980px) {
            .mis-paseos-dashboard {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 560px) {
            .mis-paseos-dashboard {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

@section Scripts {
    <script src="@Url.Content("~/js/paseo.js")"></script>
}