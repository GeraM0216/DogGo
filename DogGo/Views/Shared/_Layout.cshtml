<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — DogGo</title>

    <!-- Bootstrap -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="@Url.Content("~/css/site.css")" />

    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    <!-- ── Navbar ─────────────────────────────────────────────── -->
    <nav class="navbar navbar-expand-md navbar-doggo sticky-top px-3">
        <div class="container-fluid">

            <!-- Logo -->
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                🐾 DogGo
            </a>

            <!-- Hamburguesa mobile -->
            <button class="navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">

                <!-- Links izquierda -->
                <ul class="navbar-nav me-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Paseador" asp-action="Directorio">
                            Paseadores
                        </a>
                    </li>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Paseo" asp-action="MisPaseos">
                                Mis paseos
                            </a>
                        </li>

                        @if (User.IsInRole("Paseador"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Paseador" asp-action="Perfil">
                                    Mi perfil
                                </a>
                            </li>
                        }

                        @if (User.IsInRole("Duenio"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Perro" asp-action="Index">
                                    Mis perros
                                </a>
                            </li>
                        }
                    }
                </ul>

                <!-- Links derecha -->
                <ul class="navbar-nav gap-1 align-items-center">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <span class="nav-link pe-none d-flex align-items-center gap-2 nav-user-info">
                                @{
                                    var nombre = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value;
                                    var rol = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                                    var rolMostrado = rol == "Duenio" ? "Cliente" :
                                                      rol == "Paseador" ? "Paseador" : rol;
                                }
                                <span>👤 @nombre</span>
                                <span class="badge-rol">@rolMostrado</span>
                            </span>
                        </li>

                        <li class="nav-item">
                            <form asp-controller="Auth" asp-action="Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-logout">
                                    Cerrar sesión
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Auth" asp-action="Login">
                                Iniciar sesión
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-pill-btn" asp-controller="Auth" asp-action="Register">
                                Registrarse
                            </a>
                        </li>
                    }
                </ul>

            </div>
        </div>
    </nav>

    <!-- ── TempData alerts ────────────────────────────────────── -->
    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible tempdata-alert" role="alert">
            ✅ @TempData["Exito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible tempdata-alert" role="alert">
            ❌ @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- ── Contenido principal ────────────────────────────────── -->
    <main>
        @RenderBody()
    </main>

    <!-- ── Footer ─────────────────────────────────────────────── -->
    <footer class="footer-doggo">
        <div class="footer-logo">🐾 DogGo</div>
        <div>DogGo &copy; @DateTime.Now.Year — Proyecto universitario</div>
    </footer>

    <!-- ── Scripts ────────────────────────────────────────────── -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>

    <script>
        document.querySelectorAll(".tempdata-alert").forEach(alert => {
        setTimeout(() => {
        const bsAlert = bootstrap.Alert.getOrCreateInstance(alert);
        bsAlert.close();
        }, 4000);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
