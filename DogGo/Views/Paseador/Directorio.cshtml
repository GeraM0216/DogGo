@model List<DogGo.Models.Paseador>
@using DogGo.Models
@using System.Globalization

@{
    ViewData["Title"] = "Paseadores disponibles";
}

<!-- ── Page Header ── -->
<div class="page-header-wrap">
    <div class="page-header-inner">
        <div class="page-eyebrow">Encuentra tu paseador</div>
        <h1 class="page-title">Paseadores disponibles</h1>
        <p class="page-sub">Elige al paseador ideal para tu mascota — todos verificados y calificados.</p>
    </div>
</div>

<!-- ── Contenido ── -->
<div class="dir-container">

    <!-- ── Filtros y búsqueda ── -->
    <form asp-action="Directorio" method="get" class="filtros-card">
        <div class="filtros-grid">

            <div class="filtro-group">
                <label>Buscar</label>
                <input type="text"
                       name="busqueda"
                       value="@ViewBag.Busqueda"
                       placeholder="Nombre o descripción"
                       class="form-ctrl" />
            </div>

            <div class="filtro-group">
                <label>Zona</label>
                <select name="zona" class="form-ctrl form-sel">
                    <option value="">Todas las zonas</option>
                    <option value="Centro" selected="@(ViewBag.Zona == "Centro")">Centro</option>
                    <option value="Cumbres" selected="@(ViewBag.Zona == "Cumbres")">Cumbres</option>
                    <option value="San Pedro" selected="@(ViewBag.Zona == "San Pedro")">San Pedro</option>
                    <option value="San Nicolás" selected="@(ViewBag.Zona == "San Nicolás")">San Nicolás</option>
                    <option value="Guadalupe" selected="@(ViewBag.Zona == "Guadalupe")">Guadalupe</option>
                    <option value="Apodaca" selected="@(ViewBag.Zona == "Apodaca")">Apodaca</option>
                    <option value="Santa Catarina" selected="@(ViewBag.Zona == "Santa Catarina")">Santa Catarina</option>
                    <option value="Escobedo" selected="@(ViewBag.Zona == "Escobedo")">Escobedo</option>
                </select>
            </div>

            <div class="filtro-group">
                <label>Experiencia mínima</label>
                <input type="number"
                       name="experienciaMinima"
                       value="@ViewBag.ExperienciaMinima"
                       min="0"
                       placeholder="Años"
                       class="form-ctrl" />
            </div>

            <div class="filtro-group">
                <label>Tarifa máxima</label>
                <input type="number"
                       name="tarifaMaxima"
                       value="@ViewBag.TarifaMaxima"
                       min="0"
                       step="0.01"
                       placeholder="Precio máximo"
                       class="form-ctrl" />
            </div>

            <div class="filtro-group">
                <label>Ordenar por</label>
                <select name="orden" class="form-ctrl form-sel">
                    <option value="calificacion_desc" selected="@(ViewBag.Orden == "calificacion_desc")">
                        Mejor calificación
                    </option>
                    <option value="tarifa_asc" selected="@(ViewBag.Orden == "tarifa_asc")">
                        Menor tarifa
                    </option>
                    <option value="tarifa_desc" selected="@(ViewBag.Orden == "tarifa_desc")">
                        Mayor tarifa
                    </option>
                    <option value="experiencia_desc" selected="@(ViewBag.Orden == "experiencia_desc")">
                        Más experiencia
                    </option>
                </select>
            </div>

            <div class="filtros-actions">
                <button type="submit" class="btn-solicitar">Buscar</button>
                <a asp-action="Directorio" class="btn-ver-perfil">Limpiar</a>
            </div>

        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">🐾</div>
            <h3>No se encontraron paseadores</h3>
            <p>Intenta cambiar los filtros o limpiar la búsqueda.</p>
        </div>
    }
    else
    {
        <div class="dir-grid">
            @foreach (var p in Model)
            {
                var nombrePaseador = $"{p.Usuario.Nombre} {p.Usuario.Apellido}";
                var nombrePaseadorJs = nombrePaseador.Replace("\\", "\\\\").Replace("'", "\\'");
                var tarifaJs = p.TarifaPorHora.ToString(CultureInfo.InvariantCulture);

                <div class="paseador-card">

                    <!-- Top: avatar + nombre + estrellas -->
                    <div class="pc-top">
                        <div class="pc-avatar">
                            @if (!string.IsNullOrWhiteSpace(p.FotoUrl))
                            {
                                <img src="@p.FotoUrl" alt="@p.Usuario.Nombre" />
                            }
                            else
                            {
                                <span>🐾</span>
                            }
                        </div>

                        <div class="pc-info">
                            <div class="pc-name">@p.Usuario.Nombre @p.Usuario.Apellido</div>
                            <div class="pc-tarifa">$@p.TarifaPorHora / hora</div>
                        </div>

                        <div class="pc-stars-wrap">
                            <div class="pc-stars">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span class="@(i <= Math.Round((double)p.CalificacionPromedio) ? "star-on" : "star-off")">★</span>
                                }
                            </div>
                            <div class="pc-stars-num">@p.CalificacionPromedio.ToString("0.0")</div>
                        </div>
                    </div>

                    <!-- Descripción -->
                    @if (!string.IsNullOrEmpty(p.Descripcion))
                    {
                        <p class="pc-desc">@p.Descripcion</p>
                    }

                    <!-- Tags: zonas + disponibilidad -->
                    <div class="pc-tags">
                        @if (!string.IsNullOrWhiteSpace(p.ZonaServicio))
                        {
                            @foreach (var zonaItem in p.ZonaServicio.Split(',').Take(2))
                            {
                                <span class="pc-tag">@zonaItem.Trim()</span>
                            }
                        }

                        @if (p.ExperienciaAnios != null)
                        {
                            <span class="pc-tag-amber">@p.ExperienciaAnios año(s) exp.</span>
                        }

                        <span class="pc-disp @(p.Disponible ? "disp-si" : "disp-no")">
                            ● @(p.Disponible ? "Disponible" : "No disponible")
                        </span>
                    </div>

                    <!-- Acciones -->
                    <div class="pc-actions">
                        <a asp-action="Perfil" asp-route-id="@p.Id" class="btn-ver-perfil">
                            Ver perfil
                        </a>

                        @if (User.IsInRole("Duenio"))
                        {
                            var perros = ViewBag.Perros as List<Perro>;

                            if (perros != null && perros.Any())
                            {
                                <button type="button"
                                        class="btn-solicitar"
                                        onclick="abrirModal(@p.Id, '@nombrePaseadorJs', '@tarifaJs')"
                                    @(p.Disponible ? "" : "disabled")>
                                    Solicitar paseo
                                </button>
                            }
                            else
                            {
                                <a asp-controller="Perro" asp-action="Create" class="btn-solicitar btn-solicitar-warn">
                                    Registra un perro primero
                                </a>
                            }
                        }
                    </div>

                </div>
            }
        </div>
    }
</div>

<!-- ── Modal solicitar paseo ── -->
@if (User.IsInRole("Duenio"))
{
    var perros = ViewBag.Perros as List<Perro>;
    var duenioPerfil = ViewBag.DuenioPerfil as DuenioPerfil;

    if (perros != null && perros.Any())
    {
        <div id="modal-overlay" class="modal-overlay" style="display:none" onclick="cerrarModalFuera(event)">
            <div class="modal-box">
                <div class="modal-header">
                    <div>
                        <div class="modal-title">Solicitar paseo 🦮</div>
                        <div class="modal-sub" id="modal-sub">Cargando...</div>
                    </div>
                    <button type="button" class="modal-close" onclick="cerrarModal()">✕</button>
                </div>

                <form asp-controller="Paseo" asp-action="Crear" method="post" id="modal-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="paseadorId" id="modal-paseador-id" />

                    <div class="form-group">
                        <label class="form-lbl">Tus perros</label>
                        <div class="form-help">Selecciona uno o varios perros para este paseo.</div>

                        <div class="perros-select-grid">
                            @foreach (var perro in perros)
                            {
                                <label class="perro-option">
                                    <input type="checkbox" name="perroIds" value="@perro.Id" class="perro-check" />

                                    <div class="perro-option-body">
                                        <div class="perro-option-avatar">
                                            @if (!string.IsNullOrWhiteSpace(perro.ImagenUrl))
                                            {
                                                <img src="@perro.ImagenUrl" alt="@perro.Nombre" />
                                            }
                                            else
                                            {
                                                <span>🐶</span>
                                            }
                                        </div>

                                        <div class="perro-option-info">
                                            <div class="perro-option-name">@perro.Nombre</div>
                                            <div class="perro-option-meta">
                                                @(string.IsNullOrWhiteSpace(perro.Raza) ? "Sin raza registrada" : perro.Raza)

                                                @if (!string.IsNullOrWhiteSpace(perro.Tamaño))
                                                {
                                                    <span>· @perro.Tamaño</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </label>
                            }
                        </div>

                        <div id="perros-seleccionados" class="perros-seleccionados">
                            Ningún perro seleccionado.
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-lbl">Precio ($)</label>
                        <input type="number"
                               name="precio"
                               id="modal-precio"
                               class="form-ctrl"
                               step="0.01"
                               min="0"
                               required />
                    </div>

                    <div class="form-group">
                        <label class="form-lbl">Duración del paseo</label>
                        <select name="duracionMinutos" class="form-ctrl form-sel" required>
                            <option value="">Selecciona duración</option>
                            <option value="30">30 minutos</option>
                            <option value="60">60 minutos</option>
                            <option value="90">90 minutos</option>
                            <option value="120">120 minutos</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-lbl">Tipo de paseo</label>

                        <div class="tipo-row">
                            <label class="tipo-pill">
                                <input type="radio" name="esProgramado" value="false" checked class="tipo-radio" />
                                <span>Paseo ahora</span>
                            </label>

                            <label class="tipo-pill">
                                <input type="radio" name="esProgramado" value="true" class="tipo-radio" />
                                <span>Programar paseo</span>
                            </label>
                        </div>
                    </div>

                    <div class="form-group" id="fecha-wrap" style="display:none">
                        <label class="form-lbl">Fecha y hora</label>
                        <input type="datetime-local"
                               name="fechaProgramada"
                               id="input-fecha"
                               class="form-ctrl" />
                    </div>

                    <!-- ── Ubicación de recolección ── -->
                    <div class="form-group">
                        <label class="form-lbl">Dirección de recolección</label>
                        <input type="text"
                               name="direccionRecogida"
                               id="direccion-recogida"
                               class="form-ctrl"
                               placeholder="Ej. Av. Leones 123, Cumbres"
                               required />
                    </div>

                    <div class="form-group">
                        <label class="form-lbl">Referencias</label>
                        <input type="text"
                               name="referenciasRecogida"
                               id="referencias-recogida"
                               class="form-ctrl"
                               placeholder="Ej. Portón negro, casa de dos pisos" />
                    </div>

                    <div class="form-group">
                        <label class="form-lbl">Zona de recolección</label>
                        <select name="zonaRecogida" id="zona-recogida" class="form-ctrl form-sel" required>
                            <option value="">Selecciona zona</option>
                            <option value="Centro">Centro</option>
                            <option value="Cumbres">Cumbres</option>
                            <option value="San Pedro">San Pedro</option>
                            <option value="San Nicolás">San Nicolás</option>
                            <option value="Guadalupe">Guadalupe</option>
                            <option value="Apodaca">Apodaca</option>
                            <option value="Santa Catarina">Santa Catarina</option>
                            <option value="Escobedo">Escobedo</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label class="form-lbl">Punto de recolección en el mapa</label>
                        <div class="form-help">
                            Marca el punto exacto donde el paseador debe realizar la recolección del perro.
                        </div>

                        @if (duenioPerfil != null &&
                             !string.IsNullOrWhiteSpace(duenioPerfil.Direccion) &&
                             !string.IsNullOrWhiteSpace(duenioPerfil.Zona) &&
                             duenioPerfil.Latitud.HasValue &&
                             duenioPerfil.Longitud.HasValue)
                        {
                            <button type="button"
                                    class="btn-ubicacion-predeterminada"
                                    data-direccion="@duenioPerfil.Direccion"
                                    data-referencias="@duenioPerfil.ReferenciasDireccion"
                                    data-zona="@duenioPerfil.Zona"
                                    data-lat="@duenioPerfil.Latitud.Value.ToString(CultureInfo.InvariantCulture)"
                                    data-lng="@duenioPerfil.Longitud.Value.ToString(CultureInfo.InvariantCulture)"
                                    onclick="usarUbicacionPredeterminada(this)">
                                Usar mi ubicación predeterminada
                            </button>
                        }
                        else
                        {
                            <a asp-controller="DuenioPerfil"
                                   asp-action="Editar"
                                   class="btn-ubicacion-predeterminada btn-ubicacion-warn">
                                Completar ubicación predeterminada
                            </a>
                        }

                        <button type="button" class="btn-ubicacion-actual" onclick="usarUbicacionActual()">
                            Usar mi ubicación actual
                        </button>

                        <div id="mapa-recogida" class="mapa-recogida"></div>

                        <div id="texto-ubicacion-recogida" class="texto-ubicacion-recogida">
                            Todavía no has marcado el punto de recolección.
                        </div>

                        <input type="hidden" name="latitudRecogida" id="latitud-recogida" />
                        <input type="hidden" name="longitudRecogida" id="longitud-recogida" />
                    </div>

                    <div class="modal-actions">
                        <button type="button" class="btn-modal-cancel" onclick="cerrarModal()">Cancelar</button>
                        <button type="submit" class="btn-modal-confirm">Confirmar solicitud</button>
                    </div>
                </form>
            </div>
        </div>
    }
}

@section Styles {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="@Url.Content("~/css/paseador.css")" />
}

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="@Url.Content("~/js/paseador.js")"></script>
}