@{
    ViewData["Title"] = "Recuperar contraseña";
    Layout = null;
}

<div class="login-container">

    <div class="login-left">
        <h1>DogGo 🐶</h1>
        <p>Recupera el acceso a tu cuenta de forma segura</p>
    </div>

    <div class="login-right">
        <div class="login-card">

            <h2>¿Olvidaste tu contraseña?</h2>
            <p>Ingresa tu correo y te enviaremos un código de recuperación</p>

            @if (ViewBag.Error != null)
            {
                <div class="error-box">@ViewBag.Error</div>
            }

            <form asp-action="ForgotPassword" method="post">
                @Html.AntiForgeryToken()

                <input type="email" name="email" placeholder="Correo electrónico" required />

                <button type="submit">Enviar código</button>
            </form>

            <p class="register">
                <a asp-action="Login">Volver al inicio de sesión</a>
            </p>

        </div>
    </div>

</div>

<style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
    }

    .login-container {
        display: flex;
        height: 100vh;
        width: 100%;
    }

    /* IZQUIERDA */
    .login-left {
        width: 35%;
        max-width: 400px;
        backdrop-filter: blur(10px);
        background: linear-gradient(135deg, #4f46e5cc, #6366f1cc);
        color: white;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 60px;
        position: relative;
    }

        .login-left::before {
            content: "";
            position: absolute;
            width: 300px;
            height: 300px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
            top: -50px;
            left: -50px;
        }

        .login-left p {
            opacity: 0.85;
            font-size: 18px;
            line-height: 1.5;
            max-width: 300px;
        }

        .login-left h1 {
            font-size: 56px;
            font-weight: bold;
            margin-bottom: 10px;
        }

    /* DERECHA */
    .login-right {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        background: url('/images/parque-ecologico.jpg') center/cover no-repeat;
        position: relative;
    }

        .login-right::before {
            content: "";
            position: absolute;
            inset: 0;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            background: rgba(0,0,0,0.2);
        }

    .login-card {
        width: 340px;
        padding: 30px;
        border-radius: 20px;
        backdrop-filter: blur(20px);
        background: rgba(255, 255, 255, 0.25);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.4);
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        position: relative;
        z-index: 2;
    }

        .login-card input {
            width: 100%;
            padding: 12px;
            margin-bottom: 12px;
            border-radius: 10px;
            background: rgba(255,255,255,0.6);
            border: 1px solid rgba(255,255,255,0.4);
            outline: none;
            box-sizing: border-box;
        }

            .login-card input:focus {
                background: rgba(255,255,255,0.8);
                border: 1px solid #6366f1;
            }

        .login-card h2 {
            color: #111;
            margin-bottom: 8px;
        }

        .login-card p {
            color: rgba(0,0,0,0.7);
        }

        .login-card button {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #4f46e5, #6366f1);
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: bold;
            cursor: pointer;
        }

            .login-card button:hover {
                background: #4338ca;
            }

    .register {
        text-align: center;
        margin-top: 14px;
    }

        .register a {
            color: #3730a3;
            text-decoration: none;
            font-weight: 500;
        }

            .register a:hover {
                text-decoration: underline;
            }

    .error-box {
        background: rgba(220, 38, 38, 0.12);
        border: 1px solid rgba(220, 38, 38, 0.25);
        color: #991b1b;
        padding: 12px;
        border-radius: 10px;
        margin-bottom: 14px;
    }
</style>