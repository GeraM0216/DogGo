@model DogGo.Controllers.ConfirmacionAuxiliar
@{
    ViewData["Title"] = "Verificar Cuenta";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5 text-center">
                    <h2 class="fw-bold mb-4">Verifica tu cuenta 🐾</h2>
                    <p class="text-muted">Ingresa el código enviado a <strong>@Model.Email</strong></p>
                    
                    <form asp-controller="Auth" asp-action="ConfirmarEmail" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Email" />
                        
                        <div class="form-group mb-4">
                            <label class="form-label">Código de 6 dígitos</label>
                            <input asp-for="Codigo" class="form-control form-control-lg text-center fw-bold" 
                                   placeholder="000000" maxlength="6" style="letter-spacing: 8px;" required />
                            <span asp-validation-for="Codigo" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm">
                            Confirmar Registro
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>