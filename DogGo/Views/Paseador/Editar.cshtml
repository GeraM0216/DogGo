@model DogGo.Models.Paseador
@{
    ViewData["Title"] = "Editar perfil";
    var zonasSeleccionadas = string.IsNullOrWhiteSpace(Model.ZonaServicio)
        ? new List<string>()
        : Model.ZonaServicio.Split(',').Select(z => z.Trim()).ToList();
    var zonasDisponibles = new List<string>
    {
        "Centro", "Cumbres", "San Nicolás", "Guadalupe",
        "Apodaca", "Escobedo", "Contry", "Sur de Monterrey"
    };
}

<div class="editar-wrap">
    <div class="editar-card">

        <!-- Header -->
        <div class="editar-header">
            <div class="page-eyebrow">✏️ Mi perfil</div>
            <h1 class="editar-title">Editar mi perfil</h1>
            <p class="editar-sub">Completa tu perfil para que los dueños te conozcan mejor.</p>
        </div>

        <form asp-action="Editar" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <!-- Foto -->
            <div class="form-section">
                <div class="form-section-title">Foto de perfil</div>
                @if (!string.IsNullOrWhiteSpace(Model.FotoUrl))
                {
                    <img src="@Model.FotoUrl" alt="Foto actual" class="foto-preview-img" />
                }
                else
                {
                    <div class="foto-placeholder">🐾</div>
                }
                <label class="file-upload-btn">
                    📷 Cambiar foto
                    <input type="file" name="fotoArchivo" accept="image/*" style="display:none"
                           onchange="previewFoto(this)" />
                </label>
            </div>

            <!-- Zona de servicio -->
            <div class="form-section">
                <div class="form-section-title">Zona de servicio</div>
                <div class="zonas-grid">
                    @foreach (var zona in zonasDisponibles)
                    {
                        var marcada = zonasSeleccionadas.Contains(zona);
                        <label class="zona-item">
                            <input class="zona-check" type="checkbox"
                                   value="@zona"
                                   id="zona_@zona.Replace(" ", "_")"
                                   @(marcada ? "checked" : null) />
                            <span class="zona-check-custom"></span>
                            @zona
                        </label>
                    }
                </div>
                <input type="hidden" name="zonaServicio" id="zonaServicio" value="@Model.ZonaServicio" />
            </div>

            <!-- Experiencia -->
            <div class="form-group">
                <label class="form-lbl" for="ExperienciaAnios">Años de experiencia</label>
                <input asp-for="ExperienciaAnios" type="number" class="form-ctrl"
                       min="0" placeholder="Ej. 2" />
            </div>

            <!-- Descripción -->
            <div class="form-group">
                <label class="form-lbl">Descripción</label>
                <textarea asp-for="Descripcion" class="form-ctrl form-ta" rows="4"
                          placeholder="Cuéntales a los dueños sobre ti, tu experiencia y cómo cuidas a los perritos..."></textarea>
            </div>

            <!-- Tarifa -->
            <div class="form-group">
                <label class="form-lbl" asp-for="TarifaPorHora">Tarifa por hora ($)</label>
                <input asp-for="TarifaPorHora" type="number" step="0.01"
                       class="form-ctrl" min="0" />
            </div>

            <!-- Disponibilidad -->
            <div class="disponible-wrap">
                <div>
                    <div class="disponible-label">Disponible para paseos</div>
                    <div class="disponible-sub">Los dueños podrán solicitarte paseos</div>
                </div>
                <label class="toggle-wrap">
                    <input asp-for="Disponible" type="checkbox" class="toggle-input" />
                    <span class="toggle-track"></span>
                </label>
            </div>

            <!-- Acciones -->
            <div class="editar-actions">
                <button type="submit" class="btn-save">Guardar cambios</button>
                <a asp-action="Perfil" class="btn-cancel">Cancelar</a>
            </div>

        </form>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/css/paseador.css")" />
}

@section Scripts {
    <script src="@Url.Content("~/js/paseador.js")"></script>
}