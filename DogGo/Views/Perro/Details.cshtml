@model DogGo.Models.Perro
@{
    ViewData["Title"] = "Perfil de " + Model.Nombre;
}

<div class="details-wrap">

    <!-- ── Hero card ── -->
    <div class="details-hero">

        <!-- Foto -->
        <div class="details-foto-wrap">
            @if (!string.IsNullOrEmpty(Model.ImagenUrl))
            {
                <img src="@Model.ImagenUrl" alt="@Model.Nombre" class="details-foto" />
            }
            else
            {
                <div class="details-foto-placeholder">🐶</div>
            }
        </div>

        <!-- Info -->
        <div class="details-info">
            <div class="details-top-row">
                <div>
                    <div class="page-eyebrow">🐾 Perfil de mascota</div>
                    <h1 class="details-nombre">@Model.Nombre</h1>
                </div>
                <div class="details-actions-top">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-edit-top">✏️ Editar</a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-delete-top">🗑</a>
                </div>
            </div>

            <!-- Chips -->
            <div class="details-chips">
                @if (!string.IsNullOrWhiteSpace(Model.Raza))
                {
                    <span class="chip chip-teal">@Model.Raza</span>
                }
                @if (Model.Edad > 0)
                {
                    <span class="chip chip-amber">@Model.Edad año@(Model.Edad != 1 ? "s" : "")</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Tamaño))
                {
                    <span class="chip chip-muted">@Model.Tamaño</span>
                }
            </div>

            <!-- Stats grid -->
            <div class="details-stats">
                <div class="dstat">
                    <div class="dstat-val">@Model.Edad</div>
                    <div class="dstat-lbl">Año@(Model.Edad != 1 ? "s" : "")</div>
                </div>
                <div class="dstat">
                    <div class="dstat-val">@(string.IsNullOrWhiteSpace(Model.Tamaño) ? "—" : Model.Tamaño)</div>
                    <div class="dstat-lbl">Tamaño</div>
                </div>
                <div class="dstat">
                    <div class="dstat-val">
                        @(Model.Dueño != null ? Model.Dueño.Nombre : "—")
                    </div>
                    <div class="dstat-lbl">Dueño</div>
                </div>
            </div>

            <!-- Notas -->
            @if (!string.IsNullOrWhiteSpace(Model.Notas))
            {
                <div class="details-notas">
                    <div class="notas-title">📝 Notas especiales</div>
                    <p class="notas-texto">@Model.Notas</p>
                </div>
            }
        </div>
    </div>

    <!-- Volver -->
    <div class="details-footer">
        <a asp-action="Index" class="btn-volver">← Volver a mis perros</a>
    </div>

</div>

<style>
    .details-wrap { max-width: 820px; margin: 2rem auto; padding: 0 1.5rem 3rem; }

    .page-eyebrow { font-size: .74rem; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; color: var(--teal); margin-bottom: .4rem; }

    .details-hero {
        background: var(--card); border: 1.5px solid var(--border);
        border-radius: 24px; overflow: hidden;
        display: flex; gap: 0;
        box-shadow: 0 4px 16px rgba(45,49,66,.07);
        margin-bottom: 1rem;
    }

    /* Foto lado izquierdo */
    .details-foto-wrap {
        width: 260px; flex-shrink: 0;
        background: var(--teal-l);
        display: flex; align-items: center; justify-content: center;
        min-height: 300px;
    }
    .details-foto {
        width: 100%; height: 100%; object-fit: cover;
        display: block;
    }
    .details-foto-placeholder {
        font-size: 7rem; display: flex;
        align-items: center; justify-content: center;
        width: 100%; height: 100%; min-height: 300px;
    }

    /* Info lado derecho */
    .details-info { flex: 1; padding: 2rem; display: flex; flex-direction: column; gap: 1rem; }

    .details-top-row {
        display: flex; align-items: flex-start;
        justify-content: space-between; gap: 1rem;
    }
    .details-nombre {
        font-weight: 900; font-size: 2rem;
        letter-spacing: -.4px; color: var(--text); margin: 0;
    }
    .details-actions-top { display: flex; gap: .5rem; align-items: center; flex-shrink: 0; }

    .btn-edit-top {
        padding: .4rem 1rem; border-radius: 999px;
        font-size: .82rem; font-weight: 800;
        background: var(--teal-l); color: var(--teal);
        border: 1.5px solid var(--teal-m); text-decoration: none;
        transition: all .18s;
    }
    .btn-edit-top:hover { background: var(--teal); color: #fff; }

    .btn-delete-top {
        padding: .4rem .75rem; border-radius: 999px;
        font-size: .85rem; font-weight: 800;
        background: var(--warm); color: var(--muted);
        border: 1.5px solid var(--border); text-decoration: none;
        transition: all .18s;
    }
    .btn-delete-top:hover { background: #fee2e2; border-color: #fca5a5; color: #dc2626; }

    .details-chips { display: flex; gap: .4rem; flex-wrap: wrap; }
    .chip { padding: .25rem .75rem; border-radius: 999px; font-size: .78rem; font-weight: 800; }
    .chip-teal  { background: var(--teal-l);  color: var(--teal); }
    .chip-amber { background: var(--amber-l); color: var(--amber-d); }
    .chip-muted { background: var(--warm); color: var(--muted); border: 1.5px solid var(--border); }

    .details-stats {
        display: grid; grid-template-columns: repeat(3,1fr); gap: .75rem;
    }
    .dstat {
        background: var(--warm); border-radius: 12px;
        padding: .7rem .9rem; text-align: center;
    }
    .dstat-val { font-weight: 900; font-size: 1.05rem; color: var(--text); margin-bottom: .1rem; }
    .dstat-lbl { font-size: .7rem; color: var(--muted); font-weight: 700; text-transform: uppercase; letter-spacing: .04em; }

    .details-notas {
        background: var(--amber-l); border-radius: 14px;
        padding: .9rem 1.1rem; border: 1.5px solid #fde68a;
    }
    .notas-title { font-weight: 800; font-size: .85rem; color: var(--amber-d); margin-bottom: .4rem; }
    .notas-texto { font-size: .9rem; color: var(--text); font-weight: 600; line-height: 1.6; margin: 0; }

    .details-footer { display: flex; }
    .btn-volver {
        padding: .55rem 1.25rem; border-radius: 999px;
        font-size: .88rem; font-weight: 800;
        background: var(--warm); color: var(--muted);
        border: 1.5px solid var(--border); text-decoration: none;
        transition: all .18s;
    }
    .btn-volver:hover { border-color: var(--teal); background: var(--teal-l); color: var(--teal); }

    @@media (max-width: 640px) {
        .details-hero     { flex-direction: column; }
        .details-foto-wrap{ width: 100%; min-height: 220px; }
        .details-stats    { grid-template-columns: repeat(2,1fr); }
        .details-top-row  { flex-direction: column; }
    }
</style>