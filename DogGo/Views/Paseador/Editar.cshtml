@model DogGo.Models.Paseador
@{
    ViewData["Title"] = "Editar perfil";
    var zonasSeleccionadas = string.IsNullOrWhiteSpace(Model.ZonaServicio)
        ? new List<string>()
        : Model.ZonaServicio.Split(',').Select(z => z.Trim()).ToList();
    var zonasDisponibles = new List<string>
    {
        "Centro", "Cumbres", "San Nicolás", "Guadalupe",
        "Apodaca", "Escobedo", "Contry", "Sur de Monterrey"
    };
}

<div class="editar-wrap">
    <div class="editar-card">

        <!-- Header -->
        <div class="editar-header">
            <div class="page-eyebrow">✏️ Mi perfil</div>
            <h1 class="editar-title">Editar mi perfil</h1>
            <p class="editar-sub">Completa tu perfil para que los dueños te conozcan mejor.</p>
        </div>

        <form asp-action="Editar" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <!-- Foto -->
            <div class="form-section">
                <div class="form-section-title">Foto de perfil</div>
                @if (!string.IsNullOrWhiteSpace(Model.FotoUrl))
                {
                    <img src="@Model.FotoUrl" alt="Foto actual" class="foto-preview-img" />
                }
                else
                {
                    <div class="foto-placeholder">🐾</div>
                }
                <label class="file-upload-btn">
                    📷 Cambiar foto
                    <input type="file" name="fotoArchivo" accept="image/*" style="display:none"
                           onchange="previewFoto(this)" />
                </label>
            </div>

            <!-- Zona de servicio -->
            <div class="form-section">
                <div class="form-section-title">Zona de servicio</div>
                <div class="zonas-grid">
                    @foreach (var zona in zonasDisponibles)
                    {
                        var marcada = zonasSeleccionadas.Contains(zona);
                        <label class="zona-item">
                            <input class="zona-check" type="checkbox"
                                   value="@zona"
                                   id="zona_@zona.Replace(" ", "_")"
                                   @(marcada ? "checked" : null) />
                            <span class="zona-check-custom"></span>
                            @zona
                        </label>
                    }
                </div>
                <input type="hidden" name="zonaServicio" id="zonaServicio" value="@Model.ZonaServicio" />
            </div>

            <!-- Experiencia -->
            <div class="form-group">
                <label class="form-lbl" for="ExperienciaAnios">Años de experiencia</label>
                <input asp-for="ExperienciaAnios" type="number" class="form-ctrl"
                       min="0" placeholder="Ej. 2" />
            </div>

            <!-- Descripción -->
            <div class="form-group">
                <label class="form-lbl">Descripción</label>
                <textarea asp-for="Descripcion" class="form-ctrl form-ta" rows="4"
                          placeholder="Cuéntales a los dueños sobre ti, tu experiencia y cómo cuidas a los perritos..."></textarea>
            </div>

            <!-- Tarifa -->
            <div class="form-group">
                <label class="form-lbl" asp-for="TarifaPorHora">Tarifa por hora ($)</label>
                <input asp-for="TarifaPorHora" type="number" step="0.01"
                       class="form-ctrl" min="0" />
            </div>

            <!-- Disponibilidad -->
            <div class="disponible-wrap">
                <div>
                    <div class="disponible-label">Disponible para paseos</div>
                    <div class="disponible-sub">Los dueños podrán solicitarte paseos</div>
                </div>
                <label class="toggle-wrap">
                    <input asp-for="Disponible" type="checkbox" class="toggle-input" />
                    <span class="toggle-track"></span>
                </label>
            </div>

            <!-- Acciones -->
            <div class="editar-actions">
                <button type="submit" class="btn-save">Guardar cambios</button>
                <a asp-action="Perfil" class="btn-cancel">Cancelar</a>
            </div>

        </form>
    </div>
</div>

<style>
    .editar-wrap {
        max-width: 580px;
        margin: 2rem auto;
        padding: 0 1.5rem 3rem;
    }
    .editar-card {
        background: var(--card);
        border: 1.5px solid var(--border);
        border-radius: 24px;
        padding: 2rem;
        box-shadow: 0 4px 16px rgba(45,49,66,.07);
    }

    .editar-header { margin-bottom: 1.75rem; }
    .page-eyebrow  {
        font-size: .73rem; font-weight: 800; letter-spacing: .1em;
        text-transform: uppercase; color: var(--teal); margin-bottom: .4rem;
    }
    .editar-title { font-weight: 900; font-size: 1.5rem; letter-spacing: -.3px; color: var(--text); margin-bottom: .25rem; }
    .editar-sub   { color: var(--muted); font-size: .88rem; font-weight: 600; }

    /* Form sections */
    .form-section       { margin-bottom: 1.5rem; }
    .form-section-title { font-size: .82rem; font-weight: 800; color: var(--text); margin-bottom: .75rem; }
    .form-group         { margin-bottom: 1.25rem; }
    .form-lbl           { font-size: .82rem; font-weight: 800; color: var(--text); display: block; margin-bottom: .4rem; }

    .form-ctrl {
        width: 100%; padding: .55rem .9rem;
        border-radius: 12px; border: 1.5px solid var(--border);
        font-family: 'Nunito', sans-serif; font-size: .9rem;
        font-weight: 600; outline: none; background: #fff;
        transition: border-color .18s; color: var(--text);
    }
    .form-ctrl:focus { border-color: var(--teal); }
    .form-ta { resize: vertical; min-height: 100px; }

    /* Foto */
    .foto-preview-img {
        width: 90px; height: 90px; border-radius: 50%;
        object-fit: cover; border: 3px solid var(--teal-l);
        display: block; margin-bottom: .75rem;
    }
    .foto-placeholder {
        width: 90px; height: 90px; border-radius: 50%;
        background: var(--teal-l); display: flex;
        align-items: center; justify-content: center;
        font-size: 2.5rem; margin-bottom: .75rem;
    }
    .file-upload-btn {
        display: inline-flex; align-items: center; gap: .4rem;
        padding: .4rem 1rem; border-radius: 999px;
        font-size: .82rem; font-weight: 800;
        background: var(--warm); color: var(--text);
        border: 1.5px solid var(--border); cursor: pointer;
        transition: border-color .18s, background .18s;
    }
    .file-upload-btn:hover { border-color: var(--teal); background: var(--teal-l); color: var(--teal); }

    /* Zonas grid */
    .zonas-grid {
        display: grid; grid-template-columns: 1fr 1fr;
        gap: .5rem; background: var(--warm);
        border: 1.5px solid var(--border);
        border-radius: 14px; padding: 1rem;
    }
    .zona-item {
        display: flex; align-items: center; gap: .55rem;
        font-size: .87rem; font-weight: 700; color: var(--text);
        cursor: pointer; padding: .3rem .5rem;
        border-radius: 8px; transition: background .15s;
    }
    .zona-item:hover { background: var(--teal-l); }
    .zona-item input { display: none; }
    .zona-check-custom {
        width: 18px; height: 18px; border-radius: 6px;
        border: 2px solid var(--border); background: #fff;
        flex-shrink: 0; transition: all .18s;
        display: flex; align-items: center; justify-content: center;
    }
    .zona-item input:checked ~ .zona-check-custom {
        background: var(--teal); border-color: var(--teal);
    }
    .zona-item input:checked ~ .zona-check-custom::after {
        content: '✓'; color: #fff; font-size: .7rem; font-weight: 900;
    }

    /* Disponibilidad toggle */
    .disponible-wrap {
        display: flex; align-items: center; justify-content: space-between;
        background: var(--warm); border: 1.5px solid var(--border);
        border-radius: 14px; padding: .9rem 1.1rem; margin-bottom: 1.5rem;
    }
    .disponible-label { font-weight: 800; font-size: .92rem; color: var(--text); margin-bottom: .15rem; }
    .disponible-sub   { font-size: .78rem; color: var(--muted); font-weight: 600; }

    .toggle-wrap  { position: relative; display: inline-block; flex-shrink: 0; }
    .toggle-input { opacity: 0; width: 0; height: 0; position: absolute; }
    .toggle-track {
        display: block; width: 46px; height: 26px;
        border-radius: 999px; background: var(--border);
        cursor: pointer; transition: background .2s;
        position: relative;
    }
    .toggle-track::after {
        content: ''; position: absolute;
        width: 20px; height: 20px; border-radius: 50%;
        background: #fff; top: 3px; left: 3px;
        transition: left .2s; box-shadow: 0 1px 4px rgba(0,0,0,.15);
    }
    .toggle-input:checked + .toggle-track { background: var(--teal); }
    .toggle-input:checked + .toggle-track::after { left: 23px; }

    /* Acciones */
    .editar-actions { display: flex; flex-direction: column; gap: .6rem; }
    .btn-save {
        width: 100%; padding: .75rem; border-radius: 999px;
        font-size: .95rem; font-weight: 900; font-family: 'Nunito', sans-serif;
        background: var(--teal); color: #fff; border: none; cursor: pointer;
        box-shadow: 0 4px 14px rgba(15,155,142,.25); transition: background .18s, transform .15s;
    }
    .btn-save:hover { background: var(--teal-d); transform: translateY(-1px); }
    .btn-cancel {
        width: 100%; padding: .7rem; border-radius: 999px;
        font-size: .9rem; font-weight: 800; text-align: center;
        background: #fff; color: var(--muted);
        border: 1.5px solid var(--border); cursor: pointer;
        transition: background .18s; text-decoration: none; display: block;
    }
    .btn-cancel:hover { background: var(--warm); color: var(--muted); }
</style>

@section Scripts {
    <script>
        // Sincronizar checkboxes de zonas → hidden input
        function actualizarZonas() {
            const checks  = document.querySelectorAll(".zona-check:checked");
            const valores = Array.from(checks).map(c => c.value);
            document.getElementById("zonaServicio").value = valores.join(", ");
        }
        document.querySelectorAll(".zona-check").forEach(chk => {
            chk.addEventListener("change", actualizarZonas);
        });
        actualizarZonas();

        // Preview foto antes de subir
        function previewFoto(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    let img = document.querySelector('.foto-preview-img');
                    let ph  = document.querySelector('.foto-placeholder');
                    if (!img) {
                        img = document.createElement('img');
                        img.className = 'foto-preview-img';
                        if (ph) ph.replaceWith(img);
                        else document.querySelector('.form-section').prepend(img);
                    }
                    img.src = e.target.result;
                };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}