@model DogGo.Models.Perro
@{
    ViewData["Title"] = "Registrar perro";
}

<div class="form-page-wrap">
    <div class="form-card">

        <div class="form-card-header">
            <div class="page-eyebrow">🐾 Nueva mascota</div>
            <h1 class="form-title">Registrar perro</h1>
            <p class="form-sub">Completa el perfil de tu mascota para poder solicitar paseos.</p>
        </div>

        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="foto-section">
                <div class="foto-preview" id="fotoPreview">
                    <span id="fotoEmoji">🐶</span>
                    <img id="fotoImg" src="" alt="Vista previa de la foto" style="display:none" />
                </div>
                <label class="file-upload-btn">
                    📷 Subir foto
                    <input type="file"
                           name="imagenArchivo"
                           id="imagenArchivo"
                           accept=".jpg,.jpeg,.png,.webp"
                           onchange="previewFoto(this)" />
                </label>
                <span class="file-hint">JPG, PNG o WEBP · Máx. 5 MB</span>
            </div>

            <span asp-validation-for="ImagenUrl" class="val-error"></span>

            <div class="form-group">
                <label asp-for="Nombre" class="form-lbl">Nombre</label>
                <input asp-for="Nombre" class="form-ctrl" placeholder="Ej. Max" />
                <span asp-validation-for="Nombre" class="val-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Raza" class="form-lbl">Raza</label>
                <input asp-for="Raza" class="form-ctrl" placeholder="Ej. Golden Retriever" />
                <span asp-validation-for="Raza" class="val-error"></span>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Edad" class="form-lbl">Edad (años)</label>
                    <input asp-for="Edad" type="number" min="0" class="form-ctrl" placeholder="Ej. 3" />
                    <span asp-validation-for="Edad" class="val-error"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Tamaño" class="form-lbl">Tamaño</label>
                    <select asp-for="Tamaño" class="form-ctrl form-sel">
                        <option value="">Selecciona</option>
                        <option value="Pequeño">Pequeño</option>
                        <option value="Mediano">Mediano</option>
                        <option value="Grande">Grande</option>
                    </select>
                    <span asp-validation-for="Tamaño" class="val-error"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="Notas" class="form-lbl">Notas especiales</label>
                <textarea asp-for="Notas"
                          class="form-ctrl form-ta"
                          rows="3"
                          placeholder="Alergias, comportamiento, instrucciones para el paseador..."></textarea>
                <span asp-validation-for="Notas" class="val-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save">Guardar perro 🐾</button>
                <a asp-action="Index" class="btn-cancel">Cancelar</a>
            </div>
        </form>

    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="@Url.Content("~/css/perro.css")" />
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function previewFoto(input) {
            if (input.files && input.files[0]) {
                const reader = new FileReader();

                reader.onload = function (e) {
                    const img = document.getElementById('fotoImg');
                    const emoji = document.getElementById('fotoEmoji');

                    img.src = e.target.result;
                    img.style.display = 'block';
                    emoji.style.display = 'none';
                };

                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}