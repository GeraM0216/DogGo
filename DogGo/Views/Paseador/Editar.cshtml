@model DogGo.Models.Paseador
@{
    ViewData["Title"] = "Editar perfil";

    var zonasSeleccionadas = string.IsNullOrWhiteSpace(Model.ZonaServicio)
        ? new List<string>()
        : Model.ZonaServicio.Split(',').Select(z => z.Trim()).ToList();

    var zonasDisponibles = new List<string>
    {
        "Centro",
        "Cumbres",
        "San Nicolás",
        "Guadalupe",
        "Apodaca",
        "Escobedo",
        "Contry",
        "Sur de Monterrey"
    };
}

<div style="max-width:560px; margin:2rem auto; padding:0 1rem">
    <h4>✏️ Editar mi perfil</h4>
    <p class="text-muted">Completa tu perfil para que los dueños te conozcan mejor.</p>

    <form asp-action="Editar" method="post" enctype="multipart/form-data" class="mt-3">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="form-group mb-3">
            <label class="form-label">Foto de perfil</label>
            <input type="file" name="fotoArchivo" class="form-control" accept="image/*" />
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.FotoUrl))
        {
            <div class="mb-3">
                <img src="@Model.FotoUrl" alt="Foto actual"
                     style="width:110px; height:110px; object-fit:cover; border-radius:50%; border:1px solid #ddd;" />
            </div>
        }

        <div class="form-group mb-3">
            <label class="form-label">Zona de servicio</label>
            <div class="border rounded p-3 bg-light">
                @foreach (var zona in zonasDisponibles)
                {
                    var marcada = zonasSeleccionadas.Contains(zona);
                    <div class="form-check">
                        <input class="form-check-input zona-check"
                               type="checkbox"
                               value="@zona"
                               id="zona_@zona.Replace(" ", "_")"
                        @(marcada ? "checked" : null) />
                        <label class="form-check-label" for="zona_@zona.Replace(" ", "_")">
                            @zona
                        </label>
                    </div>
                }
            </div>
            <input type="hidden" name="zonaServicio" id="zonaServicio" value="@Model.ZonaServicio" />
        </div>

        <div class="form-group mb-3">
            <label for="ExperienciaAnios">Años de experiencia</label>
            <input asp-for="ExperienciaAnios"
                   type="number"
                   class="form-control"
                   min="0"
                   placeholder="Ej. 2" />
        </div>

        <div class="form-group mb-3">
            <label>Descripción</label>
            <textarea asp-for="Descripcion"
                      class="form-control"
                      rows="4"
                      placeholder="Cuéntales a los dueños sobre ti, tu experiencia y cómo cuidas a los perritos..."></textarea>
        </div>

        <div class="form-group mb-3">
            <label asp-for="TarifaPorHora">Tarifa por hora ($)</label>
            <input asp-for="TarifaPorHora"
                   type="number"
                   step="0.01"
                   class="form-control"
                   min="0" />
        </div>

        <div class="form-check mb-3">
            <input asp-for="Disponible" class="form-check-input" />
            <label asp-for="Disponible" class="form-check-label">
                Estoy disponible para paseos
            </label>
        </div>

        <button type="submit" class="btn btn-primary w-100">Guardar cambios</button>
        <a asp-action="Perfil" class="btn btn-outline-secondary w-100 mt-2">Cancelar</a>
    </form>
</div>

@section Scripts {
    <script>
        function actualizarZonas() {
            const checks = document.querySelectorAll(".zona-check:checked");
            const valores = Array.from(checks).map(c => c.value);
            document.getElementById("zonaServicio").value = valores.join(", ");
        }

        document.querySelectorAll(".zona-check").forEach(chk => {
            chk.addEventListener("change", actualizarZonas);
        });

        actualizarZonas();
    </script>
}