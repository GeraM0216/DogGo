@{
    ViewData["Title"] = "Inicio";
    var nombreUsuario = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "Usuario";
    var esDuenio = User.IsInRole("Duenio");
    var esPaseador = User.IsInRole("Paseador");

    // Datos reales del dueño (desde ViewBag)
    var paseoActivo = ViewBag.PaseoActivo as DogGo.Models.Paseo;
    var ultimoPaseo = ViewBag.UltimoPaseo as DogGo.Models.Paseo;
    var totalPaseos = (int?)ViewBag.TotalPaseos ?? 0;
    var perros = ViewBag.Perros as List<DogGo.Models.Perro> ?? new List<DogGo.Models.Perro>();
}

@if (User.Identity!.IsAuthenticated && esDuenio)
{
    <!-- ══════════════════════════════════════
         VISTA DUEÑO DE MASCOTA
    ══════════════════════════════════════ -->
    <!-- ── Hero ── -->
    <section class="hero-section">
        <div class="hero-inner">
            <div class="hero-left">
                <div class="hero-eyebrow">👋 Bienvenido de vuelta</div>
                <h1 class="hero-title">
                    Hola, <span class="hero-name">@nombreUsuario</span>.<br>
                    ¿Cómo están tus peludos hoy?
                </h1>
                <p class="hero-sub">
                    Todo lo que necesitas para cuidar a tus mascotas está aquí.
                </p>

                <!-- Banner paseo activo (datos reales) -->
                @if (paseoActivo != null)
                {
                    <div class="paseo-banner">
                        <div class="pb-icon">@(paseoActivo.Estado == "EnCurso" ? "🟢" : "🕐")</div>
                        <div class="pb-info">
                            <div class="pb-title">
                                @(paseoActivo.Estado == "EnCurso" ? "Paseo en curso" : "Paseo pendiente") — @paseoActivo.Perro?.Nombre
                            </div>
                            <div class="pb-sub">
                                con @paseoActivo.Paseador?.Usuario?.Nombre @paseoActivo.Paseador?.Usuario?.Apellido
                                @if (paseoActivo.EsProgramado && paseoActivo.FechaProgramada != null)
                                {
                                    <span>· @paseoActivo.FechaProgramada?.ToLocalTime().ToString("dd/MM HH:mm")</span>
                                }
                            </div>
                        </div>
                        <a asp-controller="Paseo" asp-action="Mapa" asp-route-id="@paseoActivo.Id"
                           class="pb-btn">Ver en mapa</a>
                    </div>
                }

                <div class="hero-ctas">
                    <a asp-controller="Paseador" asp-action="Directorio" class="btn-primary-doggo">
                        Buscar paseador
                    </a>
                    <a asp-controller="Paseo" asp-action="MisPaseos" class="btn-secondary-doggo">
                        Mis paseos
                    </a>
                </div>
            </div>

            <!-- Widget mascotas -->
            <div class="hero-right">
                <div class="pet-widget">
                    <div class="pw-header">
                        <div>
                            <div class="pw-title">Tus mascotas</div>
                            <div class="pw-subtitle">Toca las flechas para cambiar</div>
                        </div>
                        <a asp-controller="Perro" asp-action="Create" class="pw-add-btn">+ Añadir</a>
                    </div>

                    <div id="pw-loading" class="pw-state">
                        <div class="pw-spinner"></div>
                        <p>Cargando tus mascotas...</p>
                    </div>
                    <div id="pw-empty" class="pw-state" style="display:none">
                        <div class="pw-empty-icon">🐾</div>
                        <p>Aún no tienes mascotas registradas.</p>
                        <a asp-controller="Perro" asp-action="Create"
                               class="btn-primary-doggo" style="margin-top:.75rem;display:inline-block">
                            Registrar mi primer perro
                        </a>
                    </div>
                    <div id="pw-card" style="display:none">
                        <div class="pet-photo-wrap">
                            <img id="pw-foto" src="" alt="" class="pet-photo-img" style="display:none" />
                            <div id="pw-foto-fallback" class="pet-photo-fallback">🐶</div>
                        </div>
                        <div class="pet-info">
                            <div class="pet-name" id="pw-nombre"></div>
                            <div class="pet-breed" id="pw-raza"></div>
                        </div>
                        <div class="pet-stats">
                            <div class="pstat"><div class="pstat-val" id="pw-edad"></div><div class="pstat-lbl">Edad</div></div>
                            <div class="pstat"><div class="pstat-val" id="pw-tamaño"></div><div class="pstat-lbl">Tamaño</div></div>
                        </div>
                        <div id="pw-notas-wrap" class="pet-notas" style="display:none">
                            <span class="notas-label">📝 Notas:</span>
                            <span id="pw-notas"></span>
                        </div>
                        <div class="pet-nav">
                            <button class="pnav-btn" onclick="DogGoWidget.prev()">&#8249;</button>
                            <div class="pet-dots" id="pw-dots"></div>
                            <button class="pnav-btn" onclick="DogGoWidget.next()">&#8250;</button>
                        </div>
                        <a id="pw-ver-perfil" href="#" class="pet-ver-perfil">Ver perfil completo →</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── Resumen del dueño (datos reales) ── -->
    <div class="resumen-band">
        <div class="resumen-inner">
            <div class="rstat">
                <div class="rstat-val">@perros.Count</div>
                <div class="rstat-lbl">Mascota@(perros.Count != 1 ? "s" : "") registrada@(perros.Count != 1 ? "s" : "")</div>
            </div>
            <div class="rstat-sep"></div>
            <div class="rstat">
                <div class="rstat-val">@totalPaseos</div>
                <div class="rstat-lbl">Paseo@(totalPaseos != 1 ? "s" : "") completado@(totalPaseos != 1 ? "s" : "")</div>
            </div>
            <div class="rstat-sep"></div>
            <div class="rstat">
                @if (ultimoPaseo != null)
                {
                    <div class="rstat-val rstat-small">@ultimoPaseo.Perro?.Nombre</div>
                    <div class="rstat-lbl">Último paseo · @ultimoPaseo.FechaFin?.ToLocalTime().ToString("dd/MM/yyyy")</div>
                }
                else
                {
                    <div class="rstat-val">—</div>
                    <div class="rstat-lbl">Sin paseos aún</div>
                }
            </div>
            <div class="rstat-sep"></div>
            <div class="rstat">
                @if (paseoActivo != null)
                {
                    <div class="rstat-val rstat-green">● Activo</div>
                    <div class="rstat-lbl">Paseo @paseoActivo.Estado.ToLower()</div>
                }
                else
                {
                    <div class="rstat-val">—</div>
                    <div class="rstat-lbl">Sin paseo activo</div>
                }
            </div>
        </div>
    </div>

    <!-- ── Artículos y consejos ── -->
    <section class="home-section">
        <div class="section-inner">
            <div class="sec-label">🐾 Cuidado y bienestar</div>
            <h2 class="sec-title">Consejos para tu mejor amigo</h2>
            <p class="sec-sub">Lo que todo dueño de perro debería saber para mantenerlo sano y feliz.</p>
            <div class="articulos-grid">
                <div class="articulo-card art-featured">
                    <div class="art-emoji">🥗</div>
                    <div class="art-tag">Nutrición</div>
                    <div class="art-title">¿Qué debe comer tu perro según su tamaño?</div>
                    <p class="art-desc">La alimentación varía mucho entre razas pequeñas y grandes. Descubre las porciones ideales y los alimentos que debes evitar.</p>
                    <div class="art-meta">5 min de lectura</div>
                </div>
                <div class="articulo-card">
                    <div class="art-emoji">🏃</div>
                    <div class="art-tag">Ejercicio</div>
                    <div class="art-title">¿Cuántos paseos necesita tu perro al día?</div>
                    <p class="art-desc">No todos los perros necesitan lo mismo. Conoce la frecuencia ideal según raza y edad.</p>
                    <div class="art-meta">3 min de lectura</div>
                </div>
                <div class="articulo-card">
                    <div class="art-emoji">💉</div>
                    <div class="art-tag">Salud</div>
                    <div class="art-title">Calendario de vacunación: lo esencial</div>
                    <p class="art-desc">Mantener el esquema de vacunas al día es fundamental. Te explicamos qué vacunas son obligatorias y cuándo.</p>
                    <div class="art-meta">4 min de lectura</div>
                </div>
                <div class="articulo-card">
                    <div class="art-emoji">🛁</div>
                    <div class="art-tag">Higiene</div>
                    <div class="art-title">¿Con qué frecuencia bañar a tu perro?</div>
                    <p class="art-desc">Bañarlo demasiado puede afectar su piel. Aprende la frecuencia correcta según el tipo de pelaje.</p>
                    <div class="art-meta">3 min de lectura</div>
                </div>
                <div class="articulo-card">
                    <div class="art-emoji">🧠</div>
                    <div class="art-tag">Comportamiento</div>
                    <div class="art-title">Señales de estrés en perros que debes conocer</div>
                    <p class="art-desc">Los perros no hablan, pero su cuerpo lo dice todo. Aprende a leer su lenguaje y actuar a tiempo.</p>
                    <div class="art-meta">6 min de lectura</div>
                </div>
                <div class="articulo-card">
                    <div class="art-emoji">❤️</div>
                    <div class="art-tag">Bienestar</div>
                    <div class="art-title">Actividades para hacer con tu perro en casa</div>
                    <p class="art-desc">Cuando no puedes salir, estas actividades de estimulación mental mantendrán a tu perro entretenido y feliz.</p>
                    <div class="art-meta">4 min de lectura</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── Productos recomendados ── -->
    <section class="home-section alt-bg">
        <div class="section-inner">
            <div class="sec-label">🛍️ Para tu mascota</div>
            <h2 class="sec-title">Productos recomendados</h2>
            <p class="sec-sub">Una selección de productos que los dueños de DogGo usan y recomiendan.</p>
            <div class="productos-grid">
                <div class="producto-card">
                    <div class="prod-emoji">🎾</div>
                    <div class="prod-nombre">Juguete Kong Classic</div>
                    <div class="prod-desc">Ideal para perros que mastican mucho. Rellénalo con premios para horas de entretenimiento.</div>
                    <div class="prod-tags"><span class="prod-tag">Juguete</span><span class="prod-tag">Todas las razas</span></div>
                    <a href="https://www.amazon.com.mx/s?k=kong+classic+perro" target="_blank" class="prod-btn">Ver en Amazon →</a>
                </div>
                <div class="producto-card">
                    <div class="prod-emoji">🏠</div>
                    <div class="prod-nombre">Cama ortopédica para perros</div>
                    <div class="prod-desc">Especialmente recomendada para perros mayores o razas grandes. Cuida sus articulaciones.</div>
                    <div class="prod-tags"><span class="prod-tag">Descanso</span><span class="prod-tag">Razas grandes</span></div>
                    <a href="https://www.amazon.com.mx/s?k=cama+ortopedica+perro" target="_blank" class="prod-btn">Ver en Amazon →</a>
                </div>
                <div class="producto-card">
                    <div class="prod-emoji">🦮</div>
                    <div class="prod-nombre">Arnés antipull ajustable</div>
                    <div class="prod-desc">Paseos más cómodos y seguros. Reduce el jalón sin lastimar el cuello de tu perro.</div>
                    <div class="prod-tags"><span class="prod-tag">Paseos</span><span class="prod-tag">Seguridad</span></div>
                    <a href="https://www.amazon.com.mx/s?k=arnes+antipull+perro" target="_blank" class="prod-btn">Ver en Amazon →</a>
                </div>
                <div class="producto-card">
                    <div class="prod-emoji">🍖</div>
                    <div class="prod-nombre">Snacks naturales deshidratados</div>
                    <div class="prod-desc">Sin conservantes ni colorantes. Perfectos para premiar durante el entrenamiento.</div>
                    <div class="prod-tags"><span class="prod-tag">Nutrición</span><span class="prod-tag">Entrenamiento</span></div>
                    <a href="https://www.amazon.com.mx/s?k=snacks+naturales+perro" target="_blank" class="prod-btn">Ver en Amazon →</a>
                </div>
            </div>
        </div>
    </section>

    <!-- ── Lugares en Monterrey ── -->
    <section class="home-section">
        <div class="section-inner">
            <div class="sec-label">📍 Monterrey y área metro</div>
            <h2 class="sec-title">Lugares para tu mascota cerca de ti</h2>
            <p class="sec-sub">Veterinarias, parques y tiendas especializadas en el área metropolitana de Monterrey.</p>
            <div class="lugares-grid">
                <div class="lugar-card">
                    <div class="lugar-icon lc-teal">🏥</div>
                    <div class="lugar-info">
                        <div class="lugar-nombre">Hospital Veterinario Mascota Feliz</div>
                        <div class="lugar-dir">Av. Garza Sada 2501, Monterrey</div>
                        <div class="lugar-tags"><span class="lugar-tag">Veterinaria</span><span class="lugar-tag">24 horas</span></div>
                    </div>
                    <a href="https://maps.google.com/?q=Hospital+Veterinario+Monterrey" target="_blank" class="lugar-btn">Ver mapa</a>
                </div>
                <div class="lugar-card">
                    <div class="lugar-icon lc-green">🌳</div>
                    <div class="lugar-info">
                        <div class="lugar-nombre">Parque Canino España</div>
                        <div class="lugar-dir">Av. España, San Pedro Garza García</div>
                        <div class="lugar-tags"><span class="lugar-tag">Parque</span><span class="lugar-tag">Dog friendly</span></div>
                    </div>
                    <a href="https://maps.google.com/?q=Parque+España+San+Pedro+Garza+Garcia" target="_blank" class="lugar-btn">Ver mapa</a>
                </div>
                <div class="lugar-card">
                    <div class="lugar-icon lc-amber">🛍️</div>
                    <div class="lugar-info">
                        <div class="lugar-nombre">PetCo Cumbres</div>
                        <div class="lugar-dir">Av. Fidel Velázquez, Cumbres</div>
                        <div class="lugar-tags"><span class="lugar-tag">Tienda</span><span class="lugar-tag">Grooming</span></div>
                    </div>
                    <a href="https://maps.google.com/?q=Petco+Cumbres+Monterrey" target="_blank" class="lugar-btn">Ver mapa</a>
                </div>
                <div class="lugar-card">
                    <div class="lugar-icon lc-coral">🐾</div>
                    <div class="lugar-info">
                        <div class="lugar-nombre">Adopta Nuevo León</div>
                        <div class="lugar-dir">Varios puntos de adopción en el área metro</div>
                        <div class="lugar-tags"><span class="lugar-tag">Adopción</span><span class="lugar-tag">Rescate</span></div>
                    </div>
                    <a href="https://www.facebook.com/adoptanl" target="_blank" class="lugar-btn">Ver página</a>
                </div>
                <div class="lugar-card">
                    <div class="lugar-icon lc-teal">🏥</div>
                    <div class="lugar-info">
                        <div class="lugar-nombre">Clínica Veterinaria UANL</div>
                        <div class="lugar-dir">Campus Ciencias Agropecuarias, Escobedo</div>
                        <div class="lugar-tags"><span class="lugar-tag">Veterinaria</span><span class="lugar-tag">Económica</span></div>
                    </div>
                    <a href="https://maps.google.com/?q=Clinica+Veterinaria+UANL+Escobedo" target="_blank" class="lugar-btn">Ver mapa</a>
                </div>
                <div class="lugar-card">
                    <div class="lugar-icon lc-green">🌳</div>
                    <div class="lugar-info">
                        <div class="lugar-nombre">Parque La Pastora</div>
                        <div class="lugar-dir">Av. La Pastora, Guadalupe</div>
                        <div class="lugar-tags"><span class="lugar-tag">Parque</span><span class="lugar-tag">Amplio</span></div>
                    </div>
                    <a href="https://maps.google.com/?q=Parque+La+Pastora+Guadalupe+Monterrey" target="_blank" class="lugar-btn">Ver mapa</a>
                </div>
            </div>
        </div>
    </section>

    <!-- ── Razas destacadas ── -->
    <section class="home-section alt-bg">
        <div class="section-inner">
            <div class="sec-label">🐕 ¿Sabías que...?</div>
            <h2 class="sec-title">Curiosidades de razas populares</h2>
            <p class="sec-sub">Datos interesantes sobre las razas más comunes que pasean en DogGo.</p>
            <div class="razas-grid">
                <div class="raza-card" onclick="toggleRaza(this)">
                    <div class="raza-top">
                        <span class="raza-emoji">🐕</span>
                        <div>
                            <div class="raza-nombre">Golden Retriever</div>
                            <div class="raza-sub">Mediano–Grande · 25–34 kg</div>
                        </div>
                        <span class="raza-toggle">+</span>
                    </div>
                    <div class="raza-detalle" style="display:none">
                        <p>Necesita al menos <strong>2 horas de ejercicio diario</strong>. Son extremadamente sociables — no son buenos perros guardianes. Su pelaje doble requiere cepillado 2-3 veces por semana. Promedio de vida: 10–12 años.</p>
                    </div>
                </div>
                <div class="raza-card" onclick="toggleRaza(this)">
                    <div class="raza-top">
                        <span class="raza-emoji">🐩</span>
                        <div>
                            <div class="raza-nombre">Poodle (Caniche)</div>
                            <div class="raza-sub">Pequeño–Grande · 3–32 kg</div>
                        </div>
                        <span class="raza-toggle">+</span>
                    </div>
                    <div class="raza-detalle" style="display:none">
                        <p>Son considerados la <strong>segunda raza más inteligente</strong> del mundo. Su pelaje no suelta pelo, ideal para personas con alergia. Necesitan grooming profesional cada 6–8 semanas. Muy activos y juguetones.</p>
                    </div>
                </div>
                <div class="raza-card" onclick="toggleRaza(this)">
                    <div class="raza-top">
                        <span class="raza-emoji">🦴</span>
                        <div>
                            <div class="raza-nombre">Labrador Retriever</div>
                            <div class="raza-sub">Grande · 25–36 kg</div>
                        </div>
                        <span class="raza-toggle">+</span>
                    </div>
                    <div class="raza-detalle" style="display:none">
                        <p>La raza más popular del mundo durante décadas. Tienen tendencia a la <strong>obesidad</strong> — controla sus porciones. Aman el agua y son excelentes nadadores. Requieren mucho ejercicio: mínimo 1.5–2 horas diarias.</p>
                    </div>
                </div>
                <div class="raza-card" onclick="toggleRaza(this)">
                    <div class="raza-top">
                        <span class="raza-emoji">🐶</span>
                        <div>
                            <div class="raza-nombre">French Bulldog</div>
                            <div class="raza-sub">Pequeño · 8–14 kg</div>
                        </div>
                        <span class="raza-toggle">+</span>
                    </div>
                    <div class="raza-detalle" style="display:none">
                        <p>Por su hocico corto, son <strong>sensibles al calor</strong> — evita ejercicio intenso en días calurosos. No necesitan mucho ejercicio: 30 min diarios es suficiente. Son muy sociables y les encanta estar con personas.</p>
                    </div>
                </div>
                <div class="raza-card" onclick="toggleRaza(this)">
                    <div class="raza-top">
                        <span class="raza-emoji">🐾</span>
                        <div>
                            <div class="raza-nombre">Pastor Alemán</div>
                            <div class="raza-sub">Grande · 22–40 kg</div>
                        </div>
                        <span class="raza-toggle">+</span>
                    </div>
                    <div class="raza-detalle" style="display:none">
                        <p>Necesitan <strong>estimulación mental además de física</strong>. Sin ejercicio suficiente pueden volverse destructivos. Son extremadamente leales y protectores. Su doble capa de pelo requiere cepillado frecuente, especialmente en temporada de muda.</p>
                    </div>
                </div>
                <div class="raza-card" onclick="toggleRaza(this)">
                    <div class="raza-top">
                        <span class="raza-emoji">🐕‍🦺</span>
                        <div>
                            <div class="raza-nombre">Beagle</div>
                            <div class="raza-sub">Pequeño–Mediano · 9–11 kg</div>
                        </div>
                        <span class="raza-toggle">+</span>
                    </div>
                    <div class="raza-detalle" style="display:none">
                        <p>Tienen el olfato más desarrollado entre las razas domésticas — pueden seguir un rastro por kilómetros. Son <strong>muy vocales</strong> (aúllan). Necesitan ejercicio diario para no aburrirse. Son excelentes con niños y muy sociables.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── CTA accesos rápidos ── -->
    <section class="cta-section">
        <div class="cta-inner">
            <div class="cta-header">
                <div class="cta-badge">🎉 ¡Todo listo para ti!</div>
                <h2 class="cta-title">Prueba nuestros <span class="cta-em">servicios hoy</span></h2>
                <p class="cta-sub">Las funciones que más usas, siempre a un clic de distancia.</p>
            </div>
            <div class="cta-grid">
                <a asp-controller="Paseo" asp-action="MisPaseos" class="cta-card">
                    <span class="cta-card-icon">🦮</span>
                    <div class="cta-card-title">Ver mis paseos</div>
                    <div class="cta-card-desc">Activos, historial y seguimiento en tiempo real.</div>
                </a>
                <a asp-controller="Paseador" asp-action="Directorio" class="cta-card">
                    <span class="cta-card-icon">🔍</span>
                    <div class="cta-card-title">Buscar paseador</div>
                    <div class="cta-card-desc">Encuentra al paseador perfecto para tu mascota.</div>
                </a>
                <a asp-controller="Perro" asp-action="Index" class="cta-card">
                    <span class="cta-card-icon">🐶</span>
                    <div class="cta-card-title">Mis perros</div>
                    <div class="cta-card-desc">Administra perfiles, fotos y datos de tus mascotas.</div>
                </a>
            </div>
        </div>
    </section>
}
else if (User.Identity!.IsAuthenticated && esPaseador)
{
    <!-- ══════════════════════════════════════
         VISTA PASEADOR
    ══════════════════════════════════════ -->
    <section class="hero-section">
        <div class="hero-inner" style="grid-template-columns:1fr">
            <div class="hero-left" style="max-width:600px">
                <div class="hero-eyebrow">👋 Bienvenido de vuelta</div>
                <h1 class="hero-title">
                    Hola, <span class="hero-name">@nombreUsuario</span>.<br>
                    ¿Listo para hoy?
                </h1>
                <p class="hero-sub">Revisa tus paseos pendientes y mantén tu perfil actualizado.</p>
                <div class="hero-ctas">
                    <a asp-controller="Paseo" asp-action="MisPaseos" class="btn-primary-doggo">Ver mis paseos</a>
                    <a asp-controller="Paseador" asp-action="Perfil" class="btn-secondary-doggo">Mi perfil</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Accesos rápidos paseador -->
    <section class="cta-section" style="border-top:1.5px solid var(--border)">
        <div class="cta-inner">
            <div class="cta-grid">
                <a asp-controller="Paseo" asp-action="MisPaseos" class="cta-card">
                    <span class="cta-card-icon">🦮</span>
                    <div class="cta-card-title">Mis paseos</div>
