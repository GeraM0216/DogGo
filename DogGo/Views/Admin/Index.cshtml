@model DogGo.ViewModels.AdminDashboardViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Panel Admin";

    string MostrarRol(string rol)
    {
        return rol == "Duenio" ? "Dueño" : rol;
    }

    string EstadoClase(string estado)
    {
        return estado switch
        {
            "Pendiente" => "pill-amber",
            "EnCurso" => "pill-green",
            "Finalizado" => "pill-muted",
            "Cancelado" => "pill-red",
            _ => ""
        };
    }

    string EstadoTexto(string estado)
    {
        return estado switch
        {
            "EnCurso" => "En curso",
            _ => estado
        };
    }

    string FechaPaseo(DogGo.ViewModels.AdminPaseoItemViewModel p)
    {
        var fecha = p.FechaCancelacion
            ?? p.FechaFin
            ?? p.FechaInicio
            ?? p.FechaProgramada;

        return fecha?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "—";
    }

    var topPaseadores = Model.PaseosPorPaseador
        .OrderByDescending(p => p.Finalizados)
        .Take(6)
        .ToList();

    var ingresosPorPaseador = Model.PaseosPorPaseador
        .Where(p => p.TotalIngresos > 0)
        .OrderByDescending(p => p.TotalIngresos)
        .Take(6)
        .ToList();

    var paseadorConMasPaseos = Model.PaseosPorPaseador.OrderByDescending(p => p.Finalizados).FirstOrDefault();
    var paseadorConMasIngresos = Model.PaseosPorPaseador.OrderByDescending(p => p.TotalIngresos).FirstOrDefault();

    var estadosLabels = new[] { "Pendientes", "En curso", "Finalizados", "Cancelados" };
    var estadosData = new[] { Model.PaseosPendientes, Model.PaseosEnCurso, Model.PaseosFinalizados, Model.PaseosCancelados };

    var rolesLabels = new[] { "Dueños", "Paseadores", "Admins" };
    var rolesData = new[] { Model.TotalDuenios, Model.TotalPaseadoresUsuarios, Model.TotalAdmins };

    var topPaseadoresLabels = topPaseadores.Select(p => p.PaseadorNombre).ToList();
    var topPaseadoresData = topPaseadores.Select(p => p.Finalizados).ToList();

    var ingresosLabels = ingresosPorPaseador.Select(p => p.PaseadorNombre).ToList();
    var ingresosData = ingresosPorPaseador.Select(p => p.TotalIngresos).ToList();
}

<div class="admin-wrap">

    @if (TempData["Exito"] != null)
    {
        <div class="admin-alert admin-alert-ok">@TempData["Exito"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="admin-alert admin-alert-error">@TempData["Error"]</div>
    }

    <div class="admin-hero">
        <div>
            <div class="page-eyebrow">Panel de administración</div>
            <h1 class="admin-title">Dashboard Admin</h1>
            <p class="admin-sub">
                Métricas, actividad reciente, usuarios, paseadores, perros y paseos registrados en DogGo.
            </p>
        </div>

        <div class="admin-hero-badge">
            <span>Vista general</span>
            <strong>@DateTime.Now.ToString("dd/MM/yyyy")</strong>
        </div>
    </div>

    <div class="admin-tabs">
        <a href="#dashboard">Dashboard</a>
        <a href="#actividad">Actividad</a>
        <a href="#usuarios">Usuarios</a>
        <a href="#perros">Perros</a>
        <a href="#paseadores">Paseadores</a>
        <a href="#paseos">Paseos</a>
    </div>

    <section id="dashboard">
        <div class="admin-stats-grid">
            <div class="admin-stat-card">
                <div class="admin-stat-icon">👥</div>
                <div class="admin-stat-num">@Model.TotalUsuarios</div>
                <div class="admin-stat-label">Usuarios</div>
            </div>

            <div class="admin-stat-card">
                <div class="admin-stat-icon">🐶</div>
                <div class="admin-stat-num">@Model.TotalPerros</div>
                <div class="admin-stat-label">Perros</div>
            </div>

            <div class="admin-stat-card">
                <div class="admin-stat-icon">🦮</div>
                <div class="admin-stat-num">@Model.TotalPaseadores</div>
                <div class="admin-stat-label">Paseadores</div>
            </div>

            <div class="admin-stat-card">
                <div class="admin-stat-icon">📍</div>
                <div class="admin-stat-num">@Model.TotalPaseos</div>
                <div class="admin-stat-label">Paseos</div>
            </div>

            <div class="admin-stat-card stat-amber">
                <div class="admin-stat-icon">⏳</div>
                <div class="admin-stat-num">@Model.PaseosPendientes</div>
                <div class="admin-stat-label">Pendientes</div>
            </div>

            <div class="admin-stat-card stat-green">
                <div class="admin-stat-icon">▶</div>
                <div class="admin-stat-num">@Model.PaseosEnCurso</div>
                <div class="admin-stat-label">En curso</div>
            </div>

            <div class="admin-stat-card stat-muted">
                <div class="admin-stat-icon">✅</div>
                <div class="admin-stat-num">@Model.PaseosFinalizados</div>
                <div class="admin-stat-label">Finalizados</div>
            </div>

            <div class="admin-stat-card stat-red">
                <div class="admin-stat-icon">✕</div>
                <div class="admin-stat-num">@Model.PaseosCancelados</div>
                <div class="admin-stat-label">Cancelados</div>
            </div>
        </div>

        <div class="admin-kpi-grid">
            <div class="admin-kpi-card kpi-money">
                <div class="admin-kpi-icon">💰</div>
                <div>
                    <div class="admin-kpi-label">Ingresos finalizados</div>
                    <div class="admin-kpi-value">$@Model.IngresosFinalizados.ToString("0.00")</div>
                    <div class="admin-kpi-sub">Solo paseos finalizados</div>
                </div>
            </div>

            <div class="admin-kpi-card">
                <div class="admin-kpi-icon">🎟</div>
                <div>
                    <div class="admin-kpi-label">Ticket promedio</div>
                    <div class="admin-kpi-value">$@Model.TicketPromedioFinalizados.ToString("0.00")</div>
                    <div class="admin-kpi-sub">Promedio por paseo finalizado</div>
                </div>
            </div>

            <div class="admin-kpi-card">
                <div class="admin-kpi-icon">🏆</div>
                <div>
                    <div class="admin-kpi-label">Más paseos finalizados</div>
                    <div class="admin-kpi-value">
                        @(paseadorConMasPaseos != null ? paseadorConMasPaseos.PaseadorNombre : "—")
                    </div>
                    <div class="admin-kpi-sub">
                        @(paseadorConMasPaseos != null ? $"{paseadorConMasPaseos.Finalizados} finalizados" : "Sin datos")
                    </div>
                </div>
            </div>

            <div class="admin-kpi-card">
                <div class="admin-kpi-icon">📈</div>
                <div>
                    <div class="admin-kpi-label">Mayor ingreso</div>
                    <div class="admin-kpi-value">
                        @(paseadorConMasIngresos != null ? paseadorConMasIngresos.PaseadorNombre : "—")
                    </div>
                    <div class="admin-kpi-sub">
                        @(paseadorConMasIngresos != null ? $"${paseadorConMasIngresos.TotalIngresos.ToString("0.00")}" : "Sin datos")
                    </div>
                </div>
            </div>

            <div class="admin-kpi-card">
                <div class="admin-kpi-icon">🆕</div>
                <div>
                    <div class="admin-kpi-label">Usuarios nuevos</div>
                    <div class="admin-kpi-value">@Model.UsuariosNuevosUltimos7Dias</div>
                    <div class="admin-kpi-sub">Últimos 7 días</div>
                </div>
            </div>

            <div class="admin-kpi-card @(Model.SolicitudesFinalizacionPendientes > 0 ? "kpi-warning" : "")">
                <div class="admin-kpi-icon">⚠️</div>
                <div>
                    <div class="admin-kpi-label">Solicitudes pendientes</div>
                    <div class="admin-kpi-value">@Model.SolicitudesFinalizacionPendientes</div>
                    <div class="admin-kpi-sub">Finalización anticipada</div>
                </div>
            </div>
        </div>

        <div class="admin-dashboard-grid">
            <section class="admin-section dashboard-section dashboard-charts-section">
                <div class="admin-section-header">
                    <h2>Gráficas generales</h2>
                    <span>Vista ejecutiva</span>
                </div>

                <div class="charts-grid">
                    <div class="chart-card">
                        <div class="chart-card-header">
                            <div>
                                <h3>Paseos por estado</h3>
                                <p>Pendientes, en curso, finalizados y cancelados.</p>
                            </div>
                        </div>
                        <div class="chart-box chart-box-small">
                            <canvas id="chartPaseosEstado"></canvas>
                        </div>
                    </div>

                    <div class="chart-card">
                        <div class="chart-card-header">
                            <div>
                                <h3>Usuarios por rol</h3>
                                <p>Dueños, paseadores y administradores.</p>
                            </div>
                        </div>
                        <div class="chart-box chart-box-small">
                            <canvas id="chartUsuariosRol"></canvas>
                        </div>
                    </div>

                    <div class="chart-card chart-card-wide">
                        <div class="chart-card-header">
                            <div>
                                <h3>Top paseadores por finalizados</h3>
                                <p>No cuenta cancelados ni pendientes.</p>
                            </div>
                        </div>
                        <div class="chart-box">
                            <canvas id="chartTopPaseadores"></canvas>
                        </div>
                    </div>

                    <div class="chart-card chart-card-wide">
                        <div class="chart-card-header">
                            <div>
                                <h3>Ingresos por paseador</h3>
                                <p>Usa el precio real guardado en paseos finalizados.</p>
                            </div>
                        </div>
                        <div class="chart-box">
                            <canvas id="chartIngresosPaseador"></canvas>
                        </div>
                    </div>
                </div>
            </section>

            <section id="actividad" class="admin-section activity-section">
                <div class="admin-section-header">
                    <h2>Actividad reciente</h2>
                    <span>@Model.ActividadReciente.Count movimientos</span>
                </div>

                <div class="activity-list">
                    @foreach (var a in Model.ActividadReciente)
                    {
                        <a asp-controller="Paseo"
                               asp-action="Mapa"
                               asp-route-id="@a.PaseoId"
                               class="activity-item">
                            <div class="activity-dot @EstadoClase(a.Estado)"></div>

                            <div class="activity-main">
                                <strong>@a.Accion</strong>
                                <span>Paseo #@a.PaseoId · @a.PerroNombre</span>
                            </div>

                            <div class="activity-meta">
                                <span>@a.PaseadorNombre</span>
                                <span>@a.Fecha.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                        </a>
                    }

                    @if (!Model.ActividadReciente.Any())
                    {
                        <div class="empty-admin">No hay actividad reciente registrada.</div>
                    }
                </div>
            </section>
        </div>
    </section>

    <section class="admin-section">
        <div class="admin-section-header">
            <h2>Paseos por paseador</h2>
            <span>@Model.PaseosPorPaseador.Count registros</span>
        </div>

        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Paseador</th>
                        <th>Email</th>
                        <th>Total</th>
                        <th>Pendientes</th>
                        <th>En curso</th>
                        <th>Finalizados</th>
                        <th>Cancelados</th>
                        <th>Ingresos</th>
                        <th>Ticket prom.</th>
                        <th>Calificación</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.PaseosPorPaseador)
                    {
                        <tr>
                            <td>@p.PaseadorNombre</td>
                            <td>@p.Email</td>
                            <td><span class="admin-pill">@p.TotalPaseos</span></td>
                            <td><span class="admin-pill pill-amber">@p.Pendientes</span></td>
                            <td><span class="admin-pill pill-green">@p.EnCurso</span></td>
                            <td><span class="admin-pill pill-muted">@p.Finalizados</span></td>
                            <td><span class="admin-pill pill-red">@p.Cancelados</span></td>
                            <td>$@p.TotalIngresos.ToString("0.00")</td>
                            <td>$@p.TicketPromedio.ToString("0.00")</td>
                            <td>⭐ @p.CalificacionPromedio.ToString("0.0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section id="usuarios" class="admin-section">
        <div class="admin-section-header">
            <h2>Usuarios registrados</h2>
            <span>@Model.Usuarios.Count registros</span>
        </div>

        <form asp-action="Index" method="get" class="admin-filtros-grid">
            <div class="admin-filter-group">
                <label>Buscar usuario</label>
                <input type="text"
                       name="busquedaUsuario"
                       value="@Model.BusquedaUsuario"
                       placeholder="Nombre, email o teléfono"
                       class="admin-input" />
            </div>

            <div class="admin-filter-group">
                <label>Rol</label>
                <select name="rolFiltro" class="admin-input admin-select">
                    <option value="">Todos</option>
                    <option value="Admin" selected="@(Model.RolFiltro == "Admin")">Admin</option>
                    <option value="Duenio" selected="@(Model.RolFiltro == "Duenio")">Dueño</option>
                    <option value="Paseador" selected="@(Model.RolFiltro == "Paseador")">Paseador</option>
                </select>
            </div>

            <div class="admin-filter-group">
                <label>Correo</label>
                <select name="emailConfirmadoFiltro" class="admin-input admin-select">
                    <option value="">Todos</option>
                    <option value="true" selected="@(Model.EmailConfirmadoFiltro == "true")">Confirmado</option>
                    <option value="false" selected="@(Model.EmailConfirmadoFiltro == "false")">Pendiente</option>
                </select>
            </div>

            <div class="admin-filter-actions">
                <button type="submit" class="admin-btn-primary">Filtrar</button>
                <a asp-action="Index" class="admin-btn-secondary">Limpiar</a>
            </div>
        </form>

        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Email</th>
                        <th>Teléfono</th>
                        <th>Rol</th>
                        <th>Cambiar rol</th>
                        <th>Correo</th>
                        <th>Registro</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model.Usuarios)
                    {
                        <tr>
                            <td>#@u.Id</td>
                            <td>@u.NombreCompleto</td>
                            <td>@u.Email</td>
                            <td>@(string.IsNullOrWhiteSpace(u.Telefono) ? "—" : u.Telefono)</td>
                            <td><span class="admin-pill">@MostrarRol(u.Rol)</span></td>
                            <td>
                                <form asp-action="CambiarRol" method="post" class="rol-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="usuarioId" value="@u.Id" />

                                    <select name="nuevoRol" class="rol-select">
                                        <option value="Admin" selected="@(u.Rol == "Admin")">Admin</option>
                                        <option value="Duenio" selected="@(u.Rol == "Duenio")">Dueño</option>
                                        <option value="Paseador" selected="@(u.Rol == "Paseador")">Paseador</option>
                                    </select>

                                    <button type="submit"
                                            class="btn-rol-guardar"
                                            onclick="return confirm('¿Seguro que quieres cambiar el rol de este usuario?')">
                                        Guardar
                                    </button>
                                </form>
                            </td>
                            <td>
                                @if (u.EmailConfirmado)
                                {
                                    <span class="admin-pill pill-green">Confirmado</span>
                                }
                                else
                                {
                                    <form asp-action="ConfirmarCorreo" method="post" class="inline-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="usuarioId" value="@u.Id" />
                                        <button type="submit"
                                                class="btn-mini-warning"
                                                onclick="return confirm('¿Confirmar manualmente este correo?')">
                                            Confirmar
                                        </button>
                                    </form>
                                }
                            </td>
                            <td>@u.FechaRegistro.ToLocalTime().ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section id="perros" class="admin-section">
        <div class="admin-section-header">
            <h2>Perros registrados</h2>
            <span>@Model.Perros.Count registros</span>
        </div>

        <form asp-action="Index" method="get" class="admin-filtros-grid filtros-compactos">
            <div class="admin-filter-group">
                <label>Buscar perro</label>
                <input type="text"
                       name="busquedaPerro"
                       value="@Model.BusquedaPerro"
                       placeholder="Perro, raza, dueño o email"
                       class="admin-input" />
            </div>

            <div class="admin-filter-group">
                <label>Tamaño</label>
                <select name="tamanioFiltro" class="admin-input admin-select">
                    <option value="">Todos</option>
                    <option value="Pequeño" selected="@(Model.TamanioFiltro == "Pequeño")">Pequeño</option>
                    <option value="Mediano" selected="@(Model.TamanioFiltro == "Mediano")">Mediano</option>
                    <option value="Grande" selected="@(Model.TamanioFiltro == "Grande")">Grande</option>
                </select>
            </div>

            <div class="admin-filter-actions">
                <button type="submit" class="admin-btn-primary">Filtrar</button>
                <a asp-action="Index" class="admin-btn-secondary">Limpiar</a>
            </div>
        </form>

        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Perro</th>
                        <th>Raza</th>
                        <th>Edad</th>
                        <th>Tamaño</th>
                        <th>Dueño</th>
                        <th>Email dueño</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Perros)
                    {
                        <tr>
                            <td>#@p.Id</td>
                            <td>@p.Nombre</td>
                            <td>@(string.IsNullOrWhiteSpace(p.Raza) ? "—" : p.Raza)</td>
                            <td>@p.Edad</td>
                            <td>@(string.IsNullOrWhiteSpace(p.Tamanio) ? "—" : p.Tamanio)</td>
                            <td>@p.DuenioNombre</td>
                            <td>@p.DuenioEmail</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section id="paseadores" class="admin-section">
        <div class="admin-section-header">
            <h2>Paseadores</h2>
            <span>@Model.Paseadores.Count registros</span>
        </div>

        <form asp-action="Index" method="get" class="admin-filtros-grid">
            <div class="admin-filter-group">
                <label>Buscar paseador</label>
                <input type="text"
                       name="busquedaPaseador"
                       value="@Model.BusquedaPaseador"
                       placeholder="Nombre, email o zona"
                       class="admin-input" />
            </div>

            <div class="admin-filter-group">
                <label>Disponible</label>
                <select name="disponibleFiltro" class="admin-input admin-select">
                    <option value="">Todos</option>
                    <option value="true" selected="@(Model.DisponibleFiltro == "true")">Sí</option>
                    <option value="false" selected="@(Model.DisponibleFiltro == "false")">No</option>
                </select>
            </div>

            <div class="admin-filter-group">
                <label>Ordenar</label>
                <select name="ordenPaseador" class="admin-input admin-select">
                    <option value="">Nombre</option>
                    <option value="calificacion_desc" selected="@(Model.OrdenPaseador == "calificacion_desc")">Mejor calificación</option>
                    <option value="tarifa_asc" selected="@(Model.OrdenPaseador == "tarifa_asc")">Menor tarifa</option>
                    <option value="tarifa_desc" selected="@(Model.OrdenPaseador == "tarifa_desc")">Mayor tarifa</option>
                    <option value="experiencia_desc" selected="@(Model.OrdenPaseador == "experiencia_desc")">Más experiencia</option>
                    <option value="paseos_desc" selected="@(Model.OrdenPaseador == "paseos_desc")">Más paseos finalizados</option>
                </select>
            </div>

            <div class="admin-filter-actions">
                <button type="submit" class="admin-btn-primary">Filtrar</button>
                <a asp-action="Index" class="admin-btn-secondary">Limpiar</a>
            </div>
        </form>

        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Paseador</th>
                        <th>Email</th>
                        <th>Tarifa</th>
                        <th>Calificación</th>
                        <th>Finalizados</th>
                        <th>Ingresos</th>
                        <th>Zona</th>
                        <th>Exp.</th>
                        <th>Disponible</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Paseadores)
                    {
                        <tr>
                            <td>#@p.Id</td>
                            <td>@p.NombreCompleto</td>
                            <td>@p.Email</td>
                            <td>$@p.TarifaPorHora.ToString("0.00")</td>
                            <td>⭐ @p.CalificacionPromedio.ToString("0.0")</td>
                            <td>@p.TotalPaseos</td>
                            <td>$@p.IngresosFinalizados.ToString("0.00")</td>
                            <td>@(string.IsNullOrWhiteSpace(p.ZonaServicio) ? "—" : p.ZonaServicio)</td>
                            <td>@(p.ExperienciaAnios.HasValue ? $"{p.ExperienciaAnios} años" : "—")</td>
                            <td>
                                <form asp-action="CambiarDisponibilidadPaseador" method="post" class="inline-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="paseadorId" value="@p.Id" />

                                    <button type="submit"
                                            class="btn-pill-toggle @(p.Disponible ? "toggle-on" : "toggle-off")">
                                        @(p.Disponible ? "Sí" : "No")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section id="paseos" class="admin-section">
        <div class="admin-section-header">
            <h2>Paseos</h2>
            <span>@Model.Paseos.Count registros</span>
        </div>

        <form asp-action="Index" method="get" class="admin-filtros-grid filtros-paseos">
            <div class="admin-filter-group">
                <label>Buscar paseo</label>
                <input type="text"
                       name="busquedaPaseo"
                       value="@Model.BusquedaPaseo"
                       placeholder="Perro, dueño, paseador o zona"
                       class="admin-input" />
            </div>

            <div class="admin-filter-group">
                <label>Estado</label>
                <select name="estadoFiltro" class="admin-input admin-select">
                    <option value="">Todos</option>
                    <option value="Pendiente" selected="@(Model.EstadoFiltro == "Pendiente")">Pendiente</option>
                    <option value="EnCurso" selected="@(Model.EstadoFiltro == "EnCurso")">En curso</option>
                    <option value="Finalizado" selected="@(Model.EstadoFiltro == "Finalizado")">Finalizado</option>
                    <option value="Cancelado" selected="@(Model.EstadoFiltro == "Cancelado")">Cancelado</option>
                </select>
            </div>

            <div class="admin-filter-group">
                <label>Paseador</label>
                <select name="paseadorIdFiltro" class="admin-input admin-select">
                    <option value="">Todos</option>
                    @foreach (var p in Model.PaseadoresFiltro)
                    {
                        <option value="@p.Id" selected="@(Model.PaseadorIdFiltro == p.Id)">
                            @p.NombreCompleto
                        </option>
                    }
                </select>
            </div>

            <div class="admin-filter-group">
                <label>Desde</label>
                <input type="date"
                       name="fechaDesde"
                       value="@(Model.FechaDesde?.ToString("yyyy-MM-dd"))"
                       class="admin-input" />
            </div>

            <div class="admin-filter-group">
                <label>Hasta</label>
                <input type="date"
                       name="fechaHasta"
                       value="@(Model.FechaHasta?.ToString("yyyy-MM-dd"))"
                       class="admin-input" />
            </div>

            <div class="admin-filter-actions">
                <button type="submit" class="admin-btn-primary">Filtrar</button>
                <a asp-action="Index" class="admin-btn-secondary">Limpiar</a>
            </div>
        </form>

        <div class="admin-table-wrap">
            <table class="admin-table admin-table-wide">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Estado</th>
                        <th>Perro(s)</th>
                        <th>Dueño</th>
                        <th>Paseador</th>
                        <th>Precio</th>
                        <th>Duración</th>
                        <th>Tipo</th>
                        <th>Fecha</th>
                        <th>Zona</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Paseos)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Paseo"
                                       asp-action="Mapa"
                                       asp-route-id="@p.Id"
                                       class="admin-link">
                                    #@p.Id
                                </a>
                            </td>
                            <td>
                                <span class="admin-pill @EstadoClase(p.Estado)">
                                    @EstadoTexto(p.Estado)
                                </span>

                                @if (p.FinalizacionAnticipadaAprobada == true)
                                {
                                    <span class="admin-pill pill-red">Anticipado</span>
                                }
                                else if (p.FinalizacionAnticipadaSolicitada && p.FinalizacionAnticipadaAprobada == null)
                                {
                                    <span class="admin-pill pill-amber">Solicitud</span>
                                }
                            </td>
                            <td>@p.PerroNombre</td>
                            <td>@p.DuenioNombre</td>
                            <td>@p.PaseadorNombre</td>
                            <td>$@p.Precio.ToString("0.00")</td>
                            <td>
                                @p.DuracionMinutos min

                                @if (p.DuracionRealMinutos.HasValue)
                                {
                                    <span class="admin-muted">/ real @p.DuracionRealMinutos min</span>
                                }
                            </td>
                            <td>@(p.EsProgramado ? "Programado" : "Ahora")</td>
                            <td>@FechaPaseo(p)</td>
                            <td>@(string.IsNullOrWhiteSpace(p.ZonaRecoleccion) ? "—" : p.ZonaRecoleccion)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

